<Window x:Class="FarmaciaPOS.Views.ProductosWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Productos"
        Height="650"
        Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#EEF2F7">

    <Grid Margin="15">

        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->

        <Border Background="White"
                CornerRadius="10"
                Padding="20"
                Margin="0,0,0,15">

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="300"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Gestión de Productos"
                           FontSize="32"
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>

                <TextBox x:Name="txtBuscar"
                         Grid.Column="1"
                         Height="45"
                         FontSize="18"
                         VerticalContentAlignment="Center"
                         Text="Buscar producto..."/>

            </Grid>

        </Border>

        <!-- CONTENIDO -->

        <Grid Grid.Row="1">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- FORMULARIO -->

            <Border Background="White"
                    CornerRadius="10"
                    Padding="20"
                    Margin="0,0,15,0">

                <ScrollViewer>

                    <StackPanel>

                        <TextBlock Text="Nuevo Producto"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Margin="0,0,0,20"/>

                        <!-- NOMBRE -->

                        <TextBlock Text="Nombre"
                                   FontWeight="Bold"
                                   FontSize="16"/>

                        <TextBox x:Name="txtNombre"
                                 Height="40"
                                 FontSize="16"
                                 Margin="0,5,0,15"/>

                        <!-- CODIGO -->

                        <TextBlock Text="Código de Barras"
                                   FontWeight="Bold"
                                   FontSize="16"/>

                        <TextBox x:Name="txtCodigo"
                                 Height="40"
                                 FontSize="16"
                                 Margin="0,5,0,15"/>

                        <!-- DESCRIPCION -->

                        <TextBlock Text="Descripción"
                                   FontWeight="Bold"
                                   FontSize="16"/>

                        <TextBox x:Name="txtDescripcion"
                                 Height="80"
                                 FontSize="16"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 Margin="0,5,0,15"/>

                        <!-- CATEGORIA -->

                        <TextBlock Text="Categoría"
                                   FontWeight="Bold"
                                   FontSize="16"/>

                        <ComboBox x:Name="cbCategorias"
                                  Height="40"
                                  FontSize="16"
                                  DisplayMemberPath="Nombre"
                                  SelectedValuePath="Id"
                                  Margin="0,5,0,15"/>

                        <!-- PRECIO COMPRA -->

                        <TextBlock Text="Precio Compra"
                                   FontWeight="Bold"
                                   FontSize="16"/>

                        <TextBox x:Name="txtPrecioCompra"
                                 Height="40"
                                 FontSize="16"
                                 Margin="0,5,0,15"/>

                        <!-- PRECIO VENTA -->

                        <TextBlock Text="Precio Venta"
                                   FontWeight="Bold"
                                   FontSize="16"/>

                        <TextBox x:Name="txtPrecioVenta"
                                 Height="40"
                                 FontSize="16"
                                 Margin="0,5,0,15"/>

                        <!-- STOCK -->

                        <TextBlock Text="Stock"
                                   FontWeight="Bold"
                                   FontSize="16"/>

                        <TextBox x:Name="txtStock"
                                 Height="40"
                                 FontSize="16"
                                 Margin="0,5,0,15"/>

                        <!-- STOCK MINIMO -->

                        <TextBlock Text="Stock Mínimo"
                                   FontWeight="Bold"
                                   FontSize="16"/>

                        <TextBox x:Name="txtStockMinimo"
                                 Height="40"
                                 FontSize="16"
                                 Margin="0,5,0,15"/>

                        <!-- CADUCIDAD -->

                        <TextBlock Text="Caducidad"
                                   FontWeight="Bold"
                                   FontSize="16"/>

                        <DatePicker x:Name="dpCaducidad"
                                    Height="40"
                                    Margin="0,5,0,15"/>

                        <!-- CONTROLADO -->

                        <TextBlock Text="Imagen URL"
                                   FontWeight="Bold"
                                   Margin="0,10,0,5"/>

                        <TextBox  x:Name="txtImagenURL"
                                  Height="35"
                                  FontSize="14"/>

                        <CheckBox x:Name="chkControlado"
                                  Content="Medicamento Controlado"
                                  FontSize="16"
                                  Margin="0,10,0,15"/>

                        <!-- ACTIVO -->

                        <CheckBox x:Name="chkActivo"
                                  Content="Producto Activo"
                                  FontSize="16"
                                  IsChecked="True"
                                  Margin="0,0,0,20"/>

                        <!-- BOTONES -->

                        <Button Content="Guardar Producto"
                                Height="50"
                                FontSize="18"
                                FontWeight="Bold"
                                Background="#2563EB"
                                Foreground="White"
                                Margin="0,20,0,10"
                                Click="BtnGuardar_Click"/>

                        <Button Content="Actualizar"
                                Height="50"
                                FontSize="18"
                                FontWeight="Bold"
                                Background="#16A34A"
                                Foreground="White"
                                Margin="0,0,0,10"
                                Click="BtnActualizar_Click"/>

                        <Button Content="Eliminar"
                                Height="50"
                                FontSize="18"
                                FontWeight="Bold"
                                Background="#DC2626"
                                Foreground="White"
                                Click="BtnEliminar_Click"/>

                    </StackPanel>

                </ScrollViewer>

            </Border>

            <!-- TABLA -->

            <Border Grid.Column="1"
                    Background="White"
                    CornerRadius="10"
                    Padding="10">

                <DataGrid x:Name="dgProductos"
                          AutoGenerateColumns="False"
                          FontSize="16"
                          CanUserAddRows="False"
                          SelectionChanged="dgProductos_SelectionChanged">

                    <DataGrid.Columns>

                        <DataGridTextColumn Header="ID"
                                            Binding="{Binding Id}"
                                            Width="80"/>

                        <DataGridTextColumn Header="Código"
                                            Binding="{Binding CodigoBarras}"
                                            Width="180"/>

                        <DataGridTextColumn Header="Nombre"
                                            Binding="{Binding Nombre}"
                                            Width="220"/>

                        <DataGridTextColumn Header="Descripción"
                                            Binding="{Binding Descripcion}"
                                            Width="250"/>

                        <DataGridTextColumn Header="Categoría"
                                            Binding="{Binding CategoriaId}"
                                            Width="120"/>

                        <DataGridTextColumn Header="Precio Compra"
                                            Binding="{Binding PrecioCompra}"
                                            Width="140"/>

                        <DataGridTextColumn Header="Precio Venta"
                                            Binding="{Binding PrecioVenta}"
                                            Width="140"/>

                        <DataGridTextColumn Header="Stock"
                                            Binding="{Binding Stock}"
                                            Width="100"/>

                        <DataGridTextColumn Header="Stock Min."
                                            Binding="{Binding StockMinimo}"
                                            Width="120"/>

                        <DataGridCheckBoxColumn Header="Activo"
                                                Binding="{Binding Activo}"
                                                Width="100"/>

                    </DataGrid.Columns>

                </DataGrid>

            </Border>

        </Grid>

    </Grid>

</Window>