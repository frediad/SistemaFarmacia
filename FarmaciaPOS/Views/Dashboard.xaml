<Window x:Class="FarmaciaPOS.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Farmacia POS"
        Height="720"
        Width="1280"
        WindowStartupLocation="CenterScreen"
        Background="#E9ECEF">

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="90"/>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="120"/>
            <RowDefinition Height="80"/>
        </Grid.RowDefinitions>

        <!-- ===================================== -->
        <!-- POS RAPIDO -->
        <!-- ===================================== -->

        <Border Background="White"
                CornerRadius="10"
                Margin="20"
                Padding="15"
                HorizontalAlignment="Right"
                Width="400"
                Grid.Row="2"
                Panel.ZIndex="10">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="89*"/>
                    <ColumnDefinition Width="0*"/>
                    <ColumnDefinition Width="41*"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="120"/>
                    <RowDefinition Height="70"/>
                </Grid.RowDefinitions>

                <TextBox x:Name="txtEscaner"
                         Height="40"
                         FontSize="18"
                         VerticalContentAlignment="Center"
                         KeyDown="txtEscaner_KeyDown" Grid.ColumnSpan="3" Margin="0,5,0,5"/>

                <DataGrid x:Name="dgCarritoDashboard"
                          Grid.Row="1"
                          Margin="0,15,0,15"
                          AutoGenerateColumns="False" Grid.ColumnSpan="3">

                    <DataGrid.Columns>

                        <DataGridTextColumn
                            Header="Producto"
                            Binding="{Binding Nombre}"
                            Width="*"/>

                        <DataGridTextColumn
                            Header="Cant."
                            Binding="{Binding Cantidad}"
                            Width="70"/>

                        <DataGridTextColumn
                            Header="Subtotal"
                            Binding="{Binding Subtotal}"
                            Width="100"/>

                    </DataGrid.Columns>

                </DataGrid>

                <Border Grid.Row="1"
                        Background="#1E293B"
                        CornerRadius="10" Grid.ColumnSpan="3" Margin="0,34,0,0" Grid.RowSpan="2">

                    <StackPanel VerticalAlignment="Center">

                        <TextBlock Text="TOTAL"
                                   Foreground="White"
                                   FontSize="20"
                                   HorizontalAlignment="Center"/>

                        <TextBlock x:Name="txtTotalDashboard"
                                   Text="$0.00"
                                   Foreground="#22C55E"
                                   FontSize="36"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"/>

                    </StackPanel>

                </Border>

                <Button Grid.Row="3"
                        Content="COBRAR"
                        Margin="0,18,0,2"
                        FontSize="20"
                        Height="50"
                        Click="BtnCobrarDashboard_Click" Grid.ColumnSpan="3"/>

            </Grid>

        </Border>

        <!-- ========================================= -->
        <!-- HEADER -->
        <!-- ========================================= -->

        <Border Background="White"
                Grid.Row="0"
                BorderBrush="#D6D6D6"
                BorderThickness="0,0,0,1">

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="350"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="300"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="20,0">

                    <TextBlock Text="+"
                               FontSize="48"
                               FontWeight="Bold"
                               Foreground="#2563EB"/>

                    <StackPanel Margin="10,0">

                        <TextBlock Text="FarmaClick Yatzil"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="#1E3A8A"/>

                        <TextBlock Text="Tu sistema de ventas de confianza"
                                   FontSize="14"
                                   Foreground="Gray"/>

                    </StackPanel>

                </StackPanel>

                <TextBlock Grid.Column="1"
                           Text="farmaClickYatzil.com"
                           FontSize="24"
                           Foreground="#2563EB"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>

                <StackPanel Grid.Column="2"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center">

                    <TextBlock Text="Administrador"
                               FontSize="22"
                               FontWeight="Bold"/>

                    <TextBlock Text="Caja 1 - Principal"
                               FontSize="16"/>

                </StackPanel>

            </Grid>

        </Border>

        <!-- ========================================= -->
        <!-- MENU SUPERIOR -->
        <!-- ========================================= -->

        <Border Grid.Row="1"
                Background="#F8FAFC"
                BorderBrush="#D6D6D6"
                BorderThickness="0,0,0,1">

            <ScrollViewer HorizontalScrollBarVisibility="Hidden">

                <StackPanel Orientation="Horizontal"
                            Margin="10">

                    <Button x:Name="btnVentas"
                            Content="Ventas"
                            Width="160"
                            Height="45"
                            Margin="5"
                            Click="BtnVentas_Click"/>

                    <Button x:Name="btnPedidos"
                            Content="Pedidos"
                            Width="160"
                            Height="45"
                            Margin="5"
                            Click="BtnPedidos_Click"/>

                    <Button x:Name="btnProductos"
                            Content="Productos"
                            Width="160"
                            Height="45"
                            Margin="5"
                            Click="BtnProductos_Click"/>

                    <Button x:Name="btnInventario"
                            Content="Inventario"
                            Width="160"
                            Height="45"
                            Margin="5"
                            Click="BtnInventario_Click"/>


                    <Button x:Name="btnReportes"
                            Content="📈 Reportes"
                            Height="50"
                            Margin="0,0,0,10"
                            Click="BtnReportes_Click"/>

                    <Button x:Name="btnConfiguracion"
                            Content="Configuración"
                            Width="190"
                            Height="45"
                            Margin="5"
                            Click="BtnConfiguracion_Click"/>

                    <Button Content="Caja"
                            Width="160"
                            Height="45"
                            Margin="5"
                            Click="BtnReportes_Click"/>

                    <Button Content="Salir"
                            Width="140"
                            Height="45"
                            Margin="5"
                            Background="#DC2626"
                            Foreground="White"
                            FontWeight="Bold"
                            Click="BtnSalir_Click"/>

                </StackPanel>

            </ScrollViewer>

        </Border>

        <!-- ========================================= -->
        <!-- ÁREA DE VENTA -->
        <!-- ========================================= -->

        <Grid Grid.Row="2"
              Margin="10">

            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="70"/>
                <RowDefinition Height="70"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Background="#2563EB"
                    CornerRadius="5">

                <TextBlock Text="VENTA - Ticket 1"
                           Foreground="White"
                           FontSize="28"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           Margin="20,0"/>

            </Border>

            <!-- CÓDIGO -->

            <Grid Grid.Row="1"
                  Margin="0,10,0,0">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="20"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Código del Producto:"
                           FontSize="24"
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>

                <!-- ✅ x:Name agregado -->
                <TextBox x:Name="txtCodigoProducto"
                         Grid.Column="1"
                         Height="45"
                         FontSize="22"
                         Margin="10,0"
                         KeyDown="txtCodigoProducto_KeyDown"/>

                <Button Grid.Column="2"
                        Content="F3"
                        Height="45"
                        Margin="10,0"/>

                <Button Grid.Column="3"
                        Content="Lector Código Barras"
                        Height="45"
                        Margin="10,0"/>

            </Grid>

            <!-- BOTONES -->

            <WrapPanel Grid.Row="2"
                       Margin="0,10,0,0">

                <!-- ✅ Click agregados -->
                <Button x:Name="btnMasCant"
                        Content="Más Cant."
                        Width="180"
                        Height="50"
                        Margin="5"
                        Click="BtnMasCant_Click"/>

                <Button x:Name="btnCantidad"
                        Content="Cantidad"
                        Width="180"
                        Height="50"
                        Margin="5"
                        Click="BtnCantidad_Click"/>

                <Button x:Name="btnPrecio"
                        Content="Precio"
                        Width="180"
                        Height="50"
                        Margin="5"
                        Click="BtnPrecio_Click"/>

                <Button x:Name="btnDescuento"
                        Content="Descuento"
                        Width="180"
                        Height="50"
                        Margin="5"
                        Click="BtnDescuento_Click"/>

                <Button x:Name="btnBuscar"
                        Content="Buscar"
                        Width="180"
                        Height="50"
                        Margin="5"
                        Click="BtnBuscar_Click"/>

                <Button x:Name="btnPagar"
                        Content="Pagar"
                        Width="180"
                        Height="50"
                        Margin="5"
                        Background="#16A34A"
                        Foreground="White"
                        FontWeight="Bold"
                        Click="BtnPagar_Click"/>

                <Button x:Name="btnEliminar"
                        Content="Eliminar"
                        Width="180"
                        Height="50"
                        Margin="5"
                        Background="#DC2626"
                        Foreground="White"
                        FontWeight="Bold"
                        Click="BtnEliminar_Click"/>

            </WrapPanel>

            <!-- TABLA -->

            <Border Grid.Row="3"
                    Margin="0,10,0,0"
                    Background="White"
                    BorderBrush="#D6D6D6"
                    BorderThickness="1">

                <!-- ✅ x:Name agregado -->
                <DataGrid x:Name="dgCarritoCentral"
                          AutoGenerateColumns="False"
                          HeadersVisibility="Column"
                          CanUserAddRows="False"
                          FontSize="18">

                    <DataGrid.Columns>

                        <DataGridTextColumn Header="Cantidad"
                                            Binding="{Binding Cantidad}"
                                            Width="120"/>

                        <DataGridTextColumn Header="Código"
                                            Binding="{Binding Codigo}"
                                            Width="220"/>

                        <DataGridTextColumn Header="Clave"
                                            Binding="{Binding Clave}"
                                            Width="220"/>

                        <DataGridTextColumn Header="Descripción"
                                            Binding="{Binding Nombre}"
                                            Width="400"/>

                        <DataGridTextColumn Header="Precio"
                                            Binding="{Binding Precio}"
                                            Width="150"/>

                        <DataGridTextColumn Header="Desc."
                                            Binding="{Binding Descuento}"
                                            Width="120"/>

                        <DataGridTextColumn Header="Importe"
                                            Binding="{Binding Subtotal}"
                                            Width="150"/>

                        <DataGridTextColumn Header="Existencia"
                                            Binding="{Binding Existencia}"
                                            Width="150"/>

                    </DataGrid.Columns>

                </DataGrid>

            </Border>

        </Grid>

        <!-- ========================================= -->
        <!-- TOTAL -->
        <!-- ========================================= -->

        <Grid Grid.Row="3"
              Margin="10">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="450"/>
            </Grid.ColumnDefinitions>

            <WrapPanel VerticalAlignment="Center">

                <Button Content="Cambiar"
                        Width="180"
                        Height="55"
                        Margin="5"/>

                <Button Content="Devolución"
                        Width="180"
                        Height="55"
                        Margin="5"/>

                <Button Content="Ticket"
                        Width="180"
                        Height="55"
                        Margin="5"/>

                <!-- ✅ Click agregado -->
                <Button Content="Cobrar"
                        Width="300"
                        Height="70"
                        Margin="5"
                        FontSize="28"
                        Background="#2563EB"
                        Foreground="White"
                        FontWeight="Bold"
                        Click="BtnCobrarCentral_Click"/>

            </WrapPanel>

            <Border Grid.Column="1"
                    Background="White"
                    BorderBrush="#D6D6D6"
                    BorderThickness="1"
                    CornerRadius="10">

                <!-- ✅ x:Name agregado -->
                <TextBlock x:Name="txtTotalCentral"
                           Text="$0.00"
                           FontSize="72"
                           Foreground="#1D4ED8"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"/>

            </Border>

        </Grid>

        <!-- ========================================= -->
        <!-- FOOTER -->
        <!-- ========================================= -->

        <Border Grid.Row="4"
                Background="White"
                BorderBrush="#D6D6D6"
                BorderThickness="1,1,1,0">

            <Grid Margin="20">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="250"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal">

                    <!-- ✅ x:Name agregados -->
                    <TextBlock x:Name="txtFooterTotal"
                               Text="Total: $0.00"
                               FontSize="24"
                               FontWeight="Bold"
                               Margin="20,0"/>

                    <TextBlock x:Name="txtFooterPago"
                               Text="Pago: $0.00"
                               FontSize="24"
                               FontWeight="Bold"
                               Margin="20,0"/>

                    <TextBlock x:Name="txtFooterCambio"
                               Text="Cambio: $0.00"
                               FontSize="24"
                               FontWeight="Bold"
                               Margin="20,0"/>

                </StackPanel>

                <TextBlock Grid.Column="1"
                           Text="27/05/2026 02:30 PM"
                           FontSize="20"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"/>

            </Grid>

        </Border>

    </Grid>

</Window>