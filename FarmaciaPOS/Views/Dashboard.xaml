<Window x:Class="FarmaciaPOS.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sistema de Ventas"
        Height="750"
        Width="1250"
        WindowStartupLocation="CenterScreen"
        Background="#E9ECEF">

    <Grid>

        <Grid.RowDefinitions>
            <!-- HEADER -->
            <RowDefinition Height="90"/>

            <!-- ÁREA ESCANEO -->
            <RowDefinition Height="70"/>

            <!-- DATA GRID PRODUCTOS -->
            <RowDefinition Height="*"/>

            <!-- BOTONES INFERIORES -->
            <RowDefinition Height="120"/>

            <!-- FOOTER -->
            <RowDefinition Height="80"/>
        </Grid.RowDefinitions>

        <!-- ========================================= -->
        <!-- HEADER -->
        <!-- ========================================= -->

        <Border Background="White"
                Grid.Row="0"
                BorderBrush="#D6D6D6"
                BorderThickness="0,0,0,1">

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="400"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="300"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="20,0">

                    <Image Source="/Images/Logo.png"
                           Width="100"
                           Height="50"/>

                    <StackPanel Margin="10,0">

                        <TextBlock Text="FarmaClick Yatzil"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="#1E3A8A"/>

                        <TextBlock Text="Tu sistema de ventas de confianza"
                                   FontSize="14"
                                   Foreground="Gray"/>

                    </StackPanel>

                </StackPanel>

                <TextBlock Grid.Column="1"
                           Text="farmaClickYatzil.com"
                           FontSize="24"
                           Foreground="#2563EB"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>

                <!-- USUARIO -->

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right"
            Margin="0,0,20,0">

                    <StackPanel Margin="0,0,20,0"
                                VerticalAlignment="Center">

                        <TextBlock x:Name="txtUsuarioSesion"
                                   Text="Usuario"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Right"/>

                        <TextBlock Text="Caja Principal"
                                   FontSize="14"
                                   Foreground="Gray"
                                   HorizontalAlignment="Right"/>

                    </StackPanel>

                        <Button Content="Salir"
                                Width="100"
                                Height="40"
                                FontSize="16"
                                Background="#DC2626"
                                Foreground="White"
                                FontWeight="Bold"
                                Click="BtnSalir_Click"/>

                </StackPanel>

            </Grid>

        </Border>

        <!-- ========================================= -->
        <!-- MENU SUPERIOR -->
        <!-- ========================================= -->

        <Border Grid.Row="1"
                Background="#F8FAFC"
                BorderBrush="#D6D6D6"
                BorderThickness="0,0,0,1">

            <ScrollViewer HorizontalScrollBarVisibility="Hidden">

                <StackPanel Orientation="Horizontal"
                            Margin="10">

                    <Button x:Name="btnVentas"
                            Content="Ventas"
                            Width="160"
                            Height="45"
                            Margin="5"
                            Click="BtnVentas_Click"/>

                    <Button x:Name="btnPedidos"
                            Content="Pedidos"
                            Width="160"
                            Height="45"
                            Margin="5"
                            Click="BtnPedidos_Click"/>

                    <Button x:Name="btnProductos"
                            Content="Productos"
                            Width="160"
                            Height="45"
                            Margin="5"
                            Click="BtnProductos_Click"/>

                    <Button x:Name="btnInventario"
                            Content="Inventario"
                            Width="160"
                            Height="45"
                            Margin="5"
                            Click="BtnInventario_Click"/>

                    <Button Content="Reportes"
                            Width="160"
                            Height="45"
                            Margin="5"
                            Click="BtnReportes_Click"/>

                    <Button x:Name="btnConfiguracion"
                            Content="Configuración"
                            Width="190"
                            Height="45"
                            Margin="5"
                            Click="BtnConfiguracion_Click"/>

                    <Button x:Name="btnCaja"
                            Content="Caja"
                            Width="160"
                            Height="45"
                            Margin="5"
                            Click="BtnCaja_Click"/>
                    
                </StackPanel>

            </ScrollViewer>

        </Border>

        <!-- ========================================= -->
        <!-- ÁREA DE VENTA -->
        <!-- ========================================= -->

        <Grid Grid.Row="2"
              Margin="-1">

            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="100"/>
                <RowDefinition Height="75"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Background="#2563EB"
                    CornerRadius="5">

                <TextBlock Text="VENTA - Ticket 1"
                           Foreground="White"
                           FontSize="28"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           Margin="20,0"/>

            </Border>

            <Grid Grid.Row="1"
                  Margin="0,10,0,0">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="250"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Código del Producto:"
                           FontSize="24"
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>

                <TextBox x:Name="txtCodigoProducto"
                         Grid.Column="1"
                         Height="45"
                         FontSize="22"
                         Margin="10,0"
                         KeyDown="txtCodigoProducto_KeyDown"/>

                <Button Grid.Column="2"
                        Content="F3"
                        Height="45"
                        Margin="10,0"/>

                <Button Grid.Column="3"
                        Content="Lector Código Barras"
                        Height="45"
                        Margin="10,0"/>

            </Grid>

            <WrapPanel Grid.Row="2"
                       Margin="0,10,0,0">

                <Button x:Name="btnMasCant"
                        Content="Más Cant."
                        Width="180"
                        Height="50"
                        Margin="5"
                        Click="BtnMasCant_Click"/>

                <Button x:Name="btnCantidad"
                        Content="Cantidad"
                        Width="180"
                        Height="50"
                        Margin="5"
                        Click="BtnCantidad_Click"/>

                <Button x:Name="btnPrecio"
                        Content="Precio"
                        Width="180"
                        Height="50"
                        Margin="5"
                        Click="BtnPrecio_Click"/>

                <Button x:Name="btnDescuento"
                        Content="Descuento"
                        Width="180"
                        Height="50"
                        Margin="5"
                        Click="BtnDescuento_Click"/>

                <Button x:Name="btnBuscar"
                        Content="Buscar"
                        Width="180"
                        Height="50"
                        Margin="5"
                        Click="BtnBuscar_Click"/>

                <Button x:Name="btnPagar"
                        Content="Pagar"
                        Width="180"
                        Height="50"
                        Margin="5"
                        Background="#16A34A"
                        Foreground="White"
                        FontWeight="Bold"
                        Click="BtnPagar_Click"/>

                <Button x:Name="btnEliminar"
                        Content="Eliminar"
                        Width="180"
                        Height="50"
                        Margin="5"
                        Background="#DC2626"
                        Foreground="White"
                        FontWeight="Bold"
                        Click="BtnEliminar_Click"/>

            </WrapPanel>

            <Border Grid.Row="3"
                    Margin="0,10,0,0"
                    Background="White"
                    BorderBrush="#D6D6D6"
                    BorderThickness="1">

                <DataGrid x:Name="dgCarritoCentral"
                          AutoGenerateColumns="False"
                          HeadersVisibility="Column"
                          CanUserAddRows="False"
                          FontSize="18"
                          Margin="10"
                          RowHeight="45"
                          SelectionMode="Single"
                          SelectionUnit="FullRow"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Visible"
                          HorizontalScrollBarVisibility="Auto"
                          MinHeight="450"
                          SelectionChanged="dgCarritoCentral_SelectionChanged_1">

                    <DataGrid.Columns>

                        <DataGridTextColumn Header="Cant."
                            Binding="{Binding Cantidad}"
                            Width="200"/>

                        <DataGridTextColumn Header="Código"
                            Binding="{Binding Codigo}"
                            Width="200"/>

                        <DataGridTextColumn Header="Descripción"
                            Binding="{Binding Nombre}"
                            Width="350"/>

                        <DataGridTextColumn Header="Precio"
                            Binding="{Binding Precio}"
                            Width="120"/>

                        <DataGridTextColumn Header="Importe"
                            Binding="{Binding Subtotal}"
                            Width="140"/>

                        <DataGridTextColumn Header="Stock"
                            Binding="{Binding Existencia}"
                            Width="100"/>

                    </DataGrid.Columns>

                </DataGrid>

            </Border>

        </Grid>

        <!-- ========================================= -->
        <!-- TOTAL                                     -->
        <!-- ========================================= -->

        <Grid Grid.Row="3"
              Height="90"
              Margin="10">

            <Grid.ColumnDefinitions>

                <!-- BOTONES -->
                <ColumnDefinition Width="500"/>

                <!-- TOTAL -->
                <ColumnDefinition Width="400"/>

            </Grid.ColumnDefinitions>

            <!-- ================================= -->
            <!-- BOTONES -->
            <!-- ================================= -->

            <UniformGrid Grid.Column="0"
                 Columns="4"
                 Margin="0,0,10,0">

                <Button Content="Cambiar"
                        Margin="4"
                FontSize="15"
                Height="50"/>

                <Button Content="Devolución"
                Margin="4"
                FontSize="15"
                Height="50"/>

                <Button Content="Ticket"
                Margin="4"
                FontSize="15"
                Height="50"/>

                <Button Content="COBRAR"
                Margin="4"
                FontSize="22"
                FontWeight="Bold"
                Height="40"
                Background="#2563EB"
                Foreground="White"
                Click="BtnCobrarCentral_Click"/>

            </UniformGrid>

            <!-- ================================= -->
            <!-- TOTAL -->
            <!-- ================================= -->

            <Border Grid.Column="2"
            Background="White"
            BorderBrush="#D6D6D6"
            BorderThickness="1"
            CornerRadius="20">

                <StackPanel VerticalAlignment="Center"
                    HorizontalAlignment="Center">

                    <TextBlock Text="TOTAL"
                       FontSize="14"
                       Foreground="Gray"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"/>

                    <TextBlock x:Name="txtTotalCentral"
                       Text="$0.00"
                       FontSize="28"
                       Foreground="#1D4ED8"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"/>

                </StackPanel>

            </Border>

        </Grid>

        <!-- ========================================= -->
        <!-- FOOTER -->
        <!-- ========================================= -->

        <Border Grid.Row="4"
                Background="White"
                BorderBrush="#D6D6D6"
                BorderThickness="1,1,1,0">

            <Grid Margin="20">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="250"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal">

                    <TextBlock x:Name="txtFooterTotal"
                               Text="Total: $0.00"
                               FontSize="24"
                               FontWeight="Bold"
                               Margin="20,0"/>

                    <TextBlock x:Name="txtFooterPago"
                               Text="Pago: $0.00"
                               FontSize="24"
                               FontWeight="Bold"
                               Margin="20,0"/>

                    <TextBlock x:Name="txtFooterCambio"
                               Text="Cambio: $0.00"
                               FontSize="24"
                               FontWeight="Bold"
                               Margin="20,0"/>

                </StackPanel>

                <TextBlock Grid.Column="1"
                           Text="27/05/2026 02:30 PM"
                           FontSize="20"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"/>

            </Grid>

        </Border>

    </Grid>

</Window>