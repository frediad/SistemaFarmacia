<Window x:Class="FarmaciaPOS.Views.InventarioWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Inventario"
        Height="750"
        Width="1300"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7FA">

    <Grid Margin="15">

        <Grid.RowDefinitions>
            <RowDefinition Height="100"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- PANEL SUPERIOR -->

        <Border Background="White"
                CornerRadius="10"
                Padding="15"
                Margin="0,0,0,10">

            <Grid>

                <Grid.ColumnDefinitions>

                    <ColumnDefinition Width="250"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>

                </Grid.ColumnDefinitions>

                <!-- PRODUCTO -->

                <StackPanel>

                    <TextBlock Text="Producto"
                               FontWeight="Bold"/>

                    <ComboBox x:Name="cbProductos"
                              Height="35"/>
                </StackPanel>

                <!-- TIPO -->

                <StackPanel Grid.Column="1"
                            Margin="10,0,0,0">

                    <TextBlock Text="Movimiento"
                               FontWeight="Bold"/>

                    <ComboBox x:Name="cbTipo"
                              Height="35">

                        <ComboBoxItem
                            Content="Entrada"/>

                        <ComboBoxItem
                            Content="Salida"/>

                    </ComboBox>

                </StackPanel>

                <!-- CANTIDAD -->

                <StackPanel Grid.Column="2"
                            Margin="10,0,0,0">

                    <TextBlock Text="Cantidad"
                               FontWeight="Bold"/>

                    <TextBox x:Name="txtCantidad"
                             Height="35"/>
                </StackPanel>

                <!-- MOTIVO -->

                <StackPanel Grid.Column="3"
                            Margin="10,0,0,0">

                    <TextBlock Text="Motivo"
                               FontWeight="Bold"/>

                    <TextBox x:Name="txtMotivo"
                             Height="35"/>
                </StackPanel>

                <!-- BOTON -->

                <Button Grid.Column="4"
                        Content="Guardar"
                        Height="40"
                        Margin="15,20,0,0"
                        Click="BtnGuardar_Click"/>

            </Grid>

        </Border>

        <!-- TABLA -->

        <Border Grid.Row="1"
                Background="White"
                CornerRadius="10"
                Padding="10">

            <DataGrid x:Name="dgMovimientos"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False">

                <DataGrid.Columns>

                    <DataGridTextColumn
                        Header="Producto"
                        Binding="{Binding ProductoNombre}"
                        Width="250"/>

                    <DataGridTextColumn
                        Header="Movimiento"
                        Binding="{Binding TipoMovimiento}"
                        Width="120"/>

                    <DataGridTextColumn
                        Header="Cantidad"
                        Binding="{Binding Cantidad}"
                        Width="120"/>

                    <DataGridTextColumn
                        Header="Fecha"
                        Binding="{Binding Fecha}"
                        Width="180"/>

                    <DataGridTextColumn
                        Header="Motivo"
                        Binding="{Binding Motivo}"
                        Width="250"/>

                </DataGrid.Columns>

            </DataGrid>

        </Border>

    </Grid>

</Window>