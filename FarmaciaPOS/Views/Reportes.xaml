<Window x:Class="FarmaciaPOS.Views.ReportesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Reportes"
        Height="650"
        Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7FA">

    <Grid Margin="20">

        <Grid.RowDefinitions>

            <RowDefinition Height="80"/>

            <RowDefinition Height="70"/>

            <RowDefinition Height="*"/>

        </Grid.RowDefinitions>

        <!-- TITULO -->

        <TextBlock Text="Reportes de Ventas"
                   FontSize="34"
                   FontWeight="Bold"
                   VerticalAlignment="Center"/>

        <!-- FILTROS -->

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal">

            <DatePicker x:Name="dpInicio"
                        Width="180"
                        Height="40"
                        Margin="0,0,10,0"/>

            <DatePicker x:Name="dpFin"
                        Width="180"
                        Height="40"
                        Margin="0,0,10,0"/>

            <Button Content="Buscar"
                    Width="150"
                    Height="40"
                    FontSize="16"
                    Click="BtnBuscar_Click"/>

        </StackPanel>

        <!-- TABLA -->

        <DataGrid x:Name="dgVentas"
                  Grid.Row="2"
                  Margin="0,20,0,0"
                  AutoGenerateColumns="False">

            <DataGrid.Columns>

                <DataGridTextColumn Header="ID"
                                    Binding="{Binding Id}"
                                    Width="80"/>

                <DataGridTextColumn Header="Fecha"
                                    Binding="{Binding Fecha}"
                                    Width="200"/>

                <DataGridTextColumn Header="Usuario"
                                    Binding="{Binding Usuario}"
                                    Width="200"/>

                <DataGridTextColumn Header="Total"
                                    Binding="{Binding Total}"
                                    Width="150"/>

            </DataGrid.Columns>

        </DataGrid>

    </Grid>

</Window>