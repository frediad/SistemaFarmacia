<!DOCTYPE html>
<html>

	<head>
		<title>Tienda Farmacia</title>

		<style>

			body{
			font-family:Arial;
			margin:40px;
			}

			.producto{
			border:1px solid #ddd;
			padding:15px;
			margin-bottom:15px;
			border-radius:10px;
			}

			button{
			padding:10px;
			cursor:pointer;
			}

		</style>

	</head>

	<body>

		<h1>Tienda Online</h1>

		<div id="productos"></div>

		<script>

			const api =
			"https://localhost:7000/api";

			async function cargarProductos()
			{
			const respuesta =
			await fetch(
			`${api}/Productos`);

			const productos =
			await respuesta.json();

			let html = "";

			productos.forEach(p =>
			{
			html += `
			<div class="producto">

				<h3>${p.nombre}</h3>

				<p>
					Precio:
					$${p.precioVenta}
				</p>

				<p>
					Stock:
					${p.stock}
				</p>

				<input
					type="number"
					value="1"
					min="1"
					id="cant_${p.id}">

					<button
						onclick="comprar(${p.id})">

						Comprar

					</button>

				</div>
			`;
			});

			document.getElementById(
			"productos")
			.innerHTML = html;
			}

			async function comprar(id)
			{
			let cantidad =
			document.getElementById(
			`cant_${id}`)
			.value;

			const respuesta =
			await fetch(
			`${api}/Ventas/comprar`,
			{
			method:"POST",

			headers:
			{
			"Content-Type":
			"application/json"
			},

			body:JSON.stringify(
			{
			usuarioId:1,

			clienteId:null,

			productos:
			[
			{
			productoId:id,
			cantidad:
			parseInt(
			cantidad)
			}
			]
			})
			});

			const resultado =
			await respuesta.json();

			alert(
			"Compra realizada");

			cargarProductos();
			}

			cargarProductos();

		</script>

	</body>
</html>