<Window x:Class="FarmaciaPOS.Views.Caducidades"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Productos por Caducar"
        Height="680"
        Width="1200"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F1F4F9"
        FontFamily="Arial"
        FontSize="11">

    <Window.Resources>

        <!-- ================== COLORES DE ESTADO ================== -->
        <Style x:Key="EstadoStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Background" Value="#E0E0E0"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Estado}" Value="CADUCADO">
                    <Setter Property="Background" Value="#FDE7E7"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Estado}" Value="PRÓXIMO A CADUCAR">
                    <Setter Property="Background" Value="#FFF3DE"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Estado}" Value="NO CADUCADO">
                    <Setter Property="Background" Value="#E4F7E9"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="EstadoTextoStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Estado}" Value="CADUCADO">
                    <Setter Property="Foreground" Value="#D32F2F"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Estado}" Value="PRÓXIMO A CADUCAR">
                    <Setter Property="Foreground" Value="#F57C00"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Estado}" Value="NO CADUCADO">
                    <Setter Property="Foreground" Value="#2E7D32"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- ================== BOTONES MODERNOS ================== -->
        <Style x:Key="BotonModerno" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.88"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.75"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ================== ESTILO DE LA LISTA TIPO TABLA (FILAS ALTERNADAS) ================== -->
        <Style x:Key="ListBoxSinBorde" TargetType="ListBox">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="AlternationCount" Value="2"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0"/>
                        <Setter Property="Background" Value="White"/>
                        <Setter Property="Focusable" Value="False"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border Background="{TemplateBinding Background}">
                                        <ContentPresenter/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                                <Setter Property="Background" Value="#F7F9F7"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#EAF5EC"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>

        <!-- ================== ENCABEZADO ================== -->
        <Border Height="90"
                VerticalAlignment="Top"
                CornerRadius="0,0,24,24">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#1B5E20" Offset="0"/>
                    <GradientStop Color="#2E7D32" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>

            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="PRODUCTOS PRÓXIMOS A CADUCAR"
                           Foreground="White"
                           FontSize="26"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Control y seguimiento de caducidad de inventario"
                           Foreground="#DDF2DD"
                           FontSize="13"
                           HorizontalAlignment="Center"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <Grid Margin="30,115,30,25">

            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="65"/>
            </Grid.RowDefinitions>

            <!-- ================== BARRA SUPERIOR ================== -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Background="White"
                        CornerRadius="10"
                        HorizontalAlignment="Left"
                        Width="360"
                        Height="42">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="🔍"
                                   FontSize="15"
                                   Margin="12,0,0,0"
                                   VerticalAlignment="Center"/>
                        <TextBox x:Name="txtBuscar"
                                 Grid.Column="1"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 VerticalContentAlignment="Center"
                                 Margin="8,0,10,0"
                                 FontSize="14"
                                 TextChanged="txtBuscar_TextChanged"/>
                    </Grid>
                </Border>

                <Button x:Name="btnActualizar"
                        Grid.Column="1"
                        Width="160"
                        Height="42"
                        Content="🔄  Actualizar"
                        Background="#1976D2"
                        Style="{StaticResource BotonModerno}"
                        Click="btnActualizar_Click"/>
            </Grid>

            <!-- ================== ENCABEZADOS (fijos, fuera de la lista) ================== -->
            <Border Grid.Row="1"
                    Background="#1B5E20"
                    CornerRadius="12,12,0,0"
                    Margin="0,15,0,0"
                    Padding="20,14"
                    BorderBrush="#1B5E20"
                    BorderThickness="1,1,1,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Imagen" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="Código" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="2" Text="Producto" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="3" Text="Caducidad" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="4" Text="Días Restantes" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="5" Text="Stock" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="6" Text="Estado" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- ================== TABLA ================== -->
            <Border Grid.Row="2"
                    Background="White"
                    CornerRadius="0,0,12,12"
                    Padding="0"
                    ClipToBounds="True"
                    BorderBrush="#E0E0E0"
                    BorderThickness="1,0,1,1">

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ListBox x:Name="dgCaducidades"
                             Style="{StaticResource ListBoxSinBorde}">

                        <ListBox.ItemTemplate>
                            <DataTemplate>

                                <Border BorderBrush="#E7EAE7"
                                        BorderThickness="0,0,0,1"
                                        Height="68"
                                        Padding="20,0">

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Imagen -->
                                        <Border Grid.Column="0"
                                                Width="46" Height="46"
                                                CornerRadius="10"
                                                Background="#EEF3EE"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Cursor="Hand"
                                                MouseLeftButtonDown="ImagenProducto_Click">
                                            <Image Source="{Binding ImagenURL}"
                                                   Stretch="UniformToFill"
                                                   Width="42" Height="42"/>
                                        </Border>

                                        <!-- Código -->
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding CodigoBarras}"
                                                   FontSize="13"
                                                   Foreground="#37474F"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>

                                        <!-- Producto -->
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding Nombre}"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="#263238"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>

                                        <!-- Caducidad -->
                                        <TextBlock Grid.Column="3"
                                                   Text="{Binding Caducidad, StringFormat=dd/MM/yyyy}"
                                                   FontSize="13"
                                                   Foreground="#37474F"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>

                                        <!-- Días Restantes -->
                                        <TextBlock Grid.Column="4"
                                                   Text="{Binding DiasRestantes}"
                                                   FontSize="13"
                                                   Foreground="#37474F"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>

                                        <!-- Stock -->
                                        <TextBlock Grid.Column="5"
                                                   Text="{Binding Stock}"
                                                   FontSize="13"
                                                   Foreground="#37474F"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>

                                        <!-- Estado -->
                                        <Border Grid.Column="6"
                                                Style="{StaticResource EstadoStyle}">
                                            <TextBlock Text="{Binding Estado}"
                                                       Style="{StaticResource EstadoTextoStyle}"/>
                                        </Border>

                                    </Grid>
                                </Border>

                            </DataTemplate>
                        </ListBox.ItemTemplate>

                    </ListBox>
                </ScrollViewer>
            </Border>

            <!-- ================== BOTÓN REGRESAR ================== -->
            <Button x:Name="btnRegresar"
                    Grid.Row="3"
                    Width="180"
                    Height="44"
                    Content="⬅  Regresar"
                    HorizontalAlignment="Right"
                    Background="#616161"
                    Style="{StaticResource BotonModerno}"
                    Click="btnRegresar_Click"/>

        </Grid>

        <!-- ================== VISOR DE IMAGEN AMPLIADA ================== -->
        <Grid x:Name="overlayImagen"
              Background="#CC000000"
              Visibility="Collapsed"
              MouseLeftButtonUp="overlayImagen_Click">

            <Image x:Name="imgAmpliada"
                   Stretch="Uniform"
                   MaxWidth="500"
                   MaxHeight="500"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"/>

            <TextBlock Text="Clic para cerrar"
                       Foreground="White"
                       FontSize="13"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Bottom"
                       Margin="0,0,0,30"/>
        </Grid>

    </Grid>

</Window>
