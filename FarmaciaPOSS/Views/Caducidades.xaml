<Window x:Class="FarmaciaPOS.Views.Caducidades"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Productos por Caducar"
        Height="650"
        Width="1050"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F5F5F5">

    <Grid>

        <!-- Encabezado -->
        <Border Background="#2E7D32"
                Height="70"
                VerticalAlignment="Top">

            <TextBlock Text="PRODUCTOS PRÓXIMOS A CADUCAR"
                       Foreground="White"
                       FontSize="26"
                       FontWeight="Bold"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"/>
        </Border>

        <Grid Margin="20,90,20,20">

            <Grid.RowDefinitions>
                <RowDefinition Height="55"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="70"/>
            </Grid.RowDefinitions>

            <!-- Barra superior -->
            <StackPanel Orientation="Horizontal">

                <TextBlock Text="Buscar:"
                           VerticalAlignment="Center"
                           FontSize="16"
                           FontWeight="SemiBold"/>

                <TextBox x:Name="txtBuscar"
                         Width="300"
                         Height="35"
                         Margin="10,0"/>

                <Button x:Name="btnActualizar"
                        Width="150"
                        Height="35"
                        Margin="30,0"
                        Content="🔄 Actualizar"
                        Background="#1976D2"
                        Foreground="White"
                        Click="btnActualizar_Click"/>

            </StackPanel>

            <!-- Tabla -->
            <DataGrid x:Name="dgCaducidades"
                      Grid.Row="1"
                      Margin="0,15"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False">

                <DataGrid.Columns>

                    <DataGridTextColumn Header="Código"
                                        Binding="{Binding CodigoBarras}"
                                        Width="120"/>

                    <DataGridTextColumn Header="Producto"
                                        Binding="{Binding Nombre}"
                                        Width="250"/>

                    <DataGridTextColumn Header="Caducidad"
                                        Binding="{Binding Caducidad,StringFormat=dd/MM/yyyy}"
                                        Width="150"/>

                    <DataGridTextColumn Header="Días Restantes"
                                        Binding="{Binding DiasRestantes}"
                                        Width="140"/>

                    <DataGridTextColumn Header="Stock"
                                        Binding="{Binding Stock}"
                                        Width="100"/>

                    <DataGridTextColumn Header="Estado"
                                        Binding="{Binding Estado}"
                                        Width="150"/>

                </DataGrid.Columns>

            </DataGrid>

            <!-- Botón regresar -->
            <Button x:Name="btnRegresar"
                    Grid.Row="2"
                    Width="180"
                    Height="40"
                    Content="⬅ Regresar"
                    HorizontalAlignment="Right"
                    Background="#757575"
                    Foreground="White"
                    Click="btnRegresar_Click"/>

        </Grid>

    </Grid>

</Window>