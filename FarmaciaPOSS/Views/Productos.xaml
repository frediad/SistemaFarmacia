                                                    FontWeight="SemiBold"/>

                                <DataGridTextColumn Header="Categoría"
                                                    Binding="{Binding NombreCategoria}"
                                                    Width="130"/>

                                <DataGridTextColumn Header="Precio 1"
                                                    Binding="{Binding PrecioVenta, StringFormat=C}"
                                                    Width="95"/>

                                <DataGridTextColumn Header="Precio 2"
                                                    Binding="{Binding Precio2, StringFormat=C}"
                                                    Width="95"/>

                                <DataGridTextColumn Header="Precio 3"
                                                    Binding="{Binding Precio3, StringFormat=C}"
                                                    Width="95"/>

                                <DataGridTemplateColumn Header="Stock" Width="90">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="10"
                                                    Padding="8,3"
                                                    HorizontalAlignment="Left">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#F0FDF4"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding EstadoStock}" Value="Bajo">
                                                                <Setter Property="Background" Value="#FEF3C7"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding EstadoStock}" Value="Agotado">
                                                                <Setter Property="Background" Value="#FEE2E2"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding Stock}"
                                                           FontSize="12"
                                                           FontWeight="Bold">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#16A34A"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding EstadoStock}" Value="Bajo">
                                                                    <Setter Property="Foreground" Value="#D97706"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding EstadoStock}" Value="Agotado">
                                                                    <Setter Property="Foreground" Value="#DC2626"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridCheckBoxColumn Header="Activo"
                                                        Binding="{Binding Activo}"
                                                        Width="70"/>

                            </DataGrid.Columns>

                        </DataGrid>

                    </TabItem>

                    <!-- ===================================== -->
                    <!-- PESTAÑA: CATÁLOGO (SOLO VISTA)          -->
                    <!-- ===================================== -->

                    <TabItem Header="🖼️ Vista de catálogo">

                        <Grid>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="55"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Text="Así se ven los productos en el punto de venta (solo referencia visual, no interactivo)"
                                       FontSize="12"
                                       Foreground="#94A3B8"
                                       FontStyle="Italic"
                                       VerticalAlignment="Center"
                                       Margin="6,0"
                                       TextWrapping="Wrap"/>

                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">

                                <ItemsControl x:Name="icCatalogoVista">

                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal" Margin="8"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>

                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>

                                            <!-- TARJETA — SOLO VISUAL, SIN INTERACCIÓN -->
                                            <Border Width="120"
                                                    Height="145"
                                                    Margin="5"
                                                    Background="White"
                                                    BorderBrush="#E2E8F0"
                                                    BorderThickness="1"
                                                    CornerRadius="12">

                                                <Grid>

                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="75"/>
                                                        <RowDefinition Height="*"/>
                                                    </Grid.RowDefinitions>

                                                    <Border Background="#F1F5F9" CornerRadius="12,12,0,0">
                                                        <Image Source="{Binding ImagenBytes, Converter={StaticResource ByteArrayToImageConverter}}"
                                                               Stretch="Uniform"
                                                               Margin="8"/>
                                                    </Border>

                                                    <StackPanel Grid.Row="1" Margin="8,4">

                                                        <TextBlock Text="{Binding Nombre}"
                                                                   FontSize="11"
                                                                   FontWeight="Bold"
                                                                   Foreground="#1E293B"
                                                                   TextWrapping="Wrap"
                                                                   MaxHeight="30"
                                                                   TextTrimming="CharacterEllipsis"/>

                                                        <TextBlock Text="{Binding PrecioVenta, StringFormat=C}"
                                                                   FontSize="13"
                                                                   FontWeight="Bold"
                                                                   Foreground="#2563EB"
                                                                   Margin="0,3,0,0"/>

                                                        <TextBlock Text="{Binding Stock, StringFormat='Stock: {0}'}"
                                                                   FontSize="10"
                                                                   Foreground="#94A3B8"/>

                                                    </StackPanel>

                                                </Grid>

                                            </Border>

                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>

                                </ItemsControl>

                            </ScrollViewer>

                        </Grid>

                    </TabItem>

                </TabControl>

            </Border>

        </Grid>

    </Grid>

</Window>