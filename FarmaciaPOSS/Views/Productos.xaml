<Window x:Class="FarmaciaPOS.Views.ProductosWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Productos"
        Height="700"
        Width="1100"
        Icon="/logo-icono.ico"
        WindowStartupLocation="CenterScreen"
        Background="#F0F4F8">

    <Grid Margin="15">

        <Grid.RowDefinitions>
            <RowDefinition Height="90"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ===================================== -->
        <!-- HEADER                                -->
        <!-- ===================================== -->

        <Border Background="#1E3A8A"
                CornerRadius="10"
                Padding="20"
                Margin="0,0,0,15">

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="300"/>
                    <ColumnDefinition Width="110"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="🧪  Gestión de Productos"
                           FontSize="26"
                           FontWeight="Bold"
                           Foreground="White"
                           VerticalAlignment="Center"/>

                <Border Grid.Column="1"
                        Background="White"
                        CornerRadius="8"
                        Margin="10,0"
                        VerticalAlignment="Center">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="🔍"
                                   FontSize="16"
                                   Margin="10,0,5,0"
                                   VerticalAlignment="Center"/>

                        <TextBox x:Name="txtBuscar"
                                 Grid.Column="1"
                                 Height="42"
                                 FontSize="15"
                                 BorderThickness="0"
                                 VerticalContentAlignment="Center"
                                 Text="Buscar producto..."
                                 Foreground="Gray"
                                 TextChanged="txtBuscar_TextChanged"
                                 GotFocus="TxtBuscar_GotFocus"
                                 LostFocus="TxtBuscar_LostFocus">
                            <TextBox.Template>
                                <ControlTemplate TargetType="TextBox">
                                    <Border Background="Transparent">
                                        <ScrollViewer x:Name="PART_ContentHost" Margin="4,0"/>
                                    </Border>
                                </ControlTemplate>
                            </TextBox.Template>
                        </TextBox>

                    </Grid>

                </Border>

                <Button Grid.Column="2"
                        Content="✕ Cerrar"
                        Width="100"
                        Height="40"
                        FontSize="14"
                        FontWeight="Bold"
                        Background="#DC2626"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        VerticalAlignment="Center"
                        Click="BtnCerrarVentana_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

            </Grid>

        </Border>

        <!-- ===================================== -->
        <!-- CONTENIDO                             -->
        <!-- ===================================== -->

        <Grid Grid.Row="1">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="430"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ===================================== -->
            <!-- FORMULARIO                            -->
            <!-- ===================================== -->

            <Border Grid.Column="0"
                    Background="White"
                    CornerRadius="10"
                    Padding="20"
                    Margin="0,0,15,0">

                <ScrollViewer>

                    <StackPanel>

                        <TextBlock Text="Nuevo Producto"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Margin="0,0,0,15"/>

                        <!-- ===================================== -->
                        <!-- CARRUSEL DE 3 IMÁGENES                -->
                        <!-- ===================================== -->

                        <Border Background="#F8FAFC"
                                BorderBrush="#D6D6D6"
                                BorderThickness="1"
                                CornerRadius="8"
                                Height="200"
                                Margin="0,0,0,15">

                            <Grid>

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="40"/>
                                </Grid.ColumnDefinitions>

                                <Button Grid.Column="0"
                                        x:Name="btnImagenAnterior"
                                        Content="‹"
                                        FontSize="28"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        VerticalAlignment="Center"
                                        Click="BtnImagenAnterior_Click"/>

                                <Grid Grid.Column="1">

                                    <Image x:Name="imgProductoPreview"
                                           Stretch="Uniform"
                                           Margin="10,10,10,30"/>

                                    <Button x:Name="btnCargarImagen"
                                            Width="50"
                                            Height="50"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Center"
                                            Background="#80000000"
                                            BorderThickness="0"
                                            Margin="0,0,0,20"
                                            Click="BtnCargarImagen_Click"
                                            ToolTip="Cargar imagen en esta posición">
                                        <TextBlock Text="📷"
                                                   FontSize="22"
                                                   Foreground="White"/>
                                    </Button>

                                    <TextBlock x:Name="txtIndicadorImagen"
                                               Text="1 / 3"
                                               FontSize="13"
                                               FontWeight="Bold"
                                               Foreground="Gray"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Bottom"
                                               Margin="0,0,0,5"/>

                                    <Button x:Name="btnEliminarImagen"
                                            Content="✕"
                                            Width="24"
                                            Height="24"
                                            FontSize="12"
                                            FontWeight="Bold"
                                            Background="#DC2626"
                                            Foreground="White"
                                            BorderThickness="0"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Top"
                                            Margin="0,5,5,0"
                                            Click="BtnEliminarImagen_Click"
                                            ToolTip="Eliminar esta imagen"/>

                                </Grid>

                                <Button Grid.Column="2"
                                        x:Name="btnImagenSiguiente"
                                        Content="›"
                                        FontSize="28"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        VerticalAlignment="Center"
                                        Click="BtnImagenSiguiente_Click"/>

                            </Grid>

                        </Border>

                        <!-- NOMBRE -->

                        <TextBlock Text="Nombre"
                                   FontWeight="Bold"
                                   FontSize="16"/>

                        <TextBox x:Name="txtNombre"
                                 Height="40"
                                 FontSize="16"
                                 Margin="0,5,0,15"/>

                        <!-- CODIGO -->

                        <TextBlock Text="Código de Barras"
                                   FontWeight="Bold"
                                   FontSize="16"/>

                        <Grid Margin="0,5,0,15">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="110"/>
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="txtCodigo"
                                     Height="40"
                                     FontSize="16"/>

                            <Button Grid.Column="1"
                                    Content="🔑 Generar"
                                    Height="40"
                                    Margin="8,0,0,0"
                                    FontSize="13"
                                    Click="BtnGenerarClave_Click"/>

                        </Grid>

                        <!-- DESCRIPCION -->

                        <TextBlock Text="Descripción"
                                   FontWeight="Bold"
                                   FontSize="16"/>

                        <TextBox x:Name="txtDescripcion"
                                 Height="80"
                                 FontSize="16"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 Margin="0,5,0,15"/>

                        <!-- CATEGORIA -->

                        <TextBlock Text="Categoría"
                                   FontWeight="Bold"
                                   FontSize="16"/>

                        <ComboBox x:Name="cbCategorias"
                                  Height="40"
                                  FontSize="16"
                                  DisplayMemberPath="Nombre"
                                  SelectedValuePath="Id"
                                  SelectionChanged="CbCategorias_SelectionChanged"
                                  Margin="0,5,0,15"/>

                        <!-- SUBCATEGORIA -->

                        <TextBlock Text="Subcategoría"
                                   FontWeight="Bold"
                                   FontSize="16"/>

                        <ComboBox x:Name="cbSubcategorias"
                                  Height="40"
                                  FontSize="16"
                                  DisplayMemberPath="Nombre"
                                  SelectedValuePath="Id"
                                  Margin="0,5,0,15"/>

                        <!-- PRECIO COMPRA -->

                        <TextBlock Text="Precio Compra"
                                   FontWeight="Bold"
                                   FontSize="16"/>

                        <TextBox x:Name="txtPrecioCompra"
                                 Height="40"
                                 FontSize="16"
                                 Margin="0,5,0,15"/>

                        <!-- PRECIO VENTA -->

                        <TextBlock Text="Precio Venta (Precio 1 — menudeo)"
                                   FontWeight="Bold"
                                   FontSize="16"/>

                        <TextBox x:Name="txtPrecioVenta"
                                 Height="40"
                                 FontSize="16"
                                 Margin="0,5,0,15"/>

                        <!-- ===================================== -->
                        <!-- PRECIOS POR VOLUMEN (ESTILO SICAR)    -->
                        <!-- ===================================== -->

                        <Border Background="#EFF6FF"
                                BorderBrush="#BFDBFE"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12"
                                Margin="0,0,0,15">

                            <StackPanel>

                                <TextBlock Text="💰 Precios por volumen"
                                           FontWeight="Bold"
                                           FontSize="14"
                                           Foreground="#1E3A8A"
                                           Margin="0,0,0,10"/>

                                <TextBlock Text="Precio por pieza"
                                           FontSize="11"
                                           Foreground="#64748B"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,10"/>

                                <!-- PRECIO 2 -->
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="140"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Text="Precio 2"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="A partir de (pzas.)" FontSize="11" Foreground="Gray"/>
                                        <TextBox x:Name="txtCantidadMayoreo2" Height="34" FontSize="14"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="4">
                                        <TextBlock Text="Precio c/u" FontSize="11" Foreground="Gray"/>
                                        <TextBox x:Name="txtPrecio2" Height="34" FontSize="14"/>
                                    </StackPanel>
                                </Grid>

                                <!-- PRECIO 3 -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="140"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Text="Precio 3"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="A partir de (pzas.)" FontSize="11" Foreground="Gray"/>
                                        <TextBox x:Name="txtCantidadMayoreo3" Height="34" FontSize="14"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="4">
                                        <TextBlock Text="Precio c/u" FontSize="11" Foreground="Gray"/>
                                        <TextBox x:Name="txtPrecio3" Height="34" FontSize="14"/>
                                    </StackPanel>
                                </Grid>

                            </StackPanel>

                        </Border>

                        <!-- STOCK -->

                        <TextBlock Text="Stock"
                                   FontWeight="Bold"
                                   FontSize="16"/>

                        <TextBox x:Name="txtStock"
                                 Height="40"
                                 FontSize="16"
                                 Margin="0,5,0,15"/>

                        <!-- STOCK MINIMO -->

                        <TextBlock Text="Stock Mínimo"
                                   FontWeight="Bold"
                                   FontSize="16"/>

                        <TextBox x:Name="txtStockMinimo"
                                 Height="40"
                                 FontSize="16"
                                 Margin="0,5,0,15"/>

                       
                        <!-- ACTIVO -->

                        <CheckBox x:Name="chkActivo"
                                  Content="Producto Activo"
                                  FontSize="16"
                                  IsChecked="True"
                                  Margin="0,0,0,20"/>

                        <!-- ===================================== -->
                        <!-- BOTONES                               -->
                        <!-- ===================================== -->

                        <Grid Margin="0,10,0,0">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0"
                                    Content="❌ Cancelar"
                                    Height="50"
                                    FontSize="16"
                                    FontWeight="Bold"
                                    Background="#9CA3AF"
                                    Foreground="White"
                                    Click="BtnCancelar_Click"/>

                            <Button Grid.Column="2"
                                    Content="💾 Guardar"
                                    Height="50"
                                    FontSize="16"
                                    FontWeight="Bold"
                                    Background="#2563EB"
                                    Foreground="White"
                                    Click="BtnGuardar_Click"/>

                        </Grid>

                        <Button Content="Actualizar"
                                Height="50"
                                FontSize="18"
                                FontWeight="Bold"
                                Background="#16A34A"
                                Foreground="White"
                                Margin="0,10,0,10"
                                Click="BtnActualizar_Click"/>

                        <Button Content="Eliminar"
                                Height="50"
                                FontSize="18"
                                FontWeight="Bold"
                                Background="#DC2626"
                                Foreground="White"
                                Click="BtnEliminar_Click"/>

                        <!-- ===================================== -->
                        <!-- LOTES                                 -->
                        <!-- ===================================== -->

                        <Separator Margin="0,20,0,15"/>

                        <TextBlock Text="Lotes del Producto"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Margin="0,0,0,10"/>

                        <Grid Margin="0,0,0,10">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="No. Lote" FontSize="13" Foreground="Gray"/>
                                <TextBox x:Name="txtNumeroLote" Height="36" FontSize="14"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Cantidad" FontSize="13" Foreground="Gray"/>
                                <TextBox x:Name="txtCantidadLote" Height="36" FontSize="14"/>
                            </StackPanel>

                        </Grid>

                        <TextBlock Text="Fecha de Caducidad del Lote"
                                   FontSize="13"
                                   Foreground="Gray"/>

                        <DatePicker x:Name="dpCaducidadLote"
                                    Height="36"
                                    Margin="0,3,0,10"/>

                        <Button Content="➕ Agregar Lote"
                                Height="40"
                                FontSize="14"
                                FontWeight="Bold"
                                Background="#16A34A"
                                Foreground="White"
                                Margin="0,0,0,15"
                                Click="BtnAgregarLote_Click"/>

                        <DataGrid x:Name="dgLotes"
                                  AutoGenerateColumns="False"
                                  FontSize="13"
                                  Height="150"
                                  CanUserAddRows="False"
                                  HeadersVisibility="Column">

                            <DataGrid.Columns>

                                <DataGridTextColumn Header="Lote"
                                 Binding="{Binding NumeroLote}"
                                 Width="*"/>

                                <DataGridTextColumn Header="Cantidad"
                                 Binding="{Binding Cantidad}"
                                 Width="70"/>

                                <DataGridTextColumn Header="Caducidad"
                                 Binding="{Binding FechaCaducidad, StringFormat=dd/MM/yyyy}"
                                 Width="100"/>

                            </DataGrid.Columns>

                        </DataGrid>

                    </StackPanel>

                </ScrollViewer>

            </Border>

            <!-- ===================================== -->
            <!-- TABLA + CATÁLOGO (SOLO LECTURA)        -->
            <!-- ===================================== -->

            <Border Grid.Column="1"
                    Background="White"
                    CornerRadius="10"
                    Padding="10">

                <TabControl x:Name="tabVistaProductos"
                            BorderThickness="0"
                            Background="Transparent">

                    <!-- ===================================== -->
                    <!-- PESTAÑA: LISTA                        -->
                    <!-- ===================================== -->

                    <TabItem Header="📋 Lista">

                        <DataGrid x:Name="dgProductos"
                                  AutoGenerateColumns="False"
                                  FontSize="16"
                                  CanUserAddRows="False"
                                  SelectionChanged="dgProductos_SelectionChanged">

                            <DataGrid.Columns>

                                <DataGridTextColumn Header="ID"
                                                    Binding="{Binding Id}"
                                                    Width="80"/>

                                <DataGridTextColumn Header="Código"
                                                    Binding="{Binding CodigoBarras}"
                                                    Width="180"/>

                                <DataGridTextColumn Header="Nombre"
                                                    Binding="{Binding Nombre}"
                                                    Width="220"/>

                                <DataGridTextColumn Header="Descripción"
                                                    Binding="{Binding Descripcion}"
                                                    Width="250"/>

                                <DataGridTextColumn Header="Categoría"
                                                    Binding="{Binding CategoriaId}"
                                                    Width="120"/>

                                <DataGridTextColumn Header="Precio Compra"
                                                    Binding="{Binding PrecioCompra}"
                                                    Width="140"/>

                                <DataGridTextColumn Header="Precio 1"
                                                    Binding="{Binding PrecioVenta}"
                                                    Width="100"/>

                                <DataGridTextColumn Header="Precio 2"
                                                    Binding="{Binding Precio2}"
                                                    Width="100"/>

                                <DataGridTextColumn Header="Precio 3"
                                                    Binding="{Binding Precio3}"
                                                    Width="100"/>

                                <DataGridTextColumn Header="Stock"
                                                    Binding="{Binding Stock}"
                                                    Width="100"/>

                                <DataGridTextColumn Header="Stock Min."
                                                    Binding="{Binding StockMinimo}"
                                                    Width="120"/>

                                <DataGridCheckBoxColumn Header="Activo"
                                                        Binding="{Binding Activo}"
                                                        Width="100"/>

                            </DataGrid.Columns>

                        </DataGrid>

                    </TabItem>

                    <!-- ===================================== -->
                    <!-- PESTAÑA: CATÁLOGO (SOLO VISTA)          -->
                    <!-- ===================================== -->

                    <TabItem Header="🖼️ Vista de catálogo">

                        <Grid>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="55"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Text="Así se ven los productos en el punto de venta (solo referencia visual, no interactivo)"
                                       FontSize="12"
                                       Foreground="#94A3B8"
                                       FontStyle="Italic"
                                       VerticalAlignment="Center"
                                       Margin="6,0"
                                       TextWrapping="Wrap"/>

                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">

                                <ItemsControl x:Name="icCatalogoVista">

                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal" Margin="8"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>

                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>

                                            <!-- TARJETA — SOLO VISUAL, SIN INTERACCIÓN -->
                                            <Border Width="120"
                                                    Height="145"
                                                    Margin="5"
                                                    Background="White"
                                                    BorderBrush="#E2E8F0"
                                                    BorderThickness="1"
                                                    CornerRadius="12">

                                                <Grid>

                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="75"/>
                                                        <RowDefinition Height="*"/>
                                                    </Grid.RowDefinitions>

                                                    <Border Background="#F1F5F9" CornerRadius="12,12,0,0">
                                                        <Image Source="{Binding ImagenURL}"
                                                               Stretch="Uniform"
                                                               Margin="8"/>
                                                    </Border>

                                                    <StackPanel Grid.Row="1" Margin="8,4">

                                                        <TextBlock Text="{Binding Nombre}"
                                                                   FontSize="11"
                                                                   FontWeight="Bold"
                                                                   Foreground="#1E293B"
                                                                   TextWrapping="Wrap"
                                                                   MaxHeight="30"
                                                                   TextTrimming="CharacterEllipsis"/>

                                                        <TextBlock Text="{Binding PrecioVenta, StringFormat=C}"
                                                                   FontSize="13"
                                                                   FontWeight="Bold"
                                                                   Foreground="#2563EB"
                                                                   Margin="0,3,0,0"/>

                                                        <TextBlock Text="{Binding Stock, StringFormat='Stock: {0}'}"
                                                                   FontSize="10"
                                                                   Foreground="#94A3B8"/>

                                                    </StackPanel>

                                                </Grid>

                                            </Border>

                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>

                                </ItemsControl>

                            </ScrollViewer>

                        </Grid>

                    </TabItem>

                </TabControl>

            </Border>

        </Grid>

    </Grid>

</Window>