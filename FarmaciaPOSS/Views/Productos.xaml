<Window x:Class="FarmaciaPOS.Views.ProductosWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Productos"
        Height="700"
        Width="1150"
        Icon="/logo-icono.ico"
        WindowStartupLocation="CenterScreen"
        Background="#EEF2F7">

    <Grid Margin="15">

        <Grid.RowDefinitions>
            <RowDefinition Height="100"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->

        <Border Background="White"
                CornerRadius="10"
                Padding="20"
                Margin="0,0,0,15">

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="300"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Gestión de Productos"
                           FontSize="32"
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>

                <TextBox x:Name="txtBuscar"
                         Grid.Column="1"
                         Height="45"
                         FontSize="18"
                         VerticalContentAlignment="Center"
                         Text="Buscar producto..."
                         Foreground="Gray"
                         GotFocus="TxtBuscar_GotFocus"
                         LostFocus="TxtBuscar_LostFocus"/>

            </Grid>

        </Border>

        <!-- CONTENIDO -->

        <Grid Grid.Row="1">

            <Grid.ColumnDefinitions>
                
                <ColumnDefinition Width="1"/>
                <!-- FORMULARIO -->
                <ColumnDefinition Width="430"/>
                <!-- TABLA -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            

            

            <!-- ===================================== -->
            <!-- FORMULARIO                            -->
            <!-- ===================================== -->

            <Border Grid.Column="1"
                    Background="White"
                    CornerRadius="10"
                    Padding="20"
                    Margin="0,0,15,0">

                <ScrollViewer>

                    <StackPanel>

                        <TextBlock Text="Nuevo Producto"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Margin="0,0,0,15"/>

                        <!-- ===================================== -->
                        <!-- ✅ INSERTAR IMAGEN     -->
                        <!-- ===================================== -->

                        <Border Background="#F8FAFC"
                                BorderBrush="#D6D6D6"
                                BorderThickness="1"
                                CornerRadius="8"
                                Height="170"
                                Margin="0,0,0,15">

                            <Grid>

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>

                                <!-- IMAGEN ACTUAL -->

                                <Grid Grid.Column="1">

                                    <Image x:Name="imgProductoPreview"
                                           Stretch="Uniform"
                                           Margin="10"/>

                                    <!-- BOTÓN CÁMARA (overlay) -->

                                    <Button x:Name="btnCargarImagen"
                                            Width="50"
                                            Height="50"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Center"
                                            Background="#80000000"
                                            BorderThickness="0"
                                            Click="BtnCargarImagen_Click"
                                            ToolTip="Cargar imagen">
                                        <TextBlock Text="📷"
                                                   FontSize="22"
                                                   Foreground="White"/>
                                    </Button>

                                </Grid>

                            </Grid>

                        </Border>

                        <!-- URL IMAGEN -->

                        <TextBlock Text="Imagen URL"
                                   FontWeight="Bold"
                                   FontSize="14"
                                   Margin="0,0,0,5"/>

                        <TextBox x:Name="txtImagenURL"
                                 Height="35"
                                 FontSize="14"
                                 Margin="0,0,0,15"
                                 TextChanged="TxtImagenURL_TextChanged"/>

                        <!-- NOMBRE -->

                        <TextBlock Text="Nombre"
                                   FontWeight="Bold"
                                   FontSize="16"/>

                        <TextBox x:Name="txtNombre"
                                 Height="40"
                                 FontSize="16"
                                 Margin="0,5,0,15"/>

                        <!-- CODIGO -->

                        <TextBlock Text="Código de Barras"
                                   FontWeight="Bold"
                                   FontSize="16"/>

                        <Grid Margin="0,5,0,15">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="110"/>
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="txtCodigo"
                                     Height="40"
                                     FontSize="16"/>

                            <Button Grid.Column="1"
                                    Content="🔑 Generar"
                                    Height="40"
                                    Margin="8,0,0,0"
                                    FontSize="13"
                                    Click="BtnGenerarClave_Click"/>

                        </Grid>

                        <!-- DESCRIPCION -->

                        <TextBlock Text="Descripción"
                                   FontWeight="Bold"
                                   FontSize="16"/>

                        <TextBox x:Name="txtDescripcion"
                                 Height="80"
                                 FontSize="16"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 Margin="0,5,0,15"/>

                      
                        <!-- CATEGORIA -->

                        <TextBlock Text="Categoría"
                                   FontWeight="Bold"
                                   FontSize="16"/>

                        <ComboBox x:Name="cbCategorias"
                                  Height="40"
                                  FontSize="16"
                                  DisplayMemberPath="Nombre"
                                  SelectedValuePath="Id"
                                  SelectionChanged="CbCategorias_SelectionChanged"
                                  Margin="0,5,0,15"/>

                        <!-- ✅ NUEVO — SUBCATEGORIA -->

                        <TextBlock Text="Subcategoría"
                                   FontWeight="Bold"
                                   FontSize="16"/>

                        <ComboBox x:Name="cbSubcategorias"
                                  Height="40"
                                  FontSize="16"
                                  DisplayMemberPath="Nombre"
                                  SelectedValuePath="Id"
                                  Margin="0,5,0,15"/>

                        <!-- PRECIO COMPRA -->

                        <TextBlock Text="Precio Compra"
                                   FontWeight="Bold"
                                   FontSize="16"/>

                        <TextBox x:Name="txtPrecioCompra"
                                 Height="40"
                                 FontSize="16"
                                 Margin="0,5,0,15"/>

                        <!-- PRECIO VENTA -->

                        <TextBlock Text="Precio Venta"
                                   FontWeight="Bold"
                                   FontSize="16"/>

                        <TextBox x:Name="txtPrecioVenta"
                                 Height="40"
                                 FontSize="16"
                                 Margin="0,5,0,15"/>

                        <!-- STOCK -->

                        <TextBlock Text="Stock"
                                   FontWeight="Bold"
                                   FontSize="16"/>

                        <TextBox x:Name="txtStock"
                                 Height="40"
                                 FontSize="16"
                                 Margin="0,5,0,15"/>

                        <!-- STOCK MINIMO -->

                        <TextBlock Text="Stock Mínimo"
                                   FontWeight="Bold"
                                   FontSize="16"/>

                        <TextBox x:Name="txtStockMinimo"
                                 Height="40"
                                 FontSize="16"
                                 Margin="0,5,0,15"/>

                        <!-- CONTROLADO -->

                        <CheckBox x:Name="chkControlado"
                                  Content="Medicamento Controlado"
                                  FontSize="16"
                                  Margin="0,0,0,15"/>

                        <!-- ACTIVO -->

                        <CheckBox x:Name="chkActivo"
                                  Content="Producto Activo"
                                  FontSize="16"
                                  IsChecked="True"
                                  Margin="0,0,0,20"/>

                        <!-- ===================================== -->
                        <!-- ✅ BOTONES ESTILO SICAR                -->
                        <!-- ===================================== -->

                        <Grid Margin="0,10,0,0">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0"
                                    Content="❌ Cancelar"
                                    Height="50"
                                    FontSize="16"
                                    FontWeight="Bold"
                                    Background="#9CA3AF"
                                    Foreground="White"
                                    Click="BtnCancelar_Click"/>

                            <Button Grid.Column="2"
                                    Content="💾 Guardar"
                                    Height="50"
                                    FontSize="16"
                                    FontWeight="Bold"
                                    Background="#2563EB"
                                    Foreground="White"
                                    Click="BtnGuardar_Click"/>

                        </Grid>

                        <Button Content="Actualizar"
                                Height="50"
                                FontSize="18"
                                FontWeight="Bold"
                                Background="#16A34A"
                                Foreground="White"
                                Margin="0,10,0,10"
                                Click="BtnActualizar_Click"/>

                        <Button Content="Eliminar"
                                Height="50"
                                FontSize="18"
                                FontWeight="Bold"
                                Background="#DC2626"
                                Foreground="White"
                                Click="BtnEliminar_Click"/>

                        <!-- ===================================== -->
                        <!-- ✅ NUEVO — SECCIÓN DE LOTES            -->
                        <!-- ===================================== -->

                        <Separator Margin="0,20,0,15"/>

                        <TextBlock Text="Lotes del Producto"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Margin="0,0,0,10"/>

                        <Grid Margin="0,0,0,10">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="No. Lote" FontSize="13" Foreground="Gray"/>
                                <TextBox x:Name="txtNumeroLote" Height="36" FontSize="14"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Cantidad" FontSize="13" Foreground="Gray"/>
                                <TextBox x:Name="txtCantidadLote" Height="36" FontSize="14"/>
                            </StackPanel>

                        </Grid>

                        <TextBlock Text="Fecha de Caducidad del Lote"
                                   FontSize="13"
                                   Foreground="Gray"/>

                        <DatePicker x:Name="dpCaducidadLote"
                                    Height="36"
                                    Margin="0,3,0,10"/>

                        <Button Content="➕ Agregar Lote"
                                Height="40"
                                FontSize="14"
                                FontWeight="Bold"
                                Background="#16A34A"
                                Foreground="White"
                                Margin="0,0,0,15"
                                Click="BtnAgregarLote_Click"/>

                        <DataGrid x:Name="dgLotes"
                                  AutoGenerateColumns="False"
                                  FontSize="13"
                                  Height="150"
                                  CanUserAddRows="False"
                                  HeadersVisibility="Column">

                            <DataGrid.Columns>

                                <DataGridTextColumn Header="Lote"
                                 Binding="{Binding NumeroLote}"
                                 Width="*"/>

                                <DataGridTextColumn Header="Cantidad"
                                 Binding="{Binding Cantidad}"
                                 Width="70"/>

                                <DataGridTextColumn Header="Caducidad"
                                 Binding="{Binding FechaCaducidad, StringFormat=dd/MM/yyyy}"
                                 Width="100"/>

                            </DataGrid.Columns>

                        </DataGrid>

                    </StackPanel>

                </ScrollViewer>

            </Border>

            <!-- ===================================== -->
            <!-- TABLA -->
            <!-- ===================================== -->

            <Border Grid.Column="2"
                    Background="White"
                    CornerRadius="10"
                    Padding="10">

                <DataGrid x:Name="dgProductos"
                          AutoGenerateColumns="False"
                          FontSize="16"
                          CanUserAddRows="False"
                          SelectionChanged="dgProductos_SelectionChanged">

                    <DataGrid.Columns>

                        <DataGridTextColumn Header="ID"
                                            Binding="{Binding Id}"
                                            Width="80"/>

                        <DataGridTextColumn Header="Código"
                                            Binding="{Binding CodigoBarras}"
                                            Width="180"/>

                        <DataGridTextColumn Header="Nombre"
                                            Binding="{Binding Nombre}"
                                            Width="220"/>

                        <DataGridTextColumn Header="Descripción"
                                            Binding="{Binding Descripcion}"
                                            Width="250"/>

                        <DataGridTextColumn Header="Categoría"
                                            Binding="{Binding CategoriaId}"
                                            Width="120"/>

                        <DataGridTextColumn Header="Precio Compra"
                                            Binding="{Binding PrecioCompra}"
                                            Width="140"/>

                        <DataGridTextColumn Header="Precio Venta"
                                            Binding="{Binding PrecioVenta}"
                                            Width="140"/>

                        <DataGridTextColumn Header="Stock"
                                            Binding="{Binding Stock}"
                                            Width="100"/>

                        <DataGridTextColumn Header="Stock Min."
                                            Binding="{Binding StockMinimo}"
                                            Width="120"/>

                        <DataGridCheckBoxColumn Header="Activo"
                                                Binding="{Binding Activo}"
                                                Width="100"/>

                    </DataGrid.Columns>

                </DataGrid>

            </Border>

        </Grid>

    </Grid>

</Window>