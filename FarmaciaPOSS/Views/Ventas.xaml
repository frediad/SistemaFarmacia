        <Style x:Key="BtnAccion" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F8FAFC"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#94A3B8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Botones pequeños de la barra del ticket -->
        <Style x:Key="BtnTicketAccion" TargetType="Button">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="3,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="110"/>
        </Grid.RowDefinitions>

        <!-- ========================================= -->
        <!-- HEADER                                    -->
        <!-- ========================================= -->

        <Border Background="#1E3A8A" Grid.Row="0">

            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="🛒  Punto de Venta"
                           Foreground="White"
                           FontSize="20"
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>

                <Button Grid.Column="1"
                        Content="✕ Cerrar"
                        Width="100"
                        Height="38"
                        FontSize="14"
                        FontWeight="Bold"
                        Background="#DC2626"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="BtnCerrarVentana_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

            </Grid>

        </Border>

        <!-- ========================================= -->
        <!-- CONTENIDO: CARRITO | CATÁLOGO             -->
        <!-- ========================================= -->

        <Grid Grid.Row="1">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="420"/>
            </Grid.ColumnDefinitions>

            <!-- ===================================== -->
            <!-- CARRITO DE VENTA                      -->
            <!-- ===================================== -->

            <Grid Margin="8,8,4,8">

                <Grid.RowDefinitions>
                    <RowDefinition Height="45"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="55"/>
                </Grid.RowDefinitions>

                <!-- TÍTULO TICKET -->
                <Border Background="#1E3A8A" CornerRadius="10,10,0,0">

                    <Grid Margin="15,0">

                        <TextBlock Text="🧾  Ticket actual"
                                   Foreground="White"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"/>

                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center">

                            <Button Content="＋ Cant"
                                    Style="{StaticResource BtnTicketAccion}"
                                    Click="BtnMasCant_Click"/>

                            <Button Content="🔢 Cant."
                                    Style="{StaticResource BtnTicketAccion}"
                                    Click="BtnCantidad_Click"/>

                            <Button Content="🏷️ Desc."
                                    Style="{StaticResource BtnTicketAccion}"
                                    Click="BtnDescuento_Click"/>

                            <Button Content="🗑️ Quitar"
                                    Style="{StaticResource BtnTicketAccion}"
                                    Background="#DC2626"
                                    Click="BtnEliminar_Click"/>

                        </StackPanel>

                    </Grid>

                </Border>

                <!-- TABLA CARRITO -->
                <Border Grid.Row="1"
                        Background="White"
                        BorderBrush="#E2E8F0"
                        BorderThickness="1,0,1,0">

                    <DataGrid x:Name="dgCarrito"
                              AutoGenerateColumns="False"
                              HeadersVisibility="Column"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              FontSize="14"
                              RowHeight="38"
                              BorderThickness="0"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#F1F5F9"
                              SelectionMode="Single"
                              SelectionUnit="FullRow"
                              ScrollViewer.VerticalScrollBarVisibility="Auto">

                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#F8FAFC"/>
                                <Setter Property="Foreground" Value="#64748B"/>
                                <Setter Property="FontSize" Value="12"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Padding" Value="10,8"/>
                                <Setter Property="BorderThickness" Value="0"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Cant." Binding="{Binding Cantidad}" Width="65"/>
                            <DataGridTextColumn Header="Descripción" Binding="{Binding Nombre}" Width="*"/>
                            <DataGridTextColumn Header="Stock" Binding="{Binding Stock}" Width="70"/>
                            <DataGridTextColumn Header="Desc." Binding="{Binding Descuento}" Width="80"/>
                            <DataGridTextColumn Header="Precio" Binding="{Binding Precio}" Width="100"/>
                            <DataGridTextColumn Header="Importe" Binding="{Binding Subtotal}" Width="110"/>
                        </DataGrid.Columns>

                    </DataGrid>

                </Border>

                <!-- ACCIONES ADICIONALES -->
                <Border Grid.Row="2"
                        Background="#F8FAFC"
                        BorderBrush="#E2E8F0"
                        BorderThickness="1,1,1,1"
                        CornerRadius="0,0,10,10">

                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="10,0">

                        <Button Content="✕ Cancelar venta"
                                Style="{StaticResource BtnAccion}"
                                Width="140"
                                Height="36"
                                Margin="4,0"
                                Click="BtnCancelar_Click"/>

                        <Button Content="🖨️ Generar Ticket"
                                Style="{StaticResource BtnAccion}"
                                Width="150"
                                Height="36"
                                Margin="4,0"
                                Click="BtnGenerarTicket_Click"/>

                    </StackPanel>

                </Border>

            </Grid>

            <!-- ===================================== -->
            <!-- CATÁLOGO: CATEGORÍAS + PRODUCTOS CARDS -->
            <!-- ===================================== -->

            <Border Grid.Column="1"
                    Background="#F8FAFC"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1,0,0,0"
                    Margin="4,8,8,8">

                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="65"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- BARRA DE CATEGORÍAS -->
                    <Border Background="White"
                            BorderBrush="#E2E8F0"
                            BorderThickness="0,0,0,1"
                            CornerRadius="10,10,0,0">

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Disabled"
                                          VerticalAlignment="Center"
                                          Margin="8,0"
                                          Padding="0,0,0,4">

                                <ScrollViewer.Resources>
                                    <Style TargetType="ScrollBar" BasedOn="{StaticResource ScrollBarCategorias}"/>
                                </ScrollViewer.Resources>

                                <StackPanel x:Name="pnlCategorias"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <!-- Los botones de categoría se generan dinámicamente desde el .cs -->
                                </StackPanel>

                            </ScrollViewer>

                            <Button Grid.Column="1"
                                    Content="🔍"
                                    Width="46"
                                    Height="42"
                                    FontSize="18"
                                    Background="#2563EB"
                                    Foreground="White"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Margin="0,0,10,0"
                                    Click="BtnBuscarProducto_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                        </Grid>

                    </Border>

                    <!-- GRID DE TARJETAS DE PRODUCTOS -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        

                        <ItemsControl x:Name="icProductosCatalogo">

                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" Margin="8"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>

                            <ItemsControl.ItemTemplate>
                                <DataTemplate>

                                    <Border Width="120"
                                            Height="145"
                                            Margin="5"
                                            Background="White"
                                            BorderBrush="#E2E8F0"
                                            BorderThickness="1"
                                            CornerRadius="12"
                                            Cursor="Hand"
                                            MouseLeftButtonUp="CardProducto_MouseLeftButtonUp">

                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="BorderBrush" Value="#2563EB"/>
                                                        <Setter Property="Effect">
                                                            <Setter.Value>
                                                                <DropShadowEffect Color="#2563EB"
                                                                                  Opacity="0.15"
                                                                                  BlurRadius="8"
                                                                                  ShadowDepth="2"/>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>

                                        <Grid>

                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="75"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>

                                            <Border Background="#F1F5F9" CornerRadius="12,12,0,0">
                                                <Image Source="{Binding ImagenBytes, Converter={StaticResource ByteArrayToImageConverter}}"
                                                       Stretch="Uniform"
                                                       Margin="8"/>
                                            </Border>

                                            <StackPanel Grid.Row="1" Margin="8,4">

                                                <TextBlock Text="{Binding Nombre}"
                                                           FontSize="11"
                                                           FontWeight="Bold"
                                                           Foreground="#1E293B"
                                                           TextWrapping="Wrap"
                                                           MaxHeight="30"
                                                           TextTrimming="CharacterEllipsis"/>

                                                <TextBlock Text="{Binding PrecioVenta, StringFormat=C}"
                                                           FontSize="13"
                                                           FontWeight="Bold"
                                                           Foreground="#2563EB"
                                                           Margin="0,3,0,0"/>

                                                <TextBlock Text="{Binding Stock, StringFormat='Stock: {0}'}"
                                                           FontSize="10"
                                                           Foreground="#94A3B8"/>

                                            </StackPanel>

                                        </Grid>

                                    </Border>

                                </DataTemplate>

                            </ItemsControl.ItemTemplate>

                        </ItemsControl>

                    </ScrollViewer>

                </Grid>

            </Border>

        </Grid>

        <!-- ========================================= -->
        <!-- TOTAL + COBRAR                            -->
        <!-- ========================================= -->

        <Grid Grid.Row="2" Margin="8,0">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="280"/>
            </Grid.ColumnDefinitions>

            <Border Background="White"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1"
                    CornerRadius="12"
                    Margin="4,8">

                <Grid Margin="20,0">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="TOTAL" FontSize="11" Foreground="#94A3B8" FontWeight="Bold"/>
                        <TextBlock x:Name="txtTotal" Text="$0.00" FontSize="24" FontWeight="Bold" Foreground="#1E3A8A"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="PAGO" FontSize="11" Foreground="#94A3B8" FontWeight="Bold"/>
                        <TextBlock x:Name="txtPago" Text="$0.00" FontSize="22" FontWeight="Bold" Foreground="#374151"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                        <TextBlock Text="CAMBIO" FontSize="11" Foreground="#94A3B8" FontWeight="Bold"/>
                        <TextBlock x:Name="txtCambio" Text="$0.00" FontSize="22" FontWeight="Bold" Foreground="#16A34A"/>
                    </StackPanel>

                </Grid>

            </Border>

            <Button Grid.Column="1"
                    Content="💳  COBRAR"
                    Style="{StaticResource BtnCobrar}"
                    Margin="4,8"
                    Click="BtnCobrar_Click"/>

        </Grid>

    </Grid>

</Window>