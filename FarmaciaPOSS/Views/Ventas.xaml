<Window x:Class="FarmaciaPOS.Views.VentasWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Punto de Venta"
        Height="650"
        Width="900"
        Icon="/logo-icono.ico"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7FA"
        KeyDown="VentasWindow_KeyDown"
        PreviewKeyDown="VentasWindow_PreviewKeyDown">

    <Grid Margin="15">

        <Grid.ColumnDefinitions>

            <ColumnDefinition Width="2*"/>

            <ColumnDefinition Width="*"/>

        </Grid.ColumnDefinitions>

        <!-- ===================================== -->
        <!-- PANEL IZQUIERDO -->
        <!-- ===================================== -->

        <Border Grid.Column="0"
                Background="White"
                CornerRadius="10"
                Padding="15"
                Margin="0,0,10,0">

            <Grid>

                <Grid.RowDefinitions>

                    <RowDefinition Height="60"/>

                    <RowDefinition Height="*"/>

                </Grid.RowDefinitions>

                <!-- BUSCADOR -->

                <TextBox x:Name="txtBuscar"
                         Height="40"
                         FontSize="16"
                         VerticalContentAlignment="Center"
                         TextChanged="txtBuscar_TextChanged"
                         KeyDown="txtBuscar_KeyDown"/>

                <!-- PRODUCTOS -->

                <DataGrid x:Name="dgProductos"
                          Grid.Row="1"
                          Margin="0,15,0,0"
                          AutoGenerateColumns="False"
                          MouseDoubleClick="dgProductos_MouseDoubleClick">

                    <DataGrid.Columns>

                        <DataGridTextColumn
                            Header="Código"
                            Binding="{Binding CodigoBarras}"
                            Width="150"/>

                        <DataGridTextColumn
                            Header="Producto"
                            Binding="{Binding Nombre}"
                            Width="*"/>

                        <DataGridTextColumn
                            Header="Precio"
                            Binding="{Binding PrecioVenta}"
                            Width="120"/>

                        <DataGridTextColumn
                            Header="Stock"
                            Binding="{Binding Stock}"
                            Width="100"/>

                    </DataGrid.Columns>

                </DataGrid>

            </Grid>

        </Border>

        <!-- ===================================== -->
        <!-- PANEL DERECHO -->
        <!-- ===================================== -->

        <Border Grid.Column="1"
                Background="White"
                CornerRadius="10"
                Padding="15">

            <Grid>

                <Grid.RowDefinitions>

                    <!-- CARRITO -->
                    <RowDefinition Height="*"/>

                    <!-- TOTAL -->
                    <RowDefinition Height="110"/>

                    <!-- BOTONES -->
                    <RowDefinition Height="140"/>

                </Grid.RowDefinitions>

                <!-- CARRITO -->

                <DataGrid x:Name="dgCarrito"
                          AutoGenerateColumns="False"
                          SelectionMode="Single"
                          SelectionUnit="FullRow">

                    <DataGrid.Columns>

                        <DataGridTextColumn
                            Header="Producto"
                            Binding="{Binding Nombre}"
                            Width="*"/>

                        <DataGridTextColumn
                            Header="Cant."
                            Binding="{Binding Cantidad}"
                            Width="60"/>

                        <DataGridTextColumn
                            Header="Precio"
                            Binding="{Binding Precio}"
                            Width="60"/>

                        <DataGridTextColumn
                            Header="Subtotal"
                            Binding="{Binding Subtotal}"
                            Width="60"/>

                    </DataGrid.Columns>

                </DataGrid>

                <!-- TOTAL -->

                <Border Grid.Row="1"
                        Background="#1E293B"
                        CornerRadius="10"
                        Margin="0,15,0,15">

                    <StackPanel
                        VerticalAlignment="Center">

                        <TextBlock Text="TOTAL"
                                   Foreground="White"
                                   FontSize="24"
                                   HorizontalAlignment="Center"/>

                        <TextBlock x:Name="txtTotal"
                                   Text="$0.00"
                                   Foreground="#22C55E"
                                   FontWeight="Bold"
                                   FontSize="42"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>

                </Border>

                <!-- BOTONES -->

                <Grid Grid.Row="2"
                      Margin="8">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- BOTÓN 1 -->

                    <Button Grid.Row="0"
                            Grid.Column="0"
                            Content="Agregar"
                            Margin="5"
                            FontSize="16"
                            Height="45"
                            Background="#DDE32D"
                            Foreground="White"
                            Click="BtnAgregarCantidad_Click"/>

                    <!-- BOTÓN 2 -->

                    <Button Grid.Row="0"
                            Grid.Column="1"
                            Content="Cobrar"
                            Margin="5"
                            FontSize="16"
                            Height="45"
                            Background="#2563EB"
                            Foreground="White"
                            Click="BtnCobrar_Click"/>

                    <!-- BOTÓN 3 -->

                    <Button Grid.Row="1"
                            Grid.Column="0"
                            Content="Cancelar"
                            Margin="5"
                            FontSize="16"
                            Height="45"
                            Background="#DC2626"
                            Foreground="White"
                            Click="BtnCancelar_Click"/>

                    <!-- BOTÓN 4 -->

                    <Button Grid.Row="1"
                            Grid.Column="1"
                            Content="Generar Ticket"
                            Margin="5"
                            FontSize="16"
                            Height="45"
                            Background="#16A34A"
                            Foreground="White"
                            Click="BtnGenerarTicket_Click"/>

                </Grid>

            </Grid>

        </Border>

    </Grid>

</Window>