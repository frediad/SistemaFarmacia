<Window x:Class="FarmaciaPOS.Views.TicketConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configuración Ticket"
        Height="600"
        Width="500"
        Icon="/logo-icono.ico"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7FA">

    <Grid Margin="20">

        <Border Background="White"
                CornerRadius="10"
                Padding="20">

            <StackPanel>

                <TextBlock Text="Nombre Negocio"
                           FontWeight="Bold"/>

                <TextBox x:Name="txtNegocio"
                         Height="35"
                         Margin="0,5,0,15"/>

                <!-- RFC -->

                <TextBlock Text="RFC"
                           FontWeight="Bold"/>

                <TextBox x:Name="txtRFC"
                         Height="35"
                         Margin="0,5,0,15"/>

                <!-- DIRECCION -->

                <TextBlock Text="Dirección"
                           FontWeight="Bold"/>

                <TextBox x:Name="txtDireccion"
                         Height="35"
                         Margin="0,5,0,15"/>

                <!-- TELEFONO -->

                <TextBlock Text="Teléfono"
                           FontWeight="Bold"/>

                <TextBox x:Name="txtTelefono"
                         Height="35"
                         Margin="0,5,0,15"/>

                <!-- MENSAJE -->

                <TextBlock Text="Mensaje Ticket"
                           FontWeight="Bold"/>

                <TextBox x:Name="txtMensaje"
                         Height="100"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         Margin="0,5,0,20"/>

                <!-- BOTON -->

                <Button Content="Guardar Configuración"
                        Height="45"
                        FontSize="16"
                        Click="BtnGuardar_Click"/>

            </StackPanel>

        </Border>

    </Grid>

</Window>