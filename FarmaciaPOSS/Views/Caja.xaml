<Window x:Class="FarmaciaPOS.Views.CajaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Caja"
        Height="650"
        Width="1000"
        Icon="/logo-icono.ico"
        WindowStartupLocation="CenterScreen">

    <Grid Background="#F5F5F5">

        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->

        <Border Background="#2563EB"
                Grid.Row="0">

            <TextBlock Text="CONTROL DE CAJA"
                       Foreground="White"
                       FontSize="28"
                       FontWeight="Bold"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"/>
        </Border>

        <!-- CONTENIDO -->

        <Grid Grid.Row="1"
              Margin="20">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- PANEL IZQUIERDO -->

            <Border Grid.Column="0"
                    Background="White"
                    CornerRadius="10"
                    Padding="20"
                    Margin="0,0,20,0">

                <StackPanel>

                    <TextBlock Text="Monto Inicial"
                               FontSize="18"
                               FontWeight="Bold"/>

                    <TextBox x:Name="txtMontoInicial"
                             Height="35"
                             Margin="0,10,0,20"
                             FontSize="16"/>

                    <Button x:Name="btnAbrirCaja"
                            Content="ABRIR CAJA"
                            Height="45"
                            Background="#16A34A"
                            Foreground="White"
                            FontSize="18"
                            FontWeight="Bold"
                            Click="BtnAbrirCaja_Click"/>

                    <Separator Margin="0,25"/>

                    <TextBlock Text="Movimiento"
                               FontSize="18"
                               FontWeight="Bold"/>

                    <ComboBox x:Name="cbTipoMovimiento"
                              Height="35"
                              Margin="0,10,0,10">

                        <ComboBoxItem Content="ENTRADA"/>
                        <ComboBoxItem Content="SALIDA"/>

                    </ComboBox>

                    <TextBox x:Name="txtMontoMovimiento"
                             Height="35"
                             Margin="0,0,0,10"
                             FontSize="16"/>

                    <TextBox x:Name="txtMotivo"
                             Height="70"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             Margin="0,0,0,20"/>

                    <Button Content="REGISTRAR MOVIMIENTO"
                            Height="45"
                            Background="#2563EB"
                            Foreground="White"
                            FontWeight="Bold"
                            Click="BtnMovimiento_Click"/>

                    <Separator Margin="0,25"/>

                    <Button Content="CERRAR CAJA"
                            Height="50"
                            Background="#DC2626"
                            Foreground="White"
                            FontSize="18"
                            FontWeight="Bold"
                            Click="BtnCerrarCaja_Click"/>

                </StackPanel>

            </Border>

            <!-- PANEL DERECHO -->

            <Border Grid.Column="1"
                    Background="White"
                    CornerRadius="10"
                    Padding="15">

                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Movimientos de Caja"
                               FontSize="24"
                               FontWeight="Bold"
                               Margin="0,0,0,15"/>

                    <DataGrid x:Name="dgMovimientos"
                              Grid.Row="1"
                              AutoGenerateColumns="True"
                              IsReadOnly="True"/>

                </Grid>

            </Border>

        </Grid>

    </Grid>

</Window>