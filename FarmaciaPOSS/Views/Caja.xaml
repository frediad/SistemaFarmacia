<Window x:Class="FarmaciaPOS.Views.CajaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Caja"
        Height="700"
        Width="1100"
        Icon="/logo-icono.ico"
        WindowStartupLocation="CenterScreen"
        Background="#F0F4F8">

    <Window.Resources>

        <Style x:Key="TxtCaja" TargetType="TextBox">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="Foreground" Value="#1E293B"/>
            <Setter Property="CaretBrush" Value="#2563EB"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#2563EB"/>
                                <Setter TargetName="border" Property="Background" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TxtDenominacion" TargetType="TextBox" BasedOn="{StaticResource TxtCaja}">
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style x:Key="CboCaja" TargetType="ComboBox">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1.5"/>
        </Style>

        <Style x:Key="BtnCajaBase" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnAbrirCajaEstilo" TargetType="Button" BasedOn="{StaticResource BtnCajaBase}">
            <Setter Property="Background" Value="#16A34A"/>
            <Setter Property="FontSize" Value="16"/>
        </Style>

        <Style x:Key="BtnMovimientoEstilo" TargetType="Button" BasedOn="{StaticResource BtnCajaBase}">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="FontSize" Value="15"/>
        </Style>

        <Style x:Key="BtnCerrarCajaEstilo" TargetType="Button" BasedOn="{StaticResource BtnCajaBase}">
            <Setter Property="Background" Value="#DC2626"/>
            <Setter Property="FontSize" Value="16"/>
        </Style>

        <Style x:Key="BtnCorteEstilo" TargetType="Button" BasedOn="{StaticResource BtnCajaBase}">
            <Setter Property="Background" Value="#7C3AED"/>
            <Setter Property="FontSize" Value="15"/>
        </Style>

    </Window.Resources>

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ===================================== -->
        <!-- HEADER                                -->
        <!-- ===================================== -->

        <Border Background="#1E3A8A" Grid.Row="0">

            <Grid Margin="20,0">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="110"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="🧾  Control de Caja"
                           Foreground="White"
                           FontSize="24"
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>

                <Button Grid.Column="1"
                        Content="✕ Cerrar"
                        Width="100"
                        Height="40"
                        FontSize="14"
                        FontWeight="Bold"
                        Background="#DC2626"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        VerticalAlignment="Center"
                        Click="BtnCerrarVentana_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

            </Grid>

        </Border>

        <!-- ===================================== -->
        <!-- PESTAÑAS                              -->
        <!-- ===================================== -->

        <TabControl x:Name="tabCaja"
                    Grid.Row="1"
                    Background="Transparent"
                    BorderThickness="0"
                    Margin="20">

            <!-- ===================================== -->
            <!-- PESTAÑA 1 — CAJA ACTUAL                -->
            <!-- ===================================== -->

            <TabItem Header="💵 Caja Actual">

                <Grid Margin="0,15,0,0">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="360"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- ===================================== -->
                    <!-- PANEL IZQUIERDO                       -->
                    <!-- ===================================== -->

                    <Border Grid.Column="0"
                            Background="White"
                            CornerRadius="12"
                            Padding="22"
                            Margin="0,0,15,0">

                        <ScrollViewer VerticalScrollBarVisibility="Auto">

                            <StackPanel>

                                <!-- APERTURA (visible solo si no hay caja abierta) -->
                                <StackPanel x:Name="pnlApertura">

                                    <TextBlock Text="💰 Apertura de Caja"
                                               FontSize="17"
                                               FontWeight="Bold"
                                               Foreground="#1E293B"
                                               Margin="0,0,0,14"/>

                                    <TextBlock Text="MONTO INICIAL"
                                               FontSize="11"
                                               FontWeight="Bold"
                                               Foreground="#94A3B8"
                                               Margin="2,0,0,6"/>

                                    <TextBox x:Name="txtMontoInicial"
                                             Height="42"
                                             Style="{StaticResource TxtCaja}"
                                             Margin="0,0,0,14"/>

                                    <Button x:Name="btnAbrirCaja"
                                            Content="🔓 ABRIR CAJA"
                                            Height="46"
                                            Style="{StaticResource BtnAbrirCajaEstilo}"
                                            Click="BtnAbrirCaja_Click"/>

                                </StackPanel>

                                <!-- MOVIMIENTOS (visible solo si hay caja abierta) -->
                                <StackPanel x:Name="pnlMovimientos" Visibility="Collapsed">

                                    <TextBlock Text="🔄 Registrar Movimiento"
                                               FontSize="17"
                                               FontWeight="Bold"
                                               Foreground="#1E293B"
                                               Margin="0,0,0,14"/>

                                    <TextBlock Text="TIPO DE MOVIMIENTO"
                                               FontSize="11"
                                               FontWeight="Bold"
                                               Foreground="#94A3B8"
                                               Margin="2,0,0,6"/>

                                    <ComboBox x:Name="cbTipoMovimiento"
                                              Height="42"
                                              Style="{StaticResource CboCaja}"
                                              Margin="0,0,0,14">

                                        <ComboBoxItem Content="ENTRADA"/>
                                        <ComboBoxItem Content="SALIDA"/>

                                    </ComboBox>

                                    <TextBlock Text="MONTO"
                                               FontSize="11"
                                               FontWeight="Bold"
                                               Foreground="#94A3B8"
                                               Margin="2,0,0,6"/>

                                    <TextBox x:Name="txtMontoMovimiento"
                                             Height="42"
                                             Style="{StaticResource TxtCaja}"
                                             Margin="0,0,0,14"/>

                                    <TextBlock Text="MOTIVO"
                                               FontSize="11"
                                               FontWeight="Bold"
                                               Foreground="#94A3B8"
                                               Margin="2,0,0,6"/>

                                    <TextBox x:Name="txtMotivo"
                                             Height="70"
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             Style="{StaticResource TxtCaja}"
                                             Margin="0,0,0,18"/>

                                    <Button Content="📝 REGISTRAR MOVIMIENTO"
                                            Height="46"
                                            Style="{StaticResource BtnMovimientoEstilo}"
                                            Click="BtnMovimiento_Click"/>

                                    <Separator Margin="0,24" Background="#E2E8F0"/>

                                    <Button Content="🧮 REALIZAR CORTE DE CAJA"
                                            Height="46"
                                            Style="{StaticResource BtnCorteEstilo}"
                                            Margin="0,0,0,12"
                                            Click="BtnAbrirCorte_Click"/>

                                    <Button Content="🔒 CERRAR CAJA SIN CORTE"
                                            Height="42"
                                            Background="#94A3B8"
                                            Foreground="White"
                                            FontWeight="Bold"
                                            BorderThickness="0"
                                            Cursor="Hand"
                                            Click="BtnCerrarCaja_Click">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>

                                </StackPanel>

                            </StackPanel>

                        </ScrollViewer>

                    </Border>

                    <!-- ===================================== -->
                    <!-- PANEL DERECHO                         -->
                    <!-- ===================================== -->

                    <Grid Grid.Column="1">

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- RESUMEN EN VIVO -->
                        <Border Background="#1E293B"
                                CornerRadius="12"
                                Padding="18"
                                Margin="0,0,0,15">

                            <UniformGrid Columns="5">

                                <StackPanel Margin="6,0" HorizontalAlignment="Center">
                                    <TextBlock Text="MONTO INICIAL" FontSize="11" Foreground="#94A3B8" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="txtResumenInicial" Text="$0.00" FontSize="18" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                </StackPanel>

                                <StackPanel Margin="6,0" HorizontalAlignment="Center">
                                    <TextBlock Text="VENTAS EFECTIVO" FontSize="11" Foreground="#94A3B8" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="txtResumenVentasEfectivo" Text="$0.00" FontSize="18" FontWeight="Bold" Foreground="#22C55E" HorizontalAlignment="Center"/>
                                </StackPanel>

                                <StackPanel Margin="6,0" HorizontalAlignment="Center">
                                    <TextBlock Text="ENTRADAS" FontSize="11" Foreground="#94A3B8" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="txtResumenEntradas" Text="$0.00" FontSize="18" FontWeight="Bold" Foreground="#22C55E" HorizontalAlignment="Center"/>
                                </StackPanel>

                                <StackPanel Margin="6,0" HorizontalAlignment="Center">
                                    <TextBlock Text="SALIDAS" FontSize="11" Foreground="#94A3B8" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="txtResumenSalidas" Text="$0.00" FontSize="18" FontWeight="Bold" Foreground="#F87171" HorizontalAlignment="Center"/>
                                </StackPanel>

                                <StackPanel Margin="6,0" HorizontalAlignment="Center">
                                    <TextBlock Text="TOTAL ESPERADO" FontSize="11" Foreground="#94A3B8" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="txtResumenEsperado" Text="$0.00" FontSize="20" FontWeight="Bold" Foreground="#60A5FA" HorizontalAlignment="Center"/>
                                </StackPanel>

                            </UniformGrid>

                        </Border>

                        <!-- MOVIMIENTOS -->
                        <Border Grid.Row="1"
                                Background="White"
                                CornerRadius="12"
                                Padding="18">

                            <Grid>

                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="Movimientos de la Caja Actual"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Foreground="#1E293B"
                                           Margin="0,0,0,12"/>

                                <DataGrid x:Name="dgMovimientos"
                                          Grid.Row="1"
                                          AutoGenerateColumns="True"
                                          IsReadOnly="True"
                                          HeadersVisibility="Column"
                                          BorderThickness="0"
                                          RowHeight="36"
                                          FontSize="14"
                                          GridLinesVisibility="Horizontal"
                                          HorizontalGridLinesBrush="#F1F5F9">

                                    <DataGrid.ColumnHeaderStyle>
                                        <Style TargetType="DataGridColumnHeader">
                                            <Setter Property="Background" Value="#F8FAFC"/>
                                            <Setter Property="Foreground" Value="#64748B"/>
                                            <Setter Property="FontSize" Value="12"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="Padding" Value="10,8"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                        </Style>
                                    </DataGrid.ColumnHeaderStyle>

                                </DataGrid>

                            </Grid>

                        </Border>

                    </Grid>

                </Grid>

            </TabItem>

            <!-- ===================================== -->
            <!-- PESTAÑA 2 — HISTORIAL DE CORTES        -->
            <!-- ===================================== -->

            <TabItem Header="📜 Historial de Cortes">

                <Border Background="White"
                        CornerRadius="12"
                        Padding="18"
                        Margin="0,15,0,0">

                    <Grid>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Historial de Cortes de Caja"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="#1E293B"
                                   Margin="0,0,0,12"/>

                        <DataGrid x:Name="dgHistorialCortes"
                                  Grid.Row="1"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  HeadersVisibility="Column"
                                  BorderThickness="0"
                                  RowHeight="38"
                                  FontSize="14"
                                  GridLinesVisibility="Horizontal"
                                  HorizontalGridLinesBrush="#F1F5F9">

                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#F8FAFC"/>
                                    <Setter Property="Foreground" Value="#64748B"/>
                                    <Setter Property="FontSize" Value="12"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="Padding" Value="10,8"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>

                            <DataGrid.Columns>

                                <DataGridTextColumn Header="Apertura"
                                    Binding="{Binding FechaApertura, StringFormat=dd/MM/yyyy HH:mm}"
                                    Width="150"/>

                                <DataGridTextColumn Header="Cierre"
                                    Binding="{Binding FechaCierre, StringFormat=dd/MM/yyyy HH:mm}"
                                    Width="150"/>

                                <DataGridTextColumn Header="Monto Inicial"
                                    Binding="{Binding MontoInicial, StringFormat=C}"
                                    Width="130"/>

                                <DataGridTextColumn Header="Esperado"
                                    Binding="{Binding MontoFinalEsperado, StringFormat=C}"
                                    Width="130"/>

                                <DataGridTextColumn Header="Contado"
                                    Binding="{Binding MontoFinalContado, StringFormat=C}"
                                    Width="130"/>

                                <DataGridTextColumn Header="Diferencia"
                                    Binding="{Binding Diferencia, StringFormat=C}"
                                    Width="130"/>

                                <DataGridTextColumn Header="Estado"
                                    Binding="{Binding Estado}"
                                    Width="*"/>

                            </DataGrid.Columns>

                        </DataGrid>

                    </Grid>

                </Border>

            </TabItem>

        </TabControl>

        <!-- ===================================== -->
        <!-- ✅ OVERLAY: CORTE DE CAJA (ARQUEO)      -->
        <!-- ===================================== -->

        <Border x:Name="overlayCorte"
                Grid.Row="0"
                Grid.RowSpan="2"
                Background="#B0000000"
                Visibility="Collapsed">

            <Border Background="White"
                    CornerRadius="16"
                    Width="620"
                    MaxHeight="700"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Padding="26">

                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.25" BlurRadius="30" ShadowDepth="6"/>
                </Border.Effect>

                <ScrollViewer VerticalScrollBarVisibility="Auto">

                    <StackPanel>

                        <TextBlock Text="🧮 Corte de Caja — Arqueo de Efectivo"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="#1E293B"
                                   Margin="0,0,0,4"/>

                        <TextBlock Text="Cuenta el efectivo físico en caja por billete y moneda"
                                   FontSize="12"
                                   Foreground="#94A3B8"
                                   Margin="0,0,0,18"/>

                        <TextBlock Text="BILLETES"
                                   FontSize="12"
                                   FontWeight="Bold"
                                   Foreground="#2563EB"
                                   Margin="0,0,0,8"/>

                        <UniformGrid Columns="3" Margin="0,0,0,18">

                            <StackPanel Margin="4">
                                <TextBlock Text="$1000" FontSize="11" Foreground="Gray" HorizontalAlignment="Center"/>
                                <TextBox x:Name="txtCant1000" Text="0" Style="{StaticResource TxtDenominacion}" Height="38" TextChanged="Denominacion_TextChanged"/>
                            </StackPanel>

                            <StackPanel Margin="4">
                                <TextBlock Text="$500" FontSize="11" Foreground="Gray" HorizontalAlignment="Center"/>
                                <TextBox x:Name="txtCant500" Text="0" Style="{StaticResource TxtDenominacion}" Height="38" TextChanged="Denominacion_TextChanged"/>
                            </StackPanel>

                            <StackPanel Margin="4">
                                <TextBlock Text="$200" FontSize="11" Foreground="Gray" HorizontalAlignment="Center"/>
                                <TextBox x:Name="txtCant200" Text="0" Style="{StaticResource TxtDenominacion}" Height="38" TextChanged="Denominacion_TextChanged"/>
                            </StackPanel>

                            <StackPanel Margin="4">
                                <TextBlock Text="$100" FontSize="11" Foreground="Gray" HorizontalAlignment="Center"/>
                                <TextBox x:Name="txtCant100" Text="0" Style="{StaticResource TxtDenominacion}" Height="38" TextChanged="Denominacion_TextChanged"/>
                            </StackPanel>

                            <StackPanel Margin="4">
                                <TextBlock Text="$50" FontSize="11" Foreground="Gray" HorizontalAlignment="Center"/>
                                <TextBox x:Name="txtCant50" Text="0" Style="{StaticResource TxtDenominacion}" Height="38" TextChanged="Denominacion_TextChanged"/>
                            </StackPanel>

                            <StackPanel Margin="4">
                                <TextBlock Text="$20" FontSize="11" Foreground="Gray" HorizontalAlignment="Center"/>
                                <TextBox x:Name="txtCant20" Text="0" Style="{StaticResource TxtDenominacion}" Height="38" TextChanged="Denominacion_TextChanged"/>
                            </StackPanel>

                        </UniformGrid>

                        <TextBlock Text="MONEDAS"
                                   FontSize="12"
                                   FontWeight="Bold"
                                   Foreground="#2563EB"
                                   Margin="0,0,0,8"/>

                        <UniformGrid Columns="5" Margin="0,0,0,18">

                            <StackPanel Margin="4">
                                <TextBlock Text="$10" FontSize="11" Foreground="Gray" HorizontalAlignment="Center"/>
                                <TextBox x:Name="txtCant10" Text="0" Style="{StaticResource TxtDenominacion}" Height="38" TextChanged="Denominacion_TextChanged"/>
                            </StackPanel>

                            <StackPanel Margin="4">
                                <TextBlock Text="$5" FontSize="11" Foreground="Gray" HorizontalAlignment="Center"/>
                                <TextBox x:Name="txtCant5" Text="0" Style="{StaticResource TxtDenominacion}" Height="38" TextChanged="Denominacion_TextChanged"/>
                            </StackPanel>

                            <StackPanel Margin="4">
                                <TextBlock Text="$2" FontSize="11" Foreground="Gray" HorizontalAlignment="Center"/>
                                <TextBox x:Name="txtCant2" Text="0" Style="{StaticResource TxtDenominacion}" Height="38" TextChanged="Denominacion_TextChanged"/>
                            </StackPanel>

                            <StackPanel Margin="4">
                                <TextBlock Text="$1" FontSize="11" Foreground="Gray" HorizontalAlignment="Center"/>
                                <TextBox x:Name="txtCant1" Text="0" Style="{StaticResource TxtDenominacion}" Height="38" TextChanged="Denominacion_TextChanged"/>
                            </StackPanel>

                            <StackPanel Margin="4">
                                <TextBlock Text="$0.50" FontSize="11" Foreground="Gray" HorizontalAlignment="Center"/>
                                <TextBox x:Name="txtCant050" Text="0" Style="{StaticResource TxtDenominacion}" Height="38" TextChanged="Denominacion_TextChanged"/>
                            </StackPanel>

                        </UniformGrid>

                        <Border Background="#F8FAFC"
                                CornerRadius="10"
                                Padding="16"
                                Margin="0,0,0,18">

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="ESPERADO" FontSize="11" FontWeight="Bold" Foreground="#94A3B8" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="txtCorteEsperado" Text="$0.00" FontSize="20" FontWeight="Bold" Foreground="#1E293B" HorizontalAlignment="Center"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                    <TextBlock Text="CONTADO" FontSize="11" FontWeight="Bold" Foreground="#94A3B8" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="txtCorteContado" Text="$0.00" FontSize="20" FontWeight="Bold" Foreground="#2563EB" HorizontalAlignment="Center"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                    <TextBlock Text="DIFERENCIA" FontSize="11" FontWeight="Bold" Foreground="#94A3B8" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="txtCorteDiferencia" Text="$0.00" FontSize="20" FontWeight="Bold" Foreground="#16A34A" HorizontalAlignment="Center"/>
                                </StackPanel>

                            </Grid>

                        </Border>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Button Content="Cancelar"
                                    Height="46"
                                    Background="#F1F5F9"
                                    Foreground="#475569"
                                    FontWeight="Bold"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Click="BtnCancelarCorte_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <Button Grid.Column="2"
                                    Content="✅ Confirmar Corte y Cerrar Caja"
                                    Height="46"
                                    Style="{StaticResource BtnCerrarCajaEstilo}"
                                    Click="BtnConfirmarCorte_Click"/>

                        </Grid>

                    </StackPanel>

                </ScrollViewer>

            </Border>

        </Border>

    </Grid>

</Window>