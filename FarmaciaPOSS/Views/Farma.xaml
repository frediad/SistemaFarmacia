<Window x:Class="FarmaciaPOS.Views.Farma"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configuración Farmacia"
        Height="550"
        Width="900"
        Icon="/logo-icono.ico"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F0F4F8">

    <Window.Resources>

        <Style x:Key="BtnModuloEstadisticas" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="24,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <Border.Effect>
                                <DropShadowEffect Color="#000000"
                                                  Opacity="0.10"
                                                  BlurRadius="12"
                                                  ShadowDepth="2"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Left"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.90"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.78"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnRegresarModulo" TargetType="Button" BasedOn="{StaticResource BtnModuloEstadisticas}">
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>

    </Window.Resources>

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="90"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ========================================= -->
        <!-- HEADER                                    -->
        <!-- ========================================= -->

        <Border Grid.Row="0">
            
           
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#1E3A8A" Offset="0"/>
                    <GradientStop Color="#1E40AF" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>

            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center">

                <TextBlock Text="📊 Estadísticas"
                           Foreground="White"
                           FontSize="26"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"/>

                <TextBlock Text="Control de caducidades y análisis de ventas"
                           Foreground="#BFDBFE"
                           FontSize="13"
                           HorizontalAlignment="Center"
                           Margin="0,4,0,0"/>

            </StackPanel>

        </Border>

        <!-- ========================================= -->
        <!-- CONTENIDO                                 -->
        <!-- ========================================= -->

        <Border Grid.Row="1"
                Background="White"
                CornerRadius="16"
                Margin="60,40">

            <Border.Effect>
                <DropShadowEffect Color="#000000"
                                  Opacity="0.06"
                                  BlurRadius="16"
                                  ShadowDepth="2"/>
            </Border.Effect>

            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Width="420">

                <Button x:Name="btnCaducidades"
                        Height="64"
                        Margin="0,10"
                        FontSize="17"
                        Background="#16A34A"
                        Style="{StaticResource BtnModuloEstadisticas}"
                        Click="btnCaducidades_Click"
                        Content="📅  Productos por Caducar"/>

                <Button x:Name="btnGraficas"
                        Height="64"
                        Margin="0,10"
                        FontSize="17"
                        Background="#2563EB"
                        Style="{StaticResource BtnModuloEstadisticas}"
                        Click="btnGraficas_Click"
                        Content="📊  Gráficas de Ventas"/>

                <Button x:Name="btnRegresar"
                        Height="52"
                        Margin="0,30,0,0"
                        FontSize="15"
                        Background="#64748B"
                        Style="{StaticResource BtnRegresarModulo}"
                        Click="btnRegresar_Click"
                        Content="⬅ Regresar"/>

            </StackPanel>

        </Border>

    </Grid>

</Window>