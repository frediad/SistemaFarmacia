<Window x:Class="FarmaciaPOS.Views.PosConfig"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configuración POS"
        Height="700"
        Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#F0F4F8">

    <Window.Resources>

        <Style x:Key="TxtConfig" TargetType="TextBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#2563EB"/>
                                <Setter TargetName="border" Property="Background" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CboConfig" TargetType="ComboBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1.5"/>
        </Style>

        <Style x:Key="BtnAccionConfig" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="65"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Background="#1E3A8A" Grid.Row="0">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="100"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="⚙️ Respaldo de información"
                           Foreground="White"
                           FontSize="20"
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>

                <Button Grid.Column="1"
                        Content="✕ Cerrar"
                        Width="90"
                        Height="36"
                        FontSize="13"
                        FontWeight="Bold"
                        Background="#DC2626"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        VerticalAlignment="Center"
                        Click="BtnCerrarVentana_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <!-- PESTAÑAS -->
        <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0" Margin="15">

            <!-- ===================================== -->
            <!-- BASE DE DATOS                          -->
            <!-- ===================================== -->

            <TabItem Header="🗄️ Base de Datos">

                <Border Background="White" CornerRadius="12" Padding="20" Margin="0,15,0,0">

                    <StackPanel>

                        <TextBlock Text="Modo de conexión"
                           FontSize="16" FontWeight="Bold" Foreground="#1E293B"/>

                        <TextBlock Text="Elige cómo se conecta el sistema a la base de datos."
                           FontSize="12" Foreground="#94A3B8" Margin="0,4,0,20"/>

                        <RadioButton x:Name="rbLocal"
                             Content="Solo Local (SQL Server en esta red)"
                             FontSize="14"
                             GroupName="ModoConexion"
                             Margin="0,0,0,10"/>

                        <RadioButton x:Name="rbAzure"
                             Content="Solo Azure SQL (nube)"
                             FontSize="14"
                             GroupName="ModoConexion"
                             Margin="0,0,0,10"/>

                        <RadioButton x:Name="rbAmbas"
                             Content="Ambas (usa Local si está disponible; si no, cambia automáticamente a Azure)"
                             FontSize="14"
                             GroupName="ModoConexion"
                             Margin="0,0,0,20"/>

                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Button Content="🔎 Probar conexión Local"
                            Height="42"
                            Background="#64748B"
                            Style="{StaticResource BtnAccionConfig}"
                            Click="BtnProbarLocal_Click"/>

                            <Button Grid.Column="2"
                            Content="🔎 Probar conexión Azure"
                            Height="42"
                            Background="#64748B"
                            Style="{StaticResource BtnAccionConfig}"
                            Click="BtnProbarAzure_Click"/>
                        </Grid>

                        <TextBlock x:Name="txtEstadoConexion"
                           FontSize="13"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap"
                           Margin="0,0,0,20"/>

                        <Button Content="💾 Guardar modo de conexión"
                        Height="46"
                        Background="#16A34A"
                        Style="{StaticResource BtnAccionConfig}"
                        FontSize="15"
                        Click="BtnGuardarModoConexion_Click"/>

                        <TextBlock Text="⚠️ El cambio aplica de inmediato para nuevas consultas. Si tienes ventanas abiertas, ciérralas y vuelve a abrirlas para asegurar que usen la nueva conexión."
                           FontSize="11"
                           Foreground="#94A3B8"
                           TextWrapping="Wrap"
                           Margin="0,10,0,0"/>

                    </StackPanel>

                </Border>

            </TabItem>

            <!-- ===================================== -->
            <!-- RESPALDOS                              -->
            <!-- ===================================== -->

            <TabItem Header="💾 Respaldos Automáticos">

                <Border Background="White" CornerRadius="12" Padding="20" Margin="0,15,0,0">

                    <StackPanel>

                        <TextBlock Text="Respaldo de la base de datos"
                           FontSize="16" FontWeight="Bold" Foreground="#1E293B"/>

                        <TextBlock TextWrapping="Wrap"
                           FontSize="12" Foreground="#94A3B8" Margin="0,4,0,20">
                    Solo disponible cuando estás conectado a SQL Server Local. Azure SQL gestiona sus
                    propios respaldos automáticos desde el Portal de Azure (no se pueden ejecutar por código).
                        </TextBlock>

                        <CheckBox x:Name="chkRespaldoAutomatico"
                          Content="Activar respaldo automático mientras el sistema esté abierto"
                          FontSize="14"
                          Margin="0,0,0,15"/>

                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="180"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="CARPETA DE DESTINO" FontSize="11" FontWeight="Bold" Foreground="#94A3B8" Margin="2,0,0,6"/>
                                <TextBox x:Name="txtCarpetaRespaldo" Height="40" Style="{StaticResource TxtConfig}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="INTERVALO (HORAS)" FontSize="11" FontWeight="Bold" Foreground="#94A3B8" Margin="2,0,0,6"/>
                                <TextBox x:Name="txtIntervaloHoras" Height="40" Style="{StaticResource TxtConfig}" Text="24"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Button Content="📁 Elegir carpeta"
                            Height="42"
                            Background="#64748B"
                            Style="{StaticResource BtnAccionConfig}"
                            Click="BtnElegirCarpeta_Click"/>

                            <Button Grid.Column="2"
                            Content="💾 Hacer respaldo ahora"
                            Height="42"
                            Background="#2563EB"
                            Style="{StaticResource BtnAccionConfig}"
                            Click="BtnRespaldarAhora_Click"/>
                        </Grid>

                        <TextBlock x:Name="txtEstadoRespaldo"
                           FontSize="13"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap"
                           Margin="0,0,0,20"/>

                        <Button Content="💾 Guardar configuración de respaldo"
                        Height="46"
                        Background="#16A34A"
                        Style="{StaticResource BtnAccionConfig}"
                        FontSize="15"
                        Click="BtnGuardarRespaldo_Click"/>

                    </StackPanel>

                </Border>

            </TabItem>

        </TabControl>
    </Grid>

</Window>