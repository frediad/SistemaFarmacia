<Window x:Class="FarmaciaPOS.Views.DevolucionesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Devoluciones"
        Height="700"
        Width="1100"
        Icon="/logo-icono.ico"
        WindowStartupLocation="CenterScreen"
        Background="#F0F4F8">

    <Window.Resources>

        <Style x:Key="TxtField" TargetType="TextBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="White"
                                BorderBrush="#CBD5E1"
                                BorderThickness="1"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="10,0"
                                          VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnAccion" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="75"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ========================================= -->
        <!-- HEADER                                    -->
        <!-- ========================================= -->

        <Border Background="#1E3A8A">

            <Grid Margin="20,0">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center">

                    <TextBlock Text="↩️  Devoluciones"
                               Foreground="White"
                               FontSize="24"
                               FontWeight="Bold"/>

                    <TextBlock Text="Busca una venta y procesa la devolución"
                               Foreground="#93C5FD"
                               FontSize="13"/>

                </StackPanel>

                <Button Grid.Column="1"
                        Content="✕ Cerrar"
                        Width="100"
                        Height="38"
                        Background="#DC2626"
                        Style="{StaticResource BtnAccion}"
                        Click="BtnCerrarVentana_Click"/>

            </Grid>

        </Border>

        <!-- ========================================= -->
        <!-- CONTENIDO                                 -->
        <!-- ========================================= -->

        <Grid Grid.Row="1"
              Margin="15">

            <Grid.ColumnDefinitions>
                <!-- LISTA DE VENTAS -->
                <ColumnDefinition Width="420"/>
                <!-- DETALLE DEVOLUCIÓN -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ===================================== -->
            <!-- PANEL IZQUIERDO — LISTA DE VENTAS     -->
            <!-- ===================================== -->

            <Border Background="White"
                    CornerRadius="12"
                    Padding="15"
                    Margin="0,0,10,0"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1">

                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Ventas Recientes"
                               FontSize="17"
                               FontWeight="Bold"
                               Foreground="#1E293B"
                               Margin="0,0,0,10"/>

                    <!-- BUSCADOR -->

                    <Border Grid.Row="1"
                            Background="#F8FAFC"
                            BorderBrush="#E2E8F0"
                            BorderThickness="1"
                            CornerRadius="8"
                            Margin="0,0,0,10">

                        <Grid>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="🔍"
                                       FontSize="16"
                                       Margin="10,0,5,0"
                                       VerticalAlignment="Center"/>

                            <TextBox x:Name="txtBuscarVenta"
                                     Grid.Column="1"
                                     Height="38"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     FontSize="14"
                                     VerticalContentAlignment="Center"
                                     TextChanged="TxtBuscarVenta_TextChanged">
                                <TextBox.Template>
                                    <ControlTemplate TargetType="TextBox">
                                        <Border Background="Transparent">
                                            <ScrollViewer x:Name="PART_ContentHost"
                                                          Margin="4,0"/>
                                        </Border>
                                    </ControlTemplate>
                                </TextBox.Template>
                            </TextBox>

                        </Grid>

                    </Border>

                    <!-- TABLA DE VENTAS -->

                    <DataGrid x:Name="dgVentas"
                              Grid.Row="2"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              BorderThickness="0"
                              RowHeight="40"
                              FontSize="13"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#F1F5F9"
                              SelectionChanged="DgVentas_SelectionChanged"
                              Cursor="Hand">

                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#F8FAFC"/>
                                <Setter Property="Foreground" Value="#64748B"/>
                                <Setter Property="FontSize" Value="11"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Padding" Value="8,6"/>
                                <Setter Property="BorderThickness" Value="0"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>

                        <DataGrid.Columns>

                            <DataGridTextColumn Header="# Venta"
                                Binding="{Binding Id}"
                                Width="70"/>

                            <DataGridTextColumn Header="Folio"
                                Binding="{Binding Folio}"
                                Width="*"/>

                            <DataGridTextColumn Header="Fecha"
                                Binding="{Binding Fecha, StringFormat=dd/MM/yyyy}"
                                Width="95"/>

                            <DataGridTextColumn Header="Total"
                                Binding="{Binding Total, StringFormat=C}"
                                Width="90"/>

                            <DataGridTemplateColumn Header="Estado"
                                                    Width="90">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="10"
                                                Padding="6,2"
                                                HorizontalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Estado}"
                                                                     Value="Completada">
                                                            <Setter Property="Background" Value="#DCFCE7"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Estado}"
                                                                     Value="Devuelta">
                                                            <Setter Property="Background" Value="#FEE2E2"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding Estado}"
                                                       FontSize="11"
                                                       FontWeight="Bold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Estado}"
                                                                         Value="Completada">
                                                                <Setter Property="Foreground" Value="#166534"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Estado}"
                                                                         Value="Devuelta">
                                                                <Setter Property="Foreground" Value="#991B1B"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                        </DataGrid.Columns>

                    </DataGrid>

                </Grid>

            </Border>

            <!-- ===================================== -->
            <!-- PANEL DERECHO — DETALLE DEVOLUCIÓN    -->
            <!-- ===================================== -->

            <Border Grid.Column="1"
                    Background="White"
                    CornerRadius="12"
                    Padding="15"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1">

                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- INFO VENTA SELECCIONADA -->

                    <Border Background="#EFF6FF"
                            CornerRadius="8"
                            Padding="12"
                            Margin="0,0,0,10">

                        <TextBlock x:Name="txtInfoVenta"
                                   Text="← Selecciona una venta de la lista"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Foreground="#1E40AF"/>

                    </Border>

                    <!-- TABLA DETALLE PRODUCTOS -->

                    <DataGrid x:Name="dgDetalleVenta"
                              Grid.Row="1"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              BorderThickness="0"
                              RowHeight="40"
                              FontSize="13"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#F1F5F9"
                              Margin="0,0,0,10">

                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#F8FAFC"/>
                                <Setter Property="Foreground" Value="#64748B"/>
                                <Setter Property="FontSize" Value="11"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Padding" Value="8,6"/>
                                <Setter Property="BorderThickness" Value="0"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>

                        <DataGrid.Columns>

                            <DataGridTextColumn Header="Producto"
                                Binding="{Binding Nombre}"
                                Width="*"
                                IsReadOnly="True"/>

                            <DataGridTextColumn Header="Vendido"
                                Binding="{Binding CantidadVendida}"
                                Width="75"
                                IsReadOnly="True"/>

                            <DataGridTextColumn Header="Devuelto"
                                Binding="{Binding CantidadYaDevuelta}"
                                Width="80"
                                IsReadOnly="True"/>

                            <DataGridTextColumn Header="Disponible"
                                Binding="{Binding CantidadDisponibleDevolver}"
                                Width="85"
                                IsReadOnly="True"/>

                            <DataGridTextColumn Header="Precio"
                                Binding="{Binding PrecioUnitario, StringFormat=C}"
                                Width="85"
                                IsReadOnly="True"/>

                            <DataGridTextColumn Header="A devolver"
                                Binding="{Binding CantidadADevolver}"
                                Width="90"/>

                        </DataGrid.Columns>

                    </DataGrid>

                    <!-- MOTIVO -->

                    <StackPanel Grid.Row="2"
                                Margin="0,0,0,12">

                        <TextBlock Text="MOTIVO DE LA DEVOLUCIÓN"
                                   FontSize="11"
                                   FontWeight="Bold"
                                   Foreground="#94A3B8"
                                   Margin="0,0,0,6"/>

                        <TextBox x:Name="txtMotivoDevolucion"
                                 Height="40"
                                 Style="{StaticResource TxtField}"/>

                    </StackPanel>

                    <!-- RESUMEN + BOTÓN -->

                    <Grid Grid.Row="3">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="220"/>
                        </Grid.ColumnDefinitions>

                        <Border Background="#FFF7ED"
                                CornerRadius="8"
                                Padding="12"
                                Margin="0,0,10,0">

                            <StackPanel VerticalAlignment="Center">

                                <TextBlock Text="MONTO A DEVOLVER"
                                           FontSize="11"
                                           FontWeight="Bold"
                                           Foreground="#92400E"/>

                                <TextBlock x:Name="txtMontoADevolver"
                                           Text="$0.00"
                                           FontSize="26"
                                           FontWeight="Bold"
                                           Foreground="#DC2626"/>

                            </StackPanel>

                        </Border>

                        <Button Grid.Column="1"
                                Content="↩️ Procesar Devolución"
                                Height="55"
                                Background="#DC2626"
                                Style="{StaticResource BtnAccion}"
                                Click="BtnProcesarDevolucion_Click"/>

                    </Grid>

                </Grid>

            </Border>

        </Grid>

    </Grid>

</Window>