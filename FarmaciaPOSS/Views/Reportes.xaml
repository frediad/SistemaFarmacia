<Window x:Class="FarmaciaPOS.Views.ReportesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Reportes de Ventas"
        Height="750"
        Width="1100"
        Icon="/logo-icono.ico"
        WindowStartupLocation="CenterScreen"
        Background="#EEF2F7">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="100"/>
            <RowDefinition Height="110"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->

        <Border Background="White"
                CornerRadius="10"
                Padding="20"
                Margin="0,0,0,15">

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="200"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Reportes de Ventas"
                           FontSize="30"
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>

                <Button Grid.Column="1"
                        Content="📄 Exportar PDF"
                        Height="45"
                        FontSize="16"
                        FontWeight="Bold"
                        Background="#DC2626"
                        Foreground="White"
                        Click="BtnExportarPDF_Click"/>

            </Grid>

        </Border>

        <!-- BOTONES DE PERIODO -->

        <Border Grid.Row="1"
                Background="White"
                CornerRadius="10"
                Padding="15"
                Margin="0,0,0,15">

            <UniformGrid Columns="4">

                <Button x:Name="btnHoy"
                        Content="📅 Hoy"
                        Height="55"
                        FontSize="18"
                        FontWeight="Bold"
                        Margin="5"
                        Background="#2563EB"
                        Foreground="White"
                        Click="BtnHoy_Click"/>

                <Button x:Name="btnSemana"
                        Content="📆 Semana"
                        Height="55"
                        FontSize="18"
                        FontWeight="Bold"
                        Margin="5"
                        Click="BtnSemana_Click"/>

                <Button x:Name="btnMes"
                        Content="🗓️ Mes"
                        Height="55"
                        FontSize="18"
                        FontWeight="Bold"
                        Margin="5"
                        Click="BtnMes_Click"/>

                <Button x:Name="btnAnio"
                        Content="📊 Año"
                        Height="55"
                        FontSize="18"
                        FontWeight="Bold"
                        Margin="5"
                        Click="BtnAnio_Click"/>

            </UniformGrid>

        </Border>

        <!-- CONTENIDO -->

        <Grid Grid.Row="2">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- RESUMEN + GRAFICA -->

            <StackPanel Margin="0,0,15,0">

                <!-- TOTALES -->

                <Border Background="#1E293B"
                        CornerRadius="10"
                        Padding="20"
                        Margin="0,0,0,15">

                    <StackPanel>

                        <TextBlock x:Name="txtPeriodoActual"
                                   Text="Periodo: Hoy"
                                   FontSize="16"
                                   Foreground="#94A3B8"
                                   HorizontalAlignment="Center"/>

                        <TextBlock Text="Total Vendido"
                                   FontSize="14"
                                   Foreground="#94A3B8"
                                   HorizontalAlignment="Center"
                                   Margin="0,15,0,0"/>

                        <TextBlock x:Name="txtTotalVentas"
                                   Text="$0.00"
                                   FontSize="42"
                                   FontWeight="Bold"
                                   Foreground="#272AF5"
                                   HorizontalAlignment="Center"/>

                        <TextBlock x:Name="txtNumeroVentas"
                                   Text="0 ventas"
                                   FontSize="16"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   Margin="0,5,0,0"/>

                    </StackPanel>

                </Border>

                <!-- GRAFICA -->

                <Border Background="White"
                        CornerRadius="10"
                        Padding="15"
                        Height="300">

                    <Grid>

                        <TextBlock Text="Ventas por día"
                                   FontWeight="Bold"
                                   FontSize="16"
                                   VerticalAlignment="Top"/>

                        <ItemsControl x:Name="icGrafica"
                                      VerticalAlignment="Bottom"
                                      Margin="0,30,0,30">

                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Center"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>

                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="6,0"
                                                Width="40">

                                        <Border Background="#2563EB"
                                                Width="30"
                                                Height="{Binding AlturaBarra}"
                                                VerticalAlignment="Bottom"
                                                CornerRadius="3"/>

                                        <TextBlock Text="{Binding Etiqueta}"
                                                   FontSize="10"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,5,0,0"/>

                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>

                        </ItemsControl>

                    </Grid>

                </Border>

            </StackPanel>

            <!-- TABLA DE PRODUCTOS -->

            <Border Grid.Column="1"
                    Background="White"
                    CornerRadius="10"
                    Padding="15">

                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Productos Vendidos"
                               FontSize="20"
                               FontWeight="Bold"
                               Margin="0,0,0,10"/>

                    <DataGrid x:Name="dgProductosVendidos"
                              Grid.Row="1"
                              AutoGenerateColumns="False"
                              FontSize="16"
                              CanUserAddRows="False"
                              HeadersVisibility="Column">

                        <DataGrid.Columns>

                            <DataGridTextColumn Header="Producto"
                                Binding="{Binding Producto}"
                                Width="*"/>

                            <DataGridTextColumn Header="Cantidad"
                                Binding="{Binding Cantidad}"
                                Width="120"/>

                            <DataGridTextColumn Header="Total"
                                Binding="{Binding Total, StringFormat=C}"
                                Width="140"/>

                        </DataGrid.Columns>

                    </DataGrid>

                </Grid>

            </Border>

        </Grid>

    </Grid>

</Window>