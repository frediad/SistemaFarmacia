<Window x:Class="FarmaciaPOS.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:FarmaciaPOS"
        Title="Sistema de Ventas"
        Height="750"
        Width="1250"
        Icon="/logo-icono.ico"
        WindowStartupLocation="CenterScreen"
        Background="#F0F4F8"
        PreviewKeyDown="DashboardWindow_PreviewKeyDown">

    <Window.Resources>

        <!-- ===================================== -->
        <!-- ESTILO BOTONES MENÚ SUPERIOR          -->
        <!-- ===================================== -->

        <Style x:Key="BtnMenuSuperior" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border"
                                        Property="Background"
                                        Value="#EFF6FF"/>
                                <Setter Property="Foreground" Value="#2563EB"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border"
                                        Property="Background"
                                        Value="#DBEAFE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===================================== -->
        <!-- ESTILO BOTONES LATERAL                -->
        <!-- ===================================== -->

        <Style x:Key="BtnLateral" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="90"/>
            <Setter Property="Height" Value="72"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border"
                                        Property="Background"
                                        Value="#EFF6FF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border"
                                        Property="Background"
                                        Value="#DBEAFE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===================================== -->
        <!-- ESTILO BOTONES CATEGORIA              -->
        <!-- ===================================== -->

        <Style x:Key="BtnCategoria" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="20"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border"
                                        Property="Background"
                                        Value="#EFF6FF"/>
                                <Setter TargetName="border"
                                        Property="BorderBrush"
                                        Value="#2563EB"/>
                                <Setter Property="Foreground" Value="#2563EB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===================================== -->
        <!-- ESTILO BOTÓN CATEGORÍA ACTIVA         -->
        <!-- ===================================== -->

        <Style x:Key="BtnCategoriaActiva" TargetType="Button">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="20"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===================================== -->
        <!-- ESTILO SCROLLBAR HORIZONTAL CATEGORÍAS -->
        <!-- ===================================== -->

        <Style x:Key="ScrollBarThumbCategorias" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="#CBD5E1"
                                CornerRadius="4"
                                Height="6"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ScrollBarCategorias" TargetType="ScrollBar">
            <Setter Property="Height" Value="8"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Track x:Name="PART_Track"
                                   IsDirectionReversed="False">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageLeftCommand"
                                                  Opacity="0"/>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageRightCommand"
                                                  Opacity="0"/>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ScrollBarThumbCategorias}"/>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===================================== -->
        <!-- ESTILO BOTÓN COBRAR                   -->
        <!-- ===================================== -->

        <Style x:Key="BtnCobrar" TargetType="Button">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border"
                                        Property="Background"
                                        Value="#1D4ED8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border"
                                        Property="Background"
                                        Value="#1E40AF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===================================== -->
        <!-- ESTILO BOTONES ACCIÓN INFERIOR        -->
        <!-- ===================================== -->

        <Style x:Key="BtnAccion" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border"
                                        Property="Background"
                                        Value="#F8FAFC"/>
                                <Setter TargetName="border"
                                        Property="BorderBrush"
                                        Value="#94A3B8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="110"/>
            <RowDefinition Height="70"/>
        </Grid.RowDefinitions>

        <!-- ========================================= -->
        <!-- HEADER                                    -->
        <!-- ========================================= -->

        <Border Background="#1693E0"
                Grid.Row="0">

            <Grid Margin="15,0">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- LOGO -->
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center">

                    <Image Source="/Images/logo-click.png"
                           Width="55"
                           Height="55"
                           Margin="0,0,12,0"/>

                    <StackPanel VerticalAlignment="Center">

                        <TextBlock Text="FarmaClick Yatzil"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="White"/>

                        <TextBlock Text="Tu sistema de ventas de confianza"
                                   FontSize="12"
                                   Foreground="#93C5FD"/>

                    </StackPanel>

                </StackPanel>

                <!-- MENÚ SUPERIOR -->
                <ScrollViewer Grid.Column="1"
                              HorizontalScrollBarVisibility="Hidden"
                              VerticalScrollBarVisibility="Hidden"
                              VerticalAlignment="Center"
                              Margin="20,0">

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center">

                        <Button x:Name="btnVentas"
                                Content="Ventas"
                                Style="{StaticResource BtnMenuSuperior}"
                                Height="40"
                                Foreground="#32248A"
                                Click="BtnVentas_Click"/>

                        <Button x:Name="btnPedidos"
                                Content="Pedidos"
                                Style="{StaticResource BtnMenuSuperior}"
                                Height="40"
                                Foreground="#32248A"
                                Click="BtnPedidos_Click"/>

                        <Button x:Name="btnProductos"
                                Content="Productos"
                                Style="{StaticResource BtnMenuSuperior}"
                                Height="40"
                                Foreground="#32248A"
                                Click="BtnProductos_Click"/>

                        <Button x:Name="btnInventario"
                                Content="Inventario"
                                Style="{StaticResource BtnMenuSuperior}"
                                Height="40"
                                Foreground="#32248A"
                                Click="BtnInventario_Click"/>

                        <Button x:Name="btnReportes"
                                Content="Reportes"
                                Style="{StaticResource BtnMenuSuperior}"
                                Height="40"
                                Foreground="#32248A"
                                Click="BtnReportes_Click"/>

                        <Button x:Name="btnConfiguracion"
                                Content="Configuración"
                                Style="{StaticResource BtnMenuSuperior}"
                                Height="40"
                                Foreground="#32248A"
                                Click="BtnConfiguracion_Click"/>

                        <Button x:Name="btnCaja"
                                Content="Caja"
                                Style="{StaticResource BtnMenuSuperior}"
                                Height="40"
                                Foreground="#32248A"
                                Click="BtnCaja_Click"/>

                    </StackPanel>

                </ScrollViewer>

                <!-- USUARIO + SALIR -->
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">

                    <StackPanel Margin="0,0,15,0"
                                VerticalAlignment="Center">

                        <TextBlock x:Name="txtUsuarioSesion"
                                   Text="Usuario"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Right"/>

                        <TextBlock x:Name="txtRolId"
                                   Text="Cargo"
                                   FontSize="12"
                                   Foreground="#93C5FD"
                                   HorizontalAlignment="Right"/>

                    </StackPanel>

                    <Button Content="⏻ Salir"
                            Width="90"
                            Height="38"
                            FontSize="14"
                            FontWeight="Bold"
                            Background="#DC2626"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="BtnSalir_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="b"
                                        Background="{TemplateBinding Background}"
                                        CornerRadius="8">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="b"
                                                Property="Background"
                                                Value="#B91C1C"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                </StackPanel>

            </Grid>

        </Border>

        <!-- ========================================= -->
        <!-- BARRA DE CÓDIGO DE PRODUCTO              -->
        <!-- ========================================= -->

        <Border Grid.Row="1"
                Background="White"
                BorderBrush="#E2E8F0"
                BorderThickness="0,0,0,1">

            <Grid Margin="15,0">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="200"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Código o Nombre:"
                           FontSize="16"
                           FontWeight="Bold"
                           Foreground="#374151"
                           VerticalAlignment="Center"/>

                <TextBox x:Name="txtCodigoProducto"
                         Grid.Column="1"
                         Height="38"
                         FontSize="18"
                         VerticalContentAlignment="Center"
                         Margin="0,0,10,0"
                         Padding="8,0"
                         BorderBrush="#CBD5E1"
                         KeyDown="txtCodigoProducto_KeyDown">
                    <TextBox.Template>
                        <ControlTemplate TargetType="TextBox">
                            <Border Background="White"
                                    BorderBrush="#CBD5E1"
                                    BorderThickness="1"
                                    CornerRadius="8">
                                <ScrollViewer x:Name="PART_ContentHost"
                                              Margin="8,0"/>
                            </Border>
                        </ControlTemplate>
                    </TextBox.Template>
                </TextBox>

                <TextBlock x:Name="txtNombreProductoActual"
                           Grid.Column="2"
                           Text=""
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="#2563EB"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"
                           TextTrimming="CharacterEllipsis"/>

                <Border Grid.Column="3"
                        Background="White"
                        BorderBrush="#CBD5E1"
                        BorderThickness="1"
                        CornerRadius="8"
                        Margin="0,8,10,8">

                    <Image x:Name="imgProductoActual"
                           Stretch="Uniform"
                           Margin="4"
                           Height="70"
                           Width="70"/>

                </Border>

                <Button Grid.Column="4"
                        Content="📷 Lector Barras"
                        Height="38"
                        FontSize="13"
                        FontWeight="Bold"
                        Background="#EFF6FF"
                        Foreground="#2563EB"
                        BorderThickness="1"
                        BorderBrush="#BFDBFE"
                        Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="b"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="b"
                                            Property="Background"
                                            Value="#DBEAFE"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

            </Grid>

        </Border>

        <!-- ========================================= -->
        <!-- CONTENIDO PRINCIPAL                       -->
        <!-- ========================================= -->

        <Grid Grid.Row="2">

            <Grid.ColumnDefinitions>
                <!-- MENÚ LATERAL -->
                <ColumnDefinition Width="100"/>
                <!-- ÁREA CENTRAL -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ===================================== -->
            <!-- MENÚ LATERAL                          -->
            <!-- ===================================== -->

            <Border Background="White"
                    BorderBrush="#E2E8F0"
                    BorderThickness="0,0,1,0">

                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="10,36,-10,-36">

                    <StackPanel Margin="5,8">

                        <Button x:Name="btnLateralBuscar"
                                Style="{StaticResource BtnLateral}"
                                Click="BtnBuscar_Click">
                            <StackPanel>
                                <TextBlock Text="🔍"
                                           FontSize="20"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Buscar"
                                           FontSize="11"
                                           FontWeight="Bold"
                                           Foreground="#374151"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="F2"
                                           FontSize="9"
                                           Foreground="#94A3B8"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="btnLateralEspera"
                                Style="{StaticResource BtnLateral}"
                                Click="BtnEspera_Click">
                            <Grid>
                                <StackPanel>
                                    <TextBlock Text="⏸️"
                                               FontSize="20"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="En espera"
                                               FontSize="10"
                                               FontWeight="Bold"
                                               Foreground="#374151"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="F4"
                                               FontSize="9"
                                               Foreground="#94A3B8"
                       HorizontalAlignment="Center"/>
                                </StackPanel>

                                <Border x:Name="badgeEspera"
                                        Background="#DC2626"
                                        CornerRadius="9"
                                        Width="18"
                                        Height="18"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Top"
                                        Margin="0,-4,4,0"
                                        Visibility="Collapsed">
                                    <TextBlock x:Name="txtBadgeEspera"
                                               Text="0"
                                               FontSize="10"
                                               FontWeight="Bold"
                                               Foreground="White"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </Button>

                        <Button x:Name="btnLateralPrecio"
                                Style="{StaticResource BtnLateral}"
                                Click="BtnPrecio_Click">
                            <StackPanel>
                                <TextBlock Text="💲"
                                           FontSize="20"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Precio"
                                           FontSize="11"
                                           FontWeight="Bold"
                                           Foreground="#374151"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="F3"
                                           FontSize="9"
                                           Foreground="#94A3B8"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="btnLateralCantidad"
                                Style="{StaticResource BtnLateral}"
                                Click="BtnCantidad_Click">
                            <StackPanel>
                                <TextBlock Text="🔢"
                                           FontSize="20"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Cantidad"
                                           FontSize="11"
                                           FontWeight="Bold"
                                           Foreground="#374151"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="F5"
                                           FontSize="9"
                                           Foreground="#94A3B8"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="btnLateralEliminar"
                                Style="{StaticResource BtnLateral}"
                                Click="BtnEliminar_Click">
                            <StackPanel>
                                <TextBlock Text="🗑️"
                                           FontSize="20"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Remover"
                                           FontSize="11"
                                           FontWeight="Bold"
                                           Foreground="#374151"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="F6"
                                           FontSize="9"
                                           Foreground="#94A3B8"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="btnLateralDescuento"
                                Style="{StaticResource BtnLateral}"
                                Click="BtnDescuento_Click">
                            <StackPanel>
                                <TextBlock Text="🏷️"
                                           FontSize="20"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Desc."
                                           FontSize="11"
                                           FontWeight="Bold"
                                           Foreground="#374151"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="F7"
                                           FontSize="9"
                                           Foreground="#94A3B8"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Rectangle Height="1"
                                   Fill="#E2E8F0"
                                   Margin="10,6"/>
                        
                        

                        <Button x:Name="btnLateralCajon"
                                Style="{StaticResource BtnLateral}">
                            <StackPanel>
                                <TextBlock Text="🗄️"
                                           FontSize="20"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Cajón"
                                           FontSize="11"
                                           FontWeight="Bold"
                                           Foreground="#374151"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="F8"
                                           FontSize="9"
                                           Foreground="#94A3B8"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="btnLateralBascula"
                                Style="{StaticResource BtnLateral}">
                            <StackPanel>
                                <TextBlock Text="⚖️"
                                           FontSize="20"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Báscula"
                                           FontSize="11"
                                           FontWeight="Bold"
                                           Foreground="#374151"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="F9"
                                           FontSize="9"
                                           Foreground="#94A3B8"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="btnLateralImporte"
                                Style="{StaticResource BtnLateral}">
                            <StackPanel>
                                <TextBlock Text="💵"
                                           FontSize="20"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Importe"
                                           FontSize="11"
                                           FontWeight="Bold"
                                           Foreground="#374151"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="F10"
                                           FontSize="9"
                                           Foreground="#94A3B8"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Rectangle Height="1"
                                   Fill="#E2E8F0"
                                   Margin="10,6"/>

                        <Button x:Name="btnLateralCliente"
                                Style="{StaticResource BtnLateral}">
                            <StackPanel>
                                <TextBlock Text="👤"
                                           FontSize="20"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Cliente"
                                           FontSize="11"
                                           FontWeight="Bold"
                                           Foreground="#374151"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="btnLateralCotizar"
                                Style="{StaticResource BtnLateral}">
                            <StackPanel>
                                <TextBlock Text="📋"
                                           FontSize="20"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Cotizar"
                                           FontSize="11"
                                           FontWeight="Bold"
                                           Foreground="#374151"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                    </StackPanel>

                </ScrollViewer>

            </Border>

            <!-- ===================================== -->
            <!-- ÁREA CENTRAL — dividida en 2 columnas -->
            <!-- Izquierda: Carrito | Derecha: Productos + Categorías -->
            <!-- ===================================== -->

            <Grid Grid.Column="1">

                <Grid.ColumnDefinitions>
                    <!-- CARRITO -->
                    <ColumnDefinition Width="*"/>
                    <!-- CATÁLOGO -->
                    <ColumnDefinition Width="420"/>
                </Grid.ColumnDefinitions>

                <!-- ===================================== -->
                <!-- CARRITO DE VENTA                      -->
                <!-- ===================================== -->

                <Grid Margin="8,8,4,8">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="45"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="55"/>
                    </Grid.RowDefinitions>

                    <!-- TÍTULO TICKET -->
                    <Border Background="#1693E0"
                            CornerRadius="10,10,0,0">

                        <Grid Margin="15,0">

                            <TextBlock Text="🧾  VENTA "
                                       Foreground="White"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"/>

                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center">

                                

                            </StackPanel>

                        </Grid>

                    </Border>

                    <!-- TABLA CARRITO -->
                    <Border Grid.Row="1"
                            Background="White"
                            BorderBrush="#E2E8F0"
                            BorderThickness="1,0,1,0">

                        <DataGrid x:Name="dgCarritoCentral"
                                  AutoGenerateColumns="False"
                                  HeadersVisibility="Column"
                                  CanUserAddRows="False"
                                  IsReadOnly="True"
                                  FontSize="14"
                                  RowHeight="38"
                                  BorderThickness="0"
                                  GridLinesVisibility="Horizontal"
                                  HorizontalGridLinesBrush="#F1F5F9"
                                  SelectionMode="Single"
                                  SelectionUnit="FullRow"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  SelectionChanged="dgCarritoCentral_SelectionChanged_1">

                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#F8FAFC"/>
                                    <Setter Property="Foreground" Value="#64748B"/>
                                    <Setter Property="FontSize" Value="12"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="Padding" Value="10,8"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>

                            <DataGrid.Columns>

                                <DataGridTextColumn Header="Cant."
                                    Binding="{Binding Cantidad}"
                                    Width="65"/>

                                <DataGridTextColumn Header="Descripción"
                                    Binding="{Binding Nombre}"
                                    Width="*"/>

                                <DataGridTextColumn Header="Stock"
                                    Binding="{Binding Stock}"
                                    Width="70"/>

                                <DataGridTextColumn Header="Desc."
                                    Binding="{Binding Descuento}"
                                    Width="80"/>

                                <DataGridTextColumn Header="Precio"
                                    Binding="{Binding Precio}"
                                    Width="100"/>

                                <DataGridTextColumn Header="Importe"
                                    Binding="{Binding Subtotal}"
                                    Width="110"/>

                            </DataGrid.Columns>

                        </DataGrid>

                    </Border>

                    <!-- ACCIONES ADICIONALES -->
                    <Border Grid.Row="2"
                            Background="#F8FAFC"
                            BorderBrush="#E2E8F0"
                            BorderThickness="1,1,1,1"
                            CornerRadius="0,0,10,10">

                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Margin="10,0">

                            <Button Content="↩ Cambiar"
                                    Style="{StaticResource BtnAccion}"
                                    Width="110"
                                    Height="36"
                                    Margin="4,0"/>

                            <Button Content="↩ Devolución"
                                    Style="{StaticResource BtnAccion}"
                                    Width="120"
                                    Height="36"
                                    Margin="4,0"/>

                            <Button x:Name="btnPagar"
                                    Content="🖨️ Ticket"
                                    Style="{StaticResource BtnAccion}"
                                    Width="110"
                                    Height="36"
                                    Margin="4,0"
                                    Click="BtnPagar_Click"/>

                        </StackPanel>

                    </Border>

                </Grid>

                <!-- ===================================== -->
                <!-- CATÁLOGO: CATEGORÍAS + PRODUCTOS CARDS -->
                <!-- ===================================== -->

                <Border Grid.Column="1"
                        Background="#F8FAFC"
                        BorderBrush="#E2E8F0"
                        BorderThickness="1,0,0,0"
                        Margin="4,8,8,8">

                    <Grid>

                        <Grid.RowDefinitions>
                            <!-- BARRA CATEGORÍAS -->
                            <RowDefinition Height="65"/>
                            <!-- GRID PRODUCTOS -->
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- ===================================== -->
                        <!-- ✅ BARRA DE CATEGORÍAS                -->
                        <!-- ===================================== -->

                        <Border Background="White"
                                BorderBrush="#E2E8F0"
                                BorderThickness="0,0,0,1"
                                CornerRadius="10,10,0,0">

                            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Disabled"
                                          VerticalAlignment="Center"
                                          Margin="8,0"
                                          Padding="0,0,0,4">

                                <ScrollViewer.Resources>
                                    <Style TargetType="ScrollBar"
                                           BasedOn="{StaticResource ScrollBarCategorias}"/>
                                </ScrollViewer.Resources>

                                <StackPanel x:Name="pnlCategorias"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center">

                                    <!-- Los botones de categoría se generan dinámicamente desde el .cs -->

                                </StackPanel>

                            </ScrollViewer>

                        </Border>

                        <!-- ===================================== -->
                        <!-- ✅ GRID DE TARJETAS DE PRODUCTOS       -->
                        <!-- ===================================== -->

                        <ScrollViewer Grid.Row="1"
                                      VerticalScrollBarVisibility="Auto">

                            <ItemsControl x:Name="icProductosCatalogo">

                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal"
                                                   Margin="8"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>

                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                      
                                        <!-- TARJETA DE PRODUCTO -->
                                        <Border Width="120"
                                                Height="145"
                                                Margin="5"
                                                Background="White"
                                                BorderBrush="#E2E8F0"
                                                BorderThickness="1"
                                                CornerRadius="12"
                                                Cursor="Hand"
                                                MouseLeftButtonUp="CardProducto_MouseLeftButtonUp">

                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="BorderBrush" Value="#2563EB"/>
                                                            <Setter Property="Effect">
                                                                <Setter.Value>
                                                                    <DropShadowEffect Color="#2563EB"
                                                                                      Opacity="0.15"
                                                                                      BlurRadius="8"
                                                                                      ShadowDepth="2"/>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>

                                            <Grid>

                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="75"/>
                                                    <RowDefinition Height="*"/>
                                                </Grid.RowDefinitions>

                                                <!-- IMAGEN -->
                                                <Border Background="#F1F5F9"
                                                        CornerRadius="12,12,0,0">

                                                    <Image Source="{Binding ImagenURL}"
                                                           Stretch="Uniform"
                                                           Margin="8"/>

                                                </Border>

                                                <!-- INFO -->
                                                <StackPanel Grid.Row="1"
                                                            Margin="8,4">

                                                    <TextBlock Text="{Binding Nombre}"
                                                               FontSize="11"
                                                               FontWeight="Bold"
                                                               Foreground="#1E293B"
                                                               TextWrapping="Wrap"
                                                               MaxHeight="30"
                                                               TextTrimming="CharacterEllipsis"/>

                                                    <TextBlock Text="{Binding PrecioVenta, StringFormat=C}"
                                                               FontSize="13"
                                                               FontWeight="Bold"
                                                               Foreground="#2563EB"
                                                               Margin="0,3,0,0"/>

                                                    <TextBlock Text="{Binding Stock, StringFormat='Stock: {0}'}"
                                                               FontSize="10"
                                                               Foreground="#94A3B8"/>

                                                </StackPanel>

                                            </Grid>

                                        </Border>

                                    </DataTemplate>

                                </ItemsControl.ItemTemplate>

                            </ItemsControl>

                        </ScrollViewer>

                    </Grid>

                </Border>

            </Grid>

        </Grid>

        <!-- ========================================= -->
        <!-- TOTAL + COBRAR                            -->
        <!-- ========================================= -->

        <Grid Grid.Row="3"
              Margin="8,0">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="280"/>
            </Grid.ColumnDefinitions>

            <!-- ESPACIO LATERAL -->
            <Border/>

            <!-- TOTAL -->
            <Border Grid.Column="1"
                    Background="White"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1"
                    CornerRadius="12"
                    Margin="4,8">

                <Grid Margin="20,0">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="TOTAL"
                                   FontSize="11"
                                   Foreground="#94A3B8"
                                   FontWeight="Bold"/>
                        <TextBlock x:Name="txtTotalCentral"
                                   Text="$0.00"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="#1E3A8A"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                VerticalAlignment="Center">
                        <TextBlock Text="PAGO"
                                   FontSize="11"
                                   Foreground="#94A3B8"
                                   FontWeight="Bold"/>
                        <TextBlock x:Name="txtFooterPago"
                                   Text="$0.00"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="#374151"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2"
                                VerticalAlignment="Center">
                        <TextBlock Text="CAMBIO"
                                   FontSize="11"
                                   Foreground="#94A3B8"
                                   FontWeight="Bold"/>
                        <TextBlock x:Name="txtFooterCambio"
                                   Text="$0.00"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="#16A34A"/>
                    </StackPanel>

                </Grid>

            </Border>

            <!-- COBRAR -->
            <Button Grid.Column="2"
                    Content="💳  COBRAR"
                    Style="{StaticResource BtnCobrar}"
                    Margin="4,8"
                    Click="BtnCobrarCentral_Click"/>

        </Grid>

        <!-- ========================================= -->
        <!-- FOOTER                                    -->
        <!-- ========================================= -->

        <Border Grid.Row="4"
                Background="#1693E0">

            <Grid Margin="20,0">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="txtFooterTotal"
                           Text="Total: $0.00"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="White"
                           VerticalAlignment="Center"/>

                <TextBlock x:Name="txtFechaHora"
                           Grid.Column="1"
                           Text=""
                           FontSize="16"
                           Foreground="#93C5FD"
                           VerticalAlignment="Center"/>

            </Grid>

        </Border>

    </Grid>

</Window>