<Window x:Class="FarmaciaPOS.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sistema de Ventas"
        Height="750"
        Width="1250"
        Icon="/logo-icono.ico"
        WindowStartupLocation="CenterScreen"
        Background="#E9ECEF"
        PreviewKeyDown="DashboardWindow_PreviewKeyDown">

    <Grid>

        <Grid.RowDefinitions>
            <!-- HEADER -->
            <RowDefinition Height="90"/>

            <!-- MENU SUPERIOR -->
            <RowDefinition Height="70"/>

            <!-- CONTENIDO PRINCIPAL -->
            <RowDefinition Height="*"/>

            <!-- BOTONES INFERIORES -->
            <RowDefinition Height="120"/>

            <!-- FOOTER -->
            <RowDefinition Height="80"/>
        </Grid.RowDefinitions>

        <!-- ========================================= -->
        <!-- HEADER -->
        <!-- ========================================= -->

        <Border Background="White"
                Grid.Row="0"
                BorderBrush="#D6D6D6"
                BorderThickness="0,0,0,1">

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="400"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="300"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="20,0">

                    <Image Source="/Images/logo-click.png"
                           Width="100"
                           Height="70"/>

                    <StackPanel Margin="10,0">

                        <TextBlock Text="FarmaClick Yatzil"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="#1E3A8A"/>

                        <TextBlock Text="Tu sistema de ventas de confianza"
                                   FontSize="14"
                                   Foreground="Gray"/>

                    </StackPanel>

                </StackPanel>

                

                <!-- USUARIO -->

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right"
                            Margin="0,0,20,0">

                    <StackPanel Margin="0,0,20,0"
                                VerticalAlignment="Center">

                        <TextBlock x:Name="txtUsuarioSesion"
                                   Text="Usuario"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Right"/>

                        <TextBlock Text="Caja Principal"
                                   FontSize="14"
                                   Foreground="Gray"
                                   HorizontalAlignment="Right"/>

                    </StackPanel>

                    <Button Content="Salir"
                            Width="100"
                            Height="40"
                            FontSize="16"
                            Background="#DC2626"
                            Foreground="White"
                            FontWeight="Bold"
                            Click="BtnSalir_Click"/>

                </StackPanel>

            </Grid>

        </Border>

        <!-- ========================================= -->
        <!-- MENU SUPERIOR -->
        <!-- ========================================= -->

        <Border Grid.Row="1"
                Background="#F8FAFC"
                BorderBrush="#D6D6D6"
                BorderThickness="0,0,0,1">

            <ScrollViewer HorizontalScrollBarVisibility="Hidden">

                <StackPanel Orientation="Horizontal"
                            Margin="10">

                    <Button x:Name="btnVentas"
                            Content="Ventas"
                            Width="160"
                            Height="45"
                            Margin="5"
                            Click="BtnVentas_Click"/>

                    <Button x:Name="btnPedidos"
                            Content="Pedidos"
                            Width="160"
                            Height="45"
                            Margin="5"
                            Click="BtnPedidos_Click"/>

                    <Button x:Name="btnProductos"
                            Content="Productos"
                            Width="160"
                            Height="45"
                            Margin="5"
                            Click="BtnProductos_Click"/>

                    <Button x:Name="btnInventario"
                            Content="Inventario"
                            Width="160"
                            Height="45"
                            Margin="5"
                            Click="BtnInventario_Click"/>

                    <Button Content="Reportes"
                            Width="160"
                            Height="45"
                            Margin="5"
                            Click="BtnReportes_Click"/>

                    <Button x:Name="btnConfiguracion"
                            Content="Configuración"
                            Width="190"
                            Height="45"
                            Margin="5"
                            Click="BtnConfiguracion_Click"/>

                    <Button x:Name="btnCaja"
                            Content="Caja"
                            Width="160"
                            Height="45"
                            Margin="5"
                            Click="BtnCaja_Click"/>

                </StackPanel>

            </ScrollViewer>

        </Border>

        <!-- ========================================= -->
        <!-- CONTENIDO PRINCIPAL                      -->
        <!-- ✅ Dividido: Menú lateral | Área de venta -->
        <!-- ========================================= -->

        <Grid Grid.Row="2"
              Margin="-1">

            <Grid.ColumnDefinitions>
                <!-- MENÚ LATERAL -->
                <ColumnDefinition Width="110"/>
                <!-- ÁREA DE VENTA -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ===================================== -->
            <!-- ✅ MENÚ LATERAL IZQUIERDO (estilo SICAR) -->
            <!-- ===================================== -->

            <Border Grid.Column="0"
                    Background="White"
                    BorderBrush="#D6D6D6"
                    BorderThickness="0,0,1,0">

                <ScrollViewer VerticalScrollBarVisibility="Auto">

                    <StackPanel Margin="5,10">

                        <Button x:Name="btnLateralBuscar"
                                Width="95"
                                Height="70"
                                Margin="3"
                                Background="Transparent"
                                BorderThickness="0"
                                Click="BtnBuscar_Click">
                            <StackPanel>
                                <TextBlock Text="🔍"
                                           FontSize="22"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Buscar"
                                           FontSize="12"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           TextWrapping="Wrap"
                                           TextAlignment="Center"/>
                                <TextBlock Text="(F2)"
                                           FontSize="10"
                                           Foreground="Gray"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="btnLateralPrecio"
                                Width="95"
                                Height="70"
                                Margin="3"
                                Background="Transparent"
                                BorderThickness="0"
                                Click="BtnPrecio_Click">
                            <StackPanel>
                                <TextBlock Text="💲"
                                           FontSize="22"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Precio"
                                           FontSize="12"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="(F3)"
                                           FontSize="10"
                                           Foreground="Gray"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="btnLateralCantidad"
                                Width="95"
                                Height="70"
                                Margin="3"
                                Background="Transparent"
                                BorderThickness="0"
                                Click="BtnCantidad_Click">
                            <StackPanel>
                                <TextBlock Text="🔢"
                                           FontSize="22"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Cantidad"
                                           FontSize="12"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="(F5)"
                                           FontSize="10"
                                           Foreground="Gray"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="btnLateralEliminar"
                                Width="95"
                                Height="70"
                                Margin="3"
                                Background="Transparent"
                                BorderThickness="0"
                                Click="BtnEliminar_Click">
                            <StackPanel>
                                <TextBlock Text="⛔"
                                           FontSize="22"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Remover"
                                           FontSize="12"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="(F6)"
                                           FontSize="10"
                                           Foreground="Gray"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="btnLateralDescuento"
                                Width="95"
                                Height="70"
                                Margin="3"
                                Background="Transparent"
                                BorderThickness="0"
                                Click="BtnDescuento_Click">
                            <StackPanel>
                                <TextBlock Text="🏷️"
                                           FontSize="22"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Desc."
                                           FontSize="12"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="(F7)"
                                           FontSize="10"
                                           Foreground="Gray"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Separator Margin="5,8"/>

                        <Button x:Name="btnLateralCajon"
                                Width="95"
                                Height="70"
                                Margin="3"
                                Background="Transparent"
                                BorderThickness="0">
                            <StackPanel>
                                <TextBlock Text="🗄️"
                                           FontSize="22"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Cajón"
                                           FontSize="12"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="(F8)"
                                           FontSize="10"
                                           Foreground="Gray"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="btnLateralBascula"
                                Width="95"
                                Height="70"
                                Margin="3"
                                Background="Transparent"
                                BorderThickness="0">
                            <StackPanel>
                                <TextBlock Text="⚖️"
                                           FontSize="22"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Báscula"
                                           FontSize="12"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="(F9)"
                                           FontSize="10"
                                           Foreground="Gray"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="btnLateralImporte"
                                Width="95"
                                Height="70"
                                Margin="3"
                                Background="Transparent"
                                BorderThickness="0">
                            <StackPanel>
                                <TextBlock Text="💵"
                                           FontSize="22"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Importe"
                                           FontSize="12"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="(F10)"
                                           FontSize="10"
                                           Foreground="Gray"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Separator Margin="5,8"/>

                        <Button x:Name="btnLateralCliente"
                                Width="95"
                                Height="70"
                                Margin="3"
                                Background="Transparent"
                                BorderThickness="0">
                            <StackPanel>
                                <TextBlock Text="👤"
                                           FontSize="22"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Cliente"
                                           FontSize="12"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="btnLateralCotizar"
                                Width="95"
                                Height="70"
                                Margin="3"
                                Background="Transparent"
                                BorderThickness="0">
                            <StackPanel>
                                <TextBlock Text="📋"
                                           FontSize="22"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Cotizar"
                                           FontSize="12"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                    </StackPanel>

                </ScrollViewer>

            </Border>

            <!-- ===================================== -->
            <!-- ÁREA DE VENTA                         -->
            <!-- ===================================== -->

            <Grid Grid.Column="1"
                  Margin="0">

                <Grid.RowDefinitions>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="120"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Background="#2563EB"
                        CornerRadius="5"
                        Margin="5">

                    <TextBlock Text="VENTA - Ticket 1"
                               Foreground="White"
                               FontSize="28"
                               FontWeight="Bold"
                               VerticalAlignment="Center"
                               Margin="20,0"/>

                </Border>

                <!-- ===================================== -->
                <!-- ✅ CÓDIGO + IMAGEN DEL PRODUCTO        -->
                <!-- ===================================== -->

                <Grid Grid.Row="1"
                      Margin="5,5,5,0">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- IMAGEN PRODUCTO -->

                    <Border Background="White"
                            BorderBrush="#D6D6D6"
                            BorderThickness="1"
                            CornerRadius="6">

                        <Image x:Name="imgProductoActual"
                               Width="90"
                               Height="90"
                               Stretch="Uniform"/>

                    </Border>

                    <!-- CÓDIGO + BOTONES -->

                    <Grid Grid.Column="1"
                          Margin="10,0,0,0">

                        <Grid.RowDefinitions>
                            <RowDefinition Height="50"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="250"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Código del Producto:"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"/>

                            <TextBox x:Name="txtCodigoProducto"
                                     Grid.Column="1"
                                     Height="45"
                                     FontSize="22"
                                     Margin="10,0"
                                     KeyDown="txtCodigoProducto_KeyDown"/>

                            <Button Grid.Column="2"
                                    Content="F3"
                                    Height="45"
                                    Margin="10,0"/>

                            <Button Grid.Column="3"
                                    Content="Lector Código Barras"
                                    Height="45"
                                    Margin="10,0"/>

                        </Grid>

                        <!-- NOMBRE PRODUCTO ESCANEADO -->

                        <TextBlock x:Name="txtNombreProductoActual"
                                   Grid.Row="1"
                                   Text=""
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="#1E3A8A"
                                   VerticalAlignment="Center"/>

                    </Grid>

                </Grid>

                <!-- ===================================== -->
                <!-- TABLA DE PRODUCTOS                    -->
                <!-- ===================================== -->

                <Border Grid.Row="2"
                        Margin="5,10,5,5"
                        Background="White"
                        BorderBrush="#D6D6D6"
                        BorderThickness="1">

                    <DataGrid x:Name="dgCarritoCentral"
                              AutoGenerateColumns="False"
                              HeadersVisibility="Column"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              FontSize="18"
                              Margin="10"
                              RowHeight="45"
                              SelectionMode="Single"
                              SelectionUnit="FullRow"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                              MinHeight="300"
                              SelectionChanged="dgCarritoCentral_SelectionChanged_1">

                        <DataGrid.Columns>

                            <DataGridTextColumn Header="Cant."
                                Binding="{Binding Cantidad}"
                                Width="100"/>

                            <DataGridTextColumn Header="Descripción"
                                Binding="{Binding Nombre}"
                                Width="*"/>

                            <DataGridTextColumn Header="Stock"
                                Binding="{Binding Stock }"
                                Width="90"/>

                            <DataGridTextColumn Header=" Desc"
                                Binding="{Binding Descuento}"
                                Width="100"/>

                            <DataGridTextColumn Header="Precio U."
                                Binding="{Binding Precio}"
                                Width="120"/>

                            <DataGridTextColumn Header="Importe"
                                Binding="{Binding Subtotal}"
                                Width="140"/>

                        </DataGrid.Columns>

                    </DataGrid>

                </Border>

            </Grid>

        </Grid>

        <!-- ========================================= -->
        <!-- TOTAL                                     -->
        <!-- ========================================= -->

        <Grid Grid.Row="3"
              Height="90"
              Margin="10">

            <Grid.ColumnDefinitions>

                <!-- BOTONES -->
                <ColumnDefinition Width="500"/>

                <!-- TOTAL -->
                <ColumnDefinition Width="400"/>

            </Grid.ColumnDefinitions>

            <!-- ================================= -->
            <!-- BOTONES -->
            <!-- ================================= -->

            <UniformGrid Grid.Column="0"
                 Columns="4"
                 Margin="0,0,10,0">

                <Button Content="Cambiar"
                        Margin="4"
                        FontSize="15"
                        Height="50"/>

                <Button Content="Devolución"
                        Margin="4"
                        FontSize="15"
                        Height="50"/>

                <Button Content="Ticket"
                        Margin="4"
                        FontSize="15"
                        Height="50"/>

                <Button Content="COBRAR"
                        Margin="4"
                        FontSize="22"
                        FontWeight="Bold"
                        Height="50"
                        Background="#2563EB"
                        Foreground="White"
                        Click="BtnCobrarCentral_Click"/>

            </UniformGrid>

            <!-- ================================= -->
            <!-- TOTAL -->
            <!-- ================================= -->

            <Border Grid.Column="2"
                    Background="White"
                    BorderBrush="#D6D6D6"
                    BorderThickness="1"
                    CornerRadius="20">

                <StackPanel VerticalAlignment="Center"
                            HorizontalAlignment="Center">

                    <TextBlock Text="TOTAL"
                               FontSize="14"
                               Foreground="Gray"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"/>

                    <TextBlock x:Name="txtTotalCentral"
                               Text="$0.00"
                               FontSize="28"
                               Foreground="#1D4ED8"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"/>

                </StackPanel>

            </Border>

        </Grid>

        <!-- ========================================= -->
        <!-- FOOTER -->
        <!-- ========================================= -->

        <Border Grid.Row="4"
                Background="White"
                BorderBrush="#D6D6D6"
                BorderThickness="1,1,1,0">

            <Grid Margin="20">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="250"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal">

                    <TextBlock x:Name="txtFooterTotal"
                               Text="Total: $0.00"
                               FontSize="24"
                               FontWeight="Bold"
                               Margin="20,0"/>

                    <TextBlock x:Name="txtFooterPago"
                               Text="Pago: $0.00"
                               FontSize="24"
                               FontWeight="Bold"
                               Margin="20,0"/>

                    <TextBlock x:Name="txtFooterCambio"
                               Text="Cambio: $0.00"
                               FontSize="24"
                               FontWeight="Bold"
                               Margin="20,0"/>

                </StackPanel>

                <TextBlock x:Name="txtFechaHora"
                           Grid.Column="1"
                           Text=""
                           FontSize="20"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"/>

            </Grid>

        </Border>

    </Grid>

</Window>