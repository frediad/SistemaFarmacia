<Window x:Class="FarmaciaPOS.Views.Cobrar"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cobrar Venta"
        Height="680"
        Width="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F0F4F8">

    <Window.Resources>

        <Style x:Key="BtnConfirmarCobro" TargetType="Button">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1D4ED8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1E40AF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TxtMontoCobro" TargetType="TextBox">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="Foreground" Value="#1E293B"/>
            <Setter Property="CaretBrush" Value="#2563EB"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#2563EB"/>
                                <Setter TargetName="border" Property="Background" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Border Background="White" CornerRadius="16" Margin="14">

        <Border.Effect>
            <DropShadowEffect Color="#000000" Opacity="0.15" BlurRadius="24" ShadowDepth="4"/>
        </Border.Effect>

        <Border.Clip>
            <RectangleGeometry Rect="0,0,452,652" RadiusX="16" RadiusY="16"/>
        </Border.Clip>

        <Grid>

            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Border Background="#1693E0">
                <TextBlock Text="💳  Cobrar Venta"
                           Foreground="White"
                           FontSize="18"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           Margin="20,0"/>
            </Border>

            <!-- RESUMEN DE PRODUCTOS -->
            <DataGrid Grid.Row="1"
                      x:Name="dgResumenCobro"
                      AutoGenerateColumns="False"
                      HeadersVisibility="Column"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      FontSize="13"
                      RowHeight="34"
                      BorderThickness="0"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#F1F5F9"
                      Margin="15,15,15,0">

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#F8FAFC"/>
                        <Setter Property="Foreground" Value="#64748B"/>
                        <Setter Property="FontSize" Value="11"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="Padding" Value="8,6"/>
                        <Setter Property="BorderThickness" Value="0"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Cant." Binding="{Binding Cantidad}" Width="50"/>
                    <DataGridTextColumn Header="Producto" Binding="{Binding Nombre}" Width="*"/>
                    <DataGridTextColumn Header="Importe" Binding="{Binding Subtotal, StringFormat=C}" Width="90"/>
                </DataGrid.Columns>

            </DataGrid>

            <!-- TOTALES + PAGO -->
            <StackPanel Grid.Row="2" Margin="20,10,20,20">

                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="SUBTOTAL" FontSize="10" FontWeight="Bold" Foreground="#94A3B8"/>
                        <TextBlock x:Name="txtSubtotalCobro" Text="$0.00" FontSize="14" FontWeight="Bold" Foreground="#374151"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                        <TextBlock Text="IVA" FontSize="10" FontWeight="Bold" Foreground="#94A3B8" HorizontalAlignment="Right"/>
                        <TextBlock x:Name="txtIvaCobro" Text="$0.00" FontSize="14" FontWeight="Bold" Foreground="#374151" HorizontalAlignment="Right"/>
                    </StackPanel>
                </Grid>

                <Border Background="#EFF6FF" CornerRadius="10" Padding="14,10" Margin="0,0,0,14">
                    <Grid>
                        <TextBlock Text="TOTAL" FontSize="13" FontWeight="Bold" Foreground="#1E3A8A" VerticalAlignment="Center"/>
                        <TextBlock x:Name="txtTotalCobro" Text="$0.00" FontSize="26" FontWeight="Bold" Foreground="#1E3A8A" HorizontalAlignment="Right"/>
                    </Grid>
                </Border>

                <TextBlock Text="MONTO RECIBIDO" FontSize="11" FontWeight="Bold" Foreground="#94A3B8" Margin="2,0,0,6"/>
                <TextBox x:Name="txtMontoRecibido"
                         Height="52"
                         Style="{StaticResource TxtMontoCobro}"
                         Margin="0,0,0,14"
                         TextChanged="txtMontoRecibido_TextChanged"/>

                <Border Background="#F0FDF4" CornerRadius="10" Padding="14,10" Margin="0,0,0,18">
                    <Grid>
                        <TextBlock Text="CAMBIO" FontSize="13" FontWeight="Bold" Foreground="#166534" VerticalAlignment="Center"/>
                        <TextBlock x:Name="txtCambioCobro" Text="$0.00" FontSize="22" FontWeight="Bold" Foreground="#16A34A" HorizontalAlignment="Right"/>
                    </Grid>
                </Border>

                <Button Content="Confirmar Venta"
                        Height="52"
                        Style="{StaticResource BtnConfirmarCobro}"
                        Margin="0,0,0,8"
                        Click="BtnConfirmarCobro_Click"/>

                <Button Content="Cancelar"
                        Height="38"
                        Background="Transparent"
                        Foreground="#64748B"
                        FontSize="13"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="BtnCancelarCobro_Click"/>

            </StackPanel>

        </Grid>

    </Border>

</Window>