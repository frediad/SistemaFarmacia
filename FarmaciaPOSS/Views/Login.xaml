<Window x:Class="FarmaciaPOS.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Iniciar Sesión"
        Height="520"
        Width="950"
        Icon="/logo-icono.ico"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F0F4F8"
        PreviewKeyDown="Login_PreviewKeyDown">




<Window.Resources>

        <!-- ===================================== -->
        <!-- ESTILO CAMPOS DE TEXTO                -->
        <!-- ===================================== -->

        <Style x:Key="TxtLogin" TargetType="TextBox">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="Foreground" Value="#1E293B"/>
            <Setter Property="CaretBrush" Value="#2563EB"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#2563EB"/>
                                <Setter TargetName="border" Property="Background" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#93C5FD"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===================================== -->
        <!-- ESTILO CONTRASEÑA                     -->
        <!-- ===================================== -->

        <Style x:Key="PwdLogin" TargetType="PasswordBox">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="Foreground" Value="#1E293B"/>
            <Setter Property="CaretBrush" Value="#2563EB"/>
            <Setter Property="PasswordChar" Value="●"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#2563EB"/>
                                <Setter TargetName="border" Property="Background" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#93C5FD"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===================================== -->
        <!-- ESTILO BOTÓN INICIAR SESIÓN           -->
        <!-- ===================================== -->

        <Style x:Key="BtnLoginPrincipal" TargetType="Button">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1D4ED8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1E40AF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Border Background="White"
            CornerRadius="18"
            Margin="18">

        <Border.Effect>
            <DropShadowEffect Color="#000000"
                              Opacity="0.12"
                              BlurRadius="30"
                              ShadowDepth="6"/>
        </Border.Effect>

        <Border.Clip>
            <RectangleGeometry Rect="0,0,914,484" RadiusX="18" RadiusY="18"/>
        </Border.Clip>

        <Grid>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>
            
            

            <!-- ===================================== -->
            <!-- PANEL IZQUIERDO — MARCA               -->
            <!-- ===================================== -->

            <Border>

                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#1E3A8A" Offset="0"/>
                        <GradientStop Color="#1E40AF" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>

                <Grid>

                    <!-- Decoración: círculos translúcidos -->
                    <Ellipse Width="220" Height="220"
                             Fill="#FFFFFF"
                             Opacity="0.05"
                             HorizontalAlignment="Right"
                             VerticalAlignment="Top"
                             Margin="0,-80,-90,0"/>

                    <Ellipse Width="160" Height="160"
                             Fill="#FFFFFF"
                             Opacity="0.06"
                             HorizontalAlignment="Left"
                             VerticalAlignment="Bottom"
                             Margin="-60,0,0,-60"/>

                    <StackPanel VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                Margin="30">

                        <Border Background="White"
                                CornerRadius="20"
                                Width="140"
                                Height="140"
                                HorizontalAlignment="Center">

                            <Border.Effect>
                                <DropShadowEffect Color="#000000"
                                                  Opacity="0.15"
                                                  BlurRadius="20"
                                                  ShadowDepth="4"/>
                            </Border.Effect>

                            <Image Source="/Images/logo-click.png"
                                   Width="100"
                                   Height="100"
                                   Stretch="Uniform"/>

                        </Border>

                        <TextBlock Text="FarmaClick Yatzil"
                                   Foreground="White"
                                   FontSize="30"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Margin="0,24,0,0"/>

                        <TextBlock Text="Tu sistema de ventas de confianza"
                                   Foreground="#93C5FD"
                                   FontSize="14"
                                   HorizontalAlignment="Center"
                                   Margin="0,6,0,0"/>

                    </StackPanel>

                    <TextBlock Text="© 2026 FarmaClick Yatzil — v1.0"
                               Foreground="#93C5FD"
                               FontSize="11"
                               Opacity="0.7"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Bottom"
                               Margin="0,0,0,18"/>

                </Grid>

            </Border>

            <!-- ===================================== -->
            <!-- PANEL DERECHO — FORMULARIO            -->
            <!-- ===================================== -->

            <Border Grid.Column="1" Background="White">

                <StackPanel Width="360"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">

                    <TextBlock Text="Bienvenido 👋"
                               FontSize="30"
                               FontWeight="Bold"
                               Foreground="#1E293B"/>

                    <TextBlock Text="Ingresa tus credenciales para continuar"
                               FontSize="13"
                               Foreground="#94A3B8"
                               Margin="0,4,0,28"/>

                    <!-- MENSAJE DE ERROR -->
                    <Border x:Name="borderError"
                            Background="#FEE2E2"
                            CornerRadius="8"
                            Padding="12,10"
                            Margin="0,0,0,16"
                            Visibility="Collapsed">

                        <TextBlock x:Name="txtError"
                                   Text="Usuario o contraseña incorrectos"
                                   Foreground="#DC2626"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"/>

                    </Border>

                    <TextBlock Text="USUARIO"
                               FontSize="11"
                               FontWeight="Bold"
                               Foreground="#94A3B8"
                               Margin="2,0,0,6"/>

                    <TextBox x:Name="txtUsuario"
                             Height="46"
                             Style="{StaticResource TxtLogin}"
                             Margin="0,0,0,20"/>

                    <TextBlock Text="CONTRASEÑA"
                               FontSize="11"
                               FontWeight="Bold"
                               Foreground="#94A3B8"
                               Margin="2,0,0,6"/>

                    <PasswordBox x:Name="txtPassword"
                                 Height="46"
                                 Style="{StaticResource PwdLogin}"
                                 Margin="0,0,0,30"/>

                    <Button Content="Iniciar Sesión"
                            Height="50"
                            Style="{StaticResource BtnLoginPrincipal}"
                            Click="BtnLogin_Click"/>

                    <TextBlock Text="Sistema de punto de venta farmacéutico"
                               FontSize="11"
                               Foreground="#CBD5E1"
                               HorizontalAlignment="Center"
                               Margin="0,26,0,0"/>

                </StackPanel>

            </Border>

        </Grid>
        
        
      </Border>

</Window>

  