<Window x:Class="FarmaciaPOS.Views.ClientesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Clientes"
        Height="750"
        Width="1250"
        Icon="/logo-icono.ico"
        WindowStartupLocation="CenterScreen"
        Background="#F0F4F8">

    <Window.Resources>

        <Style x:Key="TxtCliente" TargetType="TextBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#2563EB"/>
                                <Setter TargetName="border" Property="Background" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnAccionCliente" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ===================================== -->
        <!-- HEADER                                -->
        <!-- ===================================== -->

        <Border Background="#1E3A8A" Grid.Row="0">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="280"/>
                    <ColumnDefinition Width="110"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="👥  Clientes"
                           Foreground="White"
                           FontSize="22"
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>

                <Border Grid.Column="1"
                        Background="White"
                        CornerRadius="8"
                        Margin="10,0"
                        VerticalAlignment="Center">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="🔍"
                                   FontSize="16"
                                   Margin="10,0,5,0"
                                   VerticalAlignment="Center"/>

                        <TextBox x:Name="txtBuscarCliente"
                                 Grid.Column="1"
                                 Height="40"
                                 FontSize="14"
                                 BorderThickness="0"
                                 VerticalContentAlignment="Center"
                                 TextChanged="txtBuscarCliente_TextChanged">
                            <TextBox.Template>
                                <ControlTemplate TargetType="TextBox">
                                    <Border Background="Transparent">
                                        <ScrollViewer x:Name="PART_ContentHost" Margin="4,0"/>
                                    </Border>
                                </ControlTemplate>
                            </TextBox.Template>
                        </TextBox>

                    </Grid>

                </Border>

                <Button Grid.Column="2"
                        Content="✕ Cerrar"
                        Width="100"
                        Height="40"
                        FontSize="14"
                        FontWeight="Bold"
                        Background="#DC2626"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        VerticalAlignment="Center"
                        Click="BtnCerrarVentana_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <!-- ===================================== -->
        <!-- CONTENIDO                             -->
        <!-- ===================================== -->

        <Grid Grid.Row="1" Margin="15">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ===================================== -->
            <!-- FORMULARIO                            -->
            <!-- ===================================== -->

            <Border Grid.Column="0"
                    Background="White"
                    CornerRadius="12"
                    Padding="20"
                    Margin="0,0,15,0">

                <ScrollViewer VerticalScrollBarVisibility="Auto">

                    <StackPanel>

                        <TextBlock x:Name="txtTituloForm"
                                   Text="Nuevo Cliente"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="#1E293B"
                                   Margin="0,0,0,15"/>

                        <TextBlock Text="NOMBRE" FontSize="11" FontWeight="Bold" Foreground="#94A3B8" Margin="2,0,0,6"/>
                        <TextBox x:Name="txtNombre" Height="40" Style="{StaticResource TxtCliente}" Margin="0,0,0,14"/>

                        <TextBlock Text="TELÉFONO" FontSize="11" FontWeight="Bold" Foreground="#94A3B8" Margin="2,0,0,6"/>
                        <TextBox x:Name="txtTelefono" Height="40" Style="{StaticResource TxtCliente}" Margin="0,0,0,14"/>

                        <TextBlock Text="CORREO" FontSize="11" FontWeight="Bold" Foreground="#94A3B8" Margin="2,0,0,6"/>
                        <TextBox x:Name="txtCorreo" Height="40" Style="{StaticResource TxtCliente}" Margin="0,0,0,14"/>

                        <TextBlock Text="DIRECCIÓN" FontSize="11" FontWeight="Bold" Foreground="#94A3B8" Margin="2,0,0,6"/>
                        <TextBox x:Name="txtDireccion" Height="40" Style="{StaticResource TxtCliente}" Margin="0,0,0,14"/>

                        <TextBlock Text="RFC (OPCIONAL)" FontSize="11" FontWeight="Bold" Foreground="#94A3B8" Margin="2,0,0,6"/>
                        <TextBox x:Name="txtRFC" Height="40" Style="{StaticResource TxtCliente}" Margin="0,0,0,14"/>

                        <Border Background="#EFF6FF"
                                BorderBrush="#BFDBFE"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12"
                                Margin="0,0,0,14">

                            <StackPanel>
                                <TextBlock Text="💳 Crédito / Fiado"
                                           FontSize="13" FontWeight="Bold" Foreground="#1E3A8A" Margin="0,0,0,8"/>

                                <TextBlock Text="LÍMITE DE CRÉDITO" FontSize="11" FontWeight="Bold" Foreground="#94A3B8" Margin="2,0,0,6"/>
                                <TextBox x:Name="txtLimiteCredito" Height="38" Style="{StaticResource TxtCliente}" Text="0"/>

                                <TextBlock x:Name="txtSaldoInfo"
                                           Text="Saldo actual: $0.00"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="#DC2626"
                                           Margin="0,10,0,0"/>
                            </StackPanel>

                        </Border>

                        <CheckBox x:Name="chkActivo"
                                  Content="Cliente Activo"
                                  FontSize="14"
                                  IsChecked="True"
                                  Margin="0,0,0,20"/>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Button Content="🆕 Nuevo"
                                    Height="46"
                                    Background="#9CA3AF"
                                    Style="{StaticResource BtnAccionCliente}"
                                    Click="BtnNuevo_Click"/>

                            <Button Grid.Column="2"
                                    Content="💾 Guardar"
                                    Height="46"
                                    Background="#2563EB"
                                    Style="{StaticResource BtnAccionCliente}"
                                    Click="BtnGuardar_Click"/>
                        </Grid>

                        <Button Content="🗑️ Eliminar Cliente"
                                Height="42"
                                Background="#DC2626"
                                Style="{StaticResource BtnAccionCliente}"
                                Click="BtnEliminar_Click"/>

                        <Separator Margin="0,20,0,15"/>

                        <TextBlock Text="Registrar abono / pago"
                                   FontSize="15" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,10"/>

                        <TextBlock Text="MONTO DEL ABONO" FontSize="11" FontWeight="Bold" Foreground="#94A3B8" Margin="2,0,0,6"/>
                        <TextBox x:Name="txtMontoAbono" Height="40" Style="{StaticResource TxtCliente}" Margin="0,0,0,10"/>

                        <TextBlock Text="MOTIVO / NOTA" FontSize="11" FontWeight="Bold" Foreground="#94A3B8" Margin="2,0,0,6"/>
                        <TextBox x:Name="txtMotivoAbono" Height="40" Style="{StaticResource TxtCliente}" Margin="0,0,0,14"/>

                        <Button Content="💰 Registrar Abono"
                                Height="44"
                                Background="#16A34A"
                                Style="{StaticResource BtnAccionCliente}"
                                Click="BtnRegistrarAbono_Click"/>

                    </StackPanel>

                </ScrollViewer>

            </Border>

            <!-- ===================================== -->
            <!-- LISTA + PESTAÑAS DE DETALLE            -->
            <!-- ===================================== -->

            <Grid Grid.Column="1">

                <Grid.RowDefinitions>
                    <RowDefinition Height="2*"/>
                    <RowDefinition Height="3*"/>
                </Grid.RowDefinitions>

                <!-- LISTA DE CLIENTES -->
                <Border Background="White"
                        CornerRadius="12"
                        Padding="12"
                        Margin="0,0,0,12">

                    <DataGrid x:Name="dgClientes"
                              AutoGenerateColumns="False"
                              HeadersVisibility="Column"
                              IsReadOnly="True"
                              BorderThickness="0"
                              RowHeight="38"
                              FontSize="14"
                              CanUserAddRows="False"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#F1F5F9"
                              SelectionChanged="dgClientes_SelectionChanged">

                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#F8FAFC"/>
                                <Setter Property="Foreground" Value="#64748B"/>
                                <Setter Property="FontSize" Value="12"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Padding" Value="10,8"/>
                                <Setter Property="BorderThickness" Value="0"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>

                        

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Nombre" Binding="{Binding Nombre}" Width="*"/>
                            <DataGridTextColumn Header="Teléfono" Binding="{Binding Telefono}" Width="130"/>
                            <DataGridTextColumn Header="Límite Crédito" Binding="{Binding LimiteCredito, StringFormat=C}" Width="130"/>
                            <DataGridTextColumn Header="Saldo Actual" Binding="{Binding SaldoActual, StringFormat=C}" Width="130"/>
                            <DataGridCheckBoxColumn Header="Activo" Binding="{Binding Activo}" Width="80"/>
                        </DataGrid.Columns>

                    </DataGrid>

                </Border>

                <!-- PESTAÑAS DE DETALLE DEL CLIENTE SELECCIONADO -->
                <Border Background="White"
                        CornerRadius="12"
                        Padding="12">

                    <TabControl BorderThickness="0" Background="Transparent">

                        <TabItem Header="🧾 Historial de Compras">

                            <DataGrid x:Name="dgHistorialCompras"
                                      AutoGenerateColumns="False"
                                      HeadersVisibility="Column"
                                      IsReadOnly="True"
                                      BorderThickness="0"
                                      RowHeight="36"
                                      FontSize="13"
                                      CanUserAddRows="False"
                                      GridLinesVisibility="Horizontal"
                                      HorizontalGridLinesBrush="#F1F5F9"
                                      Margin="0,10,0,0">

                                <DataGrid.ColumnHeaderStyle>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background" Value="#F8FAFC"/>
                                        <Setter Property="Foreground" Value="#64748B"/>
                                        <Setter Property="FontSize" Value="12"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="Padding" Value="10,8"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                    </Style>
                                </DataGrid.ColumnHeaderStyle>

                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Venta #" Binding="{Binding VentaId}" Width="90"/>
                                    <DataGridTextColumn Header="Fecha" Binding="{Binding Fecha, StringFormat=dd/MM/yyyy HH:mm}" Width="160"/>
                                    <DataGridTextColumn Header="Tipo de Pago" Binding="{Binding TipoPago}" Width="130"/>
                                    <DataGridTextColumn Header="Total" Binding="{Binding Total, StringFormat=C}" Width="120"/>
                                </DataGrid.Columns>

                            </DataGrid>

                        </TabItem>

                        <TabItem Header="💰 Historial de Abonos">

                            <DataGrid x:Name="dgHistorialAbonos"
                                      AutoGenerateColumns="False"
                                      HeadersVisibility="Column"
                                      IsReadOnly="True"
                                      BorderThickness="0"
                                      RowHeight="36"
                                      FontSize="13"
                                      CanUserAddRows="False"
                                      GridLinesVisibility="Horizontal"
                                      HorizontalGridLinesBrush="#F1F5F9"
                                      Margin="0,10,0,0">

                                <DataGrid.ColumnHeaderStyle>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background" Value="#F8FAFC"/>
                                        <Setter Property="Foreground" Value="#64748B"/>
                                        <Setter Property="FontSize" Value="12"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="Padding" Value="10,8"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                    </Style>
                                </DataGrid.ColumnHeaderStyle>

                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Fecha" Binding="{Binding Fecha, StringFormat=dd/MM/yyyy HH:mm}" Width="160"/>
                                    <DataGridTextColumn Header="Monto" Binding="{Binding Monto, StringFormat=C}" Width="120"/>
                                    <DataGridTextColumn Header="Saldo después" Binding="{Binding SaldoDespues, StringFormat=C}" Width="130"/>
                                    <DataGridTextColumn Header="Motivo" Binding="{Binding Motivo}" Width="*"/>
                                </DataGrid.Columns>

                            </DataGrid>

                        </TabItem>

                    </TabControl>

                </Border>

            </Grid>

        </Grid>

    </Grid>

</Window>