<Window x:Class="FarmaciaPOS.Views.SeleccionarPrecioWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cambiar precio"
        Height="430"
        Width="430"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#F0F4F8">

    <Grid Margin="20">

        <Border Background="White"
                CornerRadius="15"
                Padding="25">

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- ENCABEZADO -->

                <StackPanel Margin="0,0,0,15">

                    <TextBlock Text="💲 Cambiar Precio"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="#1E3A8A"/>

                    <TextBlock x:Name="txtProducto"
                               Margin="0,6,0,0"
                               FontSize="14"
                               Foreground="#64748B"/>

                </StackPanel>

                <!-- OPCIONES DE PRECIO -->

                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Margin="0,5,0,0">

                    <StackPanel>

                        <!-- PRECIO 1 -->

                        <RadioButton x:Name="rb1"
                                     Margin="0,5"
                                     IsChecked="True">

                            <Border Background="#F0FDF4"
                                    BorderBrush="#86EFAC"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="14">

                                <Grid>

                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel>

                                        <TextBlock Text="💵 Precio 1"
                                                   FontWeight="Bold"
                                                   FontSize="14"
                                                   Foreground="#166534"/>

                                        <TextBlock Text="Precio estándar"
                                                   FontSize="11"
                                                   Foreground="#4ADE80"/>

                                    </StackPanel>

                                    <TextBlock x:Name="lblPrecio1"
                                               Grid.Column="1"
                                               FontSize="22"
                                               FontWeight="Bold"
                                               Foreground="#16A34A"
                                               VerticalAlignment="Center"/>

                                </Grid>

                            </Border>

                        </RadioButton>

                        <!-- PRECIO 2 -->

                        <RadioButton x:Name="rb2"
                                     Margin="0,5">

                            <Border Background="#EFF6FF"
                                    BorderBrush="#93C5FD"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="14">

                                <Grid>

                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel>

                                        <TextBlock Text="📦 Precio 2"
                                                   FontWeight="Bold"
                                                   FontSize="14"
                                                   Foreground="#1E40AF"/>

                                        <TextBlock x:Name="lblCantidad2"
                                                   FontSize="11"
                                                   Foreground="#60A5FA"/>

                                    </StackPanel>

                                    <TextBlock x:Name="lblPrecio2"
                                               Grid.Column="1"
                                               FontSize="22"
                                               FontWeight="Bold"
                                               Foreground="#2563EB"
                                               VerticalAlignment="Center"/>

                                </Grid>

                            </Border>

                        </RadioButton>

                        <!-- PRECIO 3 -->

                        <RadioButton x:Name="rb3"
                                     Margin="0,5">

                            <Border Background="#FFF7ED"
                                    BorderBrush="#FCA5A5"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="14">

                                <Grid>

                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel>

                                        <TextBlock Text="🏭 Precio 3"
                                                   FontWeight="Bold"
                                                   FontSize="14"
                                                   Foreground="#9A3412"/>

                                        <TextBlock x:Name="lblCantidad3"
                                                   FontSize="11"
                                                   Foreground="#F87171"/>

                                    </StackPanel>

                                    <TextBlock x:Name="lblPrecio3"
                                               Grid.Column="1"
                                               FontSize="22"
                                               FontWeight="Bold"
                                               Foreground="#DC2626"
                                               VerticalAlignment="Center"/>

                                </Grid>

                            </Border>

                        </RadioButton>

                    </StackPanel>

                </ScrollViewer>

                <!-- BOTONES -->

                <Grid Grid.Row="2"
                      Margin="0,20,0,0">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Content="✕ Cancelar"
                            Height="44"
                            FontSize="15"
                            FontWeight="Bold"
                            Background="#F1F5F9"
                            Foreground="#374151"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="Cancelar_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="b"
                                        Background="{TemplateBinding Background}"
                                        CornerRadius="10">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="b" Property="Background" Value="#E2E8F0"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Grid.Column="2"
                            Content="✔ Aceptar"
                            Height="44"
                            FontSize="15"
                            FontWeight="Bold"
                            Background="#2563EB"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="Aceptar_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="b"
                                        Background="{TemplateBinding Background}"
                                        CornerRadius="10">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="b" Property="Background" Value="#1D4ED8"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                </Grid>

            </Grid>

        </Border>

    </Grid>

</Window>