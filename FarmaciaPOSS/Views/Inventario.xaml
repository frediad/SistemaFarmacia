<Window x:Class="FarmaciaPOS.Views.InventarioWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Inventario"
        Height="700"
        Width="1100"
        Icon="/logo-icono.ico"
        WindowStartupLocation="CenterScreen"
        Background="#F0F4F8">

    <Window.Resources>

        <Style x:Key="TxtInventario" TargetType="TextBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#2563EB"/>
                                <Setter TargetName="border" Property="Background" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CboInventario" TargetType="ComboBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1.5"/>
        </Style>

        <Style x:Key="BtnGuardarMovimiento" TargetType="Button">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1D4ED8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
            
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Background="#1E3A8A" Grid.Row="0">
            <Grid Margin="20,0">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="📦  Inventario"
                   Foreground="White"
                   FontSize="20"
                   FontWeight="Bold"
                   VerticalAlignment="Center"/>

                <Button Grid.Column="1"
                Content="✕ Cerrar"
                Width="100"
                Height="38"
                FontSize="14"
                FontWeight="Bold"
                Background="#DC2626"
                Foreground="White"
                BorderThickness="0"
                Cursor="Hand"
                VerticalAlignment="Center"
                Click="BtnCerrarVentana_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

            </Grid>
        </Border>

        <!-- CONTENIDO -->
        <Grid Grid.Row="1" Margin="15">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <!-- ===================================== -->
            <!-- COLUMNA IZQUIERDA: FORM + MOVIMIENTOS -->
            <!-- ===================================== -->

            <Grid Margin="0,0,10,0">

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- FORMULARIO -->
                <Border Background="White"
                        CornerRadius="12"
                        Padding="18"
                        Margin="0,0,0,12">

                    <Grid>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="130"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Margin="0,0,10,0">
                            <TextBlock Text="PRODUCTO" FontSize="11" FontWeight="Bold" Foreground="#94A3B8" Margin="0,0,0,6"/>
                            <ComboBox x:Name="cbProductos" Height="38" Style="{StaticResource CboInventario}"
                                      SelectionChanged="cbProductos_SelectionChanged"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="0,0,10,0">
                            <TextBlock Text="MOVIMIENTO" FontSize="11" FontWeight="Bold" Foreground="#94A3B8" Margin="0,0,0,6"/>
                            <ComboBox x:Name="cbTipo" Height="38" Style="{StaticResource CboInventario}">
                                <ComboBoxItem Content="Entrada"/>
                                <ComboBoxItem Content="Salida"/>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Margin="0,0,10,0">
                            <TextBlock Text="CANTIDAD" FontSize="11" FontWeight="Bold" Foreground="#94A3B8" Margin="0,0,0,6"/>
                            <TextBox x:Name="txtCantidad" Height="38" Style="{StaticResource TxtInventario}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="3" Margin="0,0,10,0">
                            <TextBlock Text="MOTIVO" FontSize="11" FontWeight="Bold" Foreground="#94A3B8" Margin="0,0,0,6"/>
                            <TextBox x:Name="txtMotivo" Height="38" Style="{StaticResource TxtInventario}"/>
                        </StackPanel>

                        <Button Grid.Column="4"
                                Content="💾 Guardar"
                                Height="38"
                                VerticalAlignment="Bottom"
                                Style="{StaticResource BtnGuardarMovimiento}"
                                Click="BtnGuardar_Click"/>

                        <TextBlock x:Name="txtStockActualInfo"
                                   Grid.Row="1"
                                   Grid.ColumnSpan="5"
                                   Text=""
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="#2563EB"
                                   Margin="0,10,0,0"/>

                    </Grid>

                </Border>

                <!-- HISTORIAL DE MOVIMIENTOS -->
                <Border Grid.Row="1"
                        Background="White"
                        CornerRadius="12"
                        Padding="10">

                    <Grid>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Historial de movimientos"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Foreground="#1E293B"
                                   Margin="6,4,0,10"/>

                        <DataGrid x:Name="dgMovimientos"
                                  Grid.Row="1"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  IsReadOnly="True"
                                  HeadersVisibility="Column"
                                  BorderThickness="0"
                                  RowHeight="36"
                                  FontSize="13"
                                  GridLinesVisibility="Horizontal"
                                  HorizontalGridLinesBrush="#F1F5F9">

                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#F8FAFC"/>
                                    <Setter Property="Foreground" Value="#64748B"/>
                                    <Setter Property="FontSize" Value="12"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="Padding" Value="10,8"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>

                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding TipoMovimiento}" Value="Entrada">
                                            <Setter Property="Background" Value="#F0FDF4"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding TipoMovimiento}" Value="Salida">
                                            <Setter Property="Background" Value="#FEF2F2"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>

                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Producto" Binding="{Binding ProductoNombre}" Width="*"/>
                                <DataGridTextColumn Header="Movimiento" Binding="{Binding TipoMovimiento}" Width="110"/>
                                <DataGridTextColumn Header="Cantidad" Binding="{Binding Cantidad}" Width="90"/>
                                <DataGridTextColumn Header="Fecha" Binding="{Binding Fecha}" Width="150"/>
                                <DataGridTextColumn Header="Motivo" Binding="{Binding Motivo}" Width="220"/>
                            </DataGrid.Columns>

                        </DataGrid>

                    </Grid>

                </Border>

            </Grid>

            <!-- ===================================== -->
            <!-- COLUMNA DERECHA: ALERTAS DE STOCK       -->
            <!-- ===================================== -->

            <Border Grid.Column="1"
                    Background="White"
                    CornerRadius="12"
                    Padding="14">

                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Margin="4,0,0,10">
                        <TextBlock Text="⚠️ Estado del inventario"
                                   FontSize="15"
                                   FontWeight="Bold"
                                   Foreground="#1E293B"/>
                        <TextBlock x:Name="txtResumenAlertas"
                                   Text="Cargando..."
                                   FontSize="12"
                                   Foreground="#94A3B8"
                                   Margin="0,2,0,0"/>
                    </StackPanel>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">

                        <ItemsControl x:Name="icAlertasStock">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{Binding ColorFondo}"
                                            CornerRadius="10"
                                            Padding="10"
                                            Margin="0,0,0,8">

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel>
                                                <TextBlock Text="{Binding Nombre}"
                                                           FontSize="13"
                                                           FontWeight="Bold"
                                                           Foreground="#1E293B"
                                                           TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding Detalle}"
                                                           FontSize="11"
                                                           Foreground="#64748B"/>
                                            </StackPanel>

                                            <Border Grid.Column="1"
                                                    Background="{Binding ColorBadge}"
                                                    CornerRadius="8"
                                                    Padding="8,4"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Etiqueta}"
                                                           FontSize="11"
                                                           FontWeight="Bold"
                                                           Foreground="White"/>
                                            </Border>

                                        </Grid>

                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                    </ScrollViewer>

                </Grid>

            </Border>

        </Grid>

    </Grid>

</Window>