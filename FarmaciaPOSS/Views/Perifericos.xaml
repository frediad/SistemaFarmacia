<Window x:Class="FarmaciaPOS.Views.Perifericos"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configuración POS"
        Height="700"
        Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#F0F4F8">

    <Window.Resources>

        <Style x:Key="TxtConfig" TargetType="TextBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#2563EB"/>
                                <Setter TargetName="border" Property="Background" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CboConfig" TargetType="ComboBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1.5"/>
        </Style>

        <Style x:Key="BtnAccionConfig" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="65"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Background="#1E3A8A" Grid.Row="0">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="100"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="⚙️  Configuración de dispositivos"
                           Foreground="White"
                           FontSize="20"
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>

                <Button Grid.Column="1"
                        Content="✕ Cerrar"
                        Width="90"
                        Height="36"
                        FontSize="13"
                        FontWeight="Bold"
                        Background="#DC2626"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        VerticalAlignment="Center"
                        Click="BtnCerrarVentana_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <!-- PESTAÑAS -->
        <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0" Margin="15">

            <!-- ===================================== -->
            <!-- IMPRESORA DE TICKETS                   -->
            <!-- ===================================== -->

            <TabItem Header="🖨️ Impresora de Tickets">

                <Border Background="White" CornerRadius="12" Padding="20" Margin="0,15,0,0">

                    <StackPanel>

                        <TextBlock Text="Selecciona la impresora de tickets"
                                   FontSize="16" FontWeight="Bold" Foreground="#1E293B"/>

                        <TextBlock Text="Se usará esta impresora cada vez que el sistema genere un ticket de venta."
                                   FontSize="12" Foreground="#94A3B8" Margin="0,4,0,20"/>

                        <ComboBox x:Name="cbImpresoras"
                                  Height="42"
                                  Style="{StaticResource CboConfig}"
                                  Margin="0,0,0,15"/>

                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Button Content="🔄 Actualizar lista"
                                    Height="42"
                                    Background="#64748B"
                                    Style="{StaticResource BtnAccionConfig}"
                                    Click="BtnActualizarImpresoras_Click"/>

                            <Button Grid.Column="2"
                                    Content="🖨️ Imprimir ticket de prueba"
                                    Height="42"
                                    Background="#2563EB"
                                    Style="{StaticResource BtnAccionConfig}"
                                    Click="BtnProbarImpresora_Click"/>
                        </Grid>

                        <TextBlock x:Name="txtEstadoImpresora"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Margin="0,15,0,0"
                                   TextWrapping="Wrap"/>

                    </StackPanel>

                </Border>

            </TabItem>

            <!-- ===================================== -->
            <!-- ESCÁNER                                -->
            <!-- ===================================== -->

            <TabItem Header="🔍 Escáner de Código de Barras">

                <Border Background="White" CornerRadius="12" Padding="20" Margin="0,15,0,0">

                    <StackPanel>

                        <TextBlock Text="Prueba de funcionamiento del escáner"
                                   FontSize="16" FontWeight="Bold" Foreground="#1E293B"/>

                        <TextBlock TextWrapping="Wrap"
                                   FontSize="12" Foreground="#94A3B8" Margin="0,4,0,20">
                            La mayoría de los lectores de código de barras funcionan como un teclado (no requieren
                            controlador especial). Para verificar que funciona, haz clic en el campo de abajo y
                            escanea cualquier código de barras — el sistema detecta si la entrada llegó demasiado
                            rápido para haber sido escrita a mano.
                        </TextBlock>

                        <TextBox x:Name="txtPruebaEscaner"
                                 Height="46"
                                 FontSize="16"
                                 Style="{StaticResource TxtConfig}"
                                 Margin="0,0,0,15"
                                 PreviewKeyDown="txtPruebaEscaner_PreviewKeyDown"
                                 GotFocus="txtPruebaEscaner_GotFocus"/>

                        <Border x:Name="borderResultadoEscaner"
                                Background="#F8FAFC"
                                CornerRadius="10"
                                Padding="14"
                                Visibility="Collapsed">

                            <StackPanel>
                                <TextBlock x:Name="txtResultadoEscaner"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           TextWrapping="Wrap"/>
                                <TextBlock x:Name="txtDetalleEscaner"
                                           FontSize="12"
                                           Foreground="#64748B"
                                           Margin="0,4,0,0"/>
                            </StackPanel>

                        </Border>

                    </StackPanel>

                </Border>

            </TabItem>

            
            

        </TabControl>

    </Grid>

</Window>