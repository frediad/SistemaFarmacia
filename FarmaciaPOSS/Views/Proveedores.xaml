<Window x:Class="FarmaciaPOS.Views.ProveedoresWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Proveedores"
        Height="650"
        Width="1000"
        Icon="/logo-icono.ico"
        WindowStartupLocation="CenterScreen"
        Background="#F0F4F8">

    <Window.Resources>

        <!-- ===================================== -->
        <!-- ESTILO BOTÓN PRIMARIO (Agregar)       -->
        <!-- ===================================== -->

        <Style x:Key="BtnPrimario" TargetType="Button">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1D4ED8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1E40AF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===================================== -->
        <!-- ESTILO BOTÓN SECUNDARIO (Eliminar)    -->
        <!-- ===================================== -->

        <Style x:Key="BtnSecundario" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#DC2626"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="BorderBrush" Value="#FCA5A5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FEF2F2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===================================== -->
        <!-- ESTILO BOTÓN ACCIÓN (Pedir Mercancía) -->
        <!-- ===================================== -->

        <Style x:Key="BtnAccionPrincipal" TargetType="Button">
            <Setter Property="Background" Value="#16A34A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Padding="18,0">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#15803D"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#166534"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===================================== -->
        <!-- ESTILO ENCABEZADOS DATAGRID           -->
        <!-- ===================================== -->

        <Style x:Key="HeaderProveedores" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>

    </Window.Resources>

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="90"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="90"/>
        </Grid.RowDefinitions>

        <!-- ========================================= -->
        <!-- HEADER                                    -->
        <!-- ========================================= -->

        <Border Grid.Row="0"
                Background="#1E3A8A">

            <Grid Margin="30,0">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center">

                    <TextBlock Text="🚚 Gestión de Proveedores"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="White"/>

                    <TextBlock Text="Administra tus proveedores y solicita mercancía"
                               FontSize="13"
                               Foreground="#BFDBFE"
                               Margin="0,4,0,0"/>

                </StackPanel>

                <Button Grid.Column="2"
                        Content="✕ Cerrar"
                        Width="100"
                        Height="40"
                        FontSize="14"
                        FontWeight="Bold"
                        Background="#DC2626"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        VerticalAlignment="Center"
                        Click="BtnCerrarVentana_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

            </Grid>

        </Border>

        

        <!-- ========================================= -->
        <!-- TABLA                                     -->
        <!-- ========================================= -->

        <Border Grid.Row="1"
                Background="White"
                CornerRadius="14"
                Margin="24,20">

            <Border.Effect>
                <DropShadowEffect Color="#000000"
                                  Opacity="0.06"
                                  BlurRadius="16"
                                  ShadowDepth="2"/>
            </Border.Effect>

            <DataGrid x:Name="dgProveedores"
                      AutoGenerateColumns="False"
                      HeadersVisibility="Column"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      FontSize="14"
                      RowHeight="46"
                      BorderThickness="0"
                      Background="Transparent"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#F1F5F9"
                      AlternatingRowBackground="#FAFBFC"
                      SelectionMode="Single"
                      SelectionUnit="FullRow"
                      RowBackground="White"
                      ColumnHeaderStyle="{StaticResource HeaderProveedores}"
                      Margin="4">

                <DataGrid.Columns>

                    <DataGridTextColumn
                        Header="NOMBRE"
                        Binding="{Binding Nombre}"
                        Width="180">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Foreground" Value="#1E293B"/>
                                <Setter Property="Margin" Value="14,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn
                        Header="TELÉFONO"
                        Binding="{Binding Telefono}"
                        Width="130">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Foreground" Value="#475569"/>
                                <Setter Property="Margin" Value="14,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn
                        Header="CORREO"
                        Binding="{Binding Correo}"
                        Width="220">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Foreground" Value="#475569"/>
                                <Setter Property="Margin" Value="14,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn
                        Header="DIRECCIÓN"
                        Binding="{Binding Direccion}"
                        Width="220">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Foreground" Value="#475569"/>
                                <Setter Property="Margin" Value="14,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn
                        Header="CONTACTO"
                        Binding="{Binding Contacto}"
                        Width="*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Foreground" Value="#475569"/>
                                <Setter Property="Margin" Value="14,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                </DataGrid.Columns>

            </DataGrid>

        </Border>

        <!-- ========================================= -->
        <!-- BOTONES                                   -->
        <!-- ========================================= -->

        <Grid Grid.Row="2"
              Margin="24,0,24,20">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center">

                <Button Content="➕ Agregar"
                        Width="140"
                        Height="46"
                        Style="{StaticResource BtnPrimario}"
                        Margin="0,0,10,0"
                        Click="BtnAgregar_Click"/>

                <Button Content="🗑️ Eliminar"
                        Width="140"
                        Height="46"
                        Style="{StaticResource BtnSecundario}"
                        Click="BtnEliminar_Click"/>

            </StackPanel>

            <Button x:Name="btnPedirMercancia"
                    Grid.Column="1"
                    Content="📧 Pedir Mercancía"
                    Width="200"
                    Height="46"
                    Style="{StaticResource BtnAccionPrincipal}"
                    VerticalAlignment="Center"
                    Click="BtnPedirMercancia_Click"/>

        </Grid>

    </Grid>

</Window>