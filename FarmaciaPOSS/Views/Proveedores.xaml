<Window x:Class="FarmaciaPOS.Views.ProveedoresWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Proveedores"
        Height="600"
        Width="950"
        Icon="/logo-icono.ico"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7FA">

    <Grid Margin="20">

        <Grid.RowDefinitions>

            <RowDefinition Height="Auto"/>

            <RowDefinition Height="*"/>

            <RowDefinition Height="80"/>

        </Grid.RowDefinitions>

        <!-- TÍTULO -->

        <TextBlock Text="Gestión de Proveedores"
                   FontSize="30"
                   FontWeight="Bold"
                   Margin="0,0,0,20"/>

        <!-- TABLA -->

        <DataGrid x:Name="dgProveedores"
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  FontSize="16"
                  CanUserAddRows="False">

            <DataGrid.Columns>

                <DataGridTextColumn
                    Header="Nombre"
                    Binding="{Binding Nombre}"
                    Width="180"/>

                <DataGridTextColumn
                    Header="Teléfono"
                    Binding="{Binding Telefono}"
                    Width="130"/>

                <DataGridTextColumn
                    Header="Correo"
                    Binding="{Binding Correo}"
                    Width="220"/>

                <DataGridTextColumn
                    Header="Dirección"
                    Binding="{Binding Direccion}"
                    Width="220"/>

                <DataGridTextColumn
                    Header="Contacto"
                    Binding="{Binding Contacto}"
                    Width="180"/>

            </DataGrid.Columns>

        </DataGrid>

        <!-- BOTONES -->

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center">

            <Button Content="Agregar"
                    Width="150"
                    Height="45"
                    Margin="10"
                    FontSize="16"
                    Click="BtnAgregar_Click"/>

            <Button Content="Eliminar"
                    Width="150"
                    Height="45"
                    Margin="10"
                    FontSize="16"
                    Click="BtnEliminar_Click"/>

        </StackPanel>

    </Grid>

</Window>