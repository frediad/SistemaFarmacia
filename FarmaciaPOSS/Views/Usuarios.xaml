<Window x:Class="FarmaciaPOS.Views.UsuariosWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Usuarios y Roles"
        Height="700"
        Width="1100"
        Icon="/logo-icono.ico"
        WindowStartupLocation="CenterScreen"
        Background="#F0F4F8">

    <Window.Resources>

        <Style x:Key="BtnAccion" TargetType="Button">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TxtField" TargetType="TextBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,5,0,12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="White"
                                BorderBrush="#CBD5E1"
                                BorderThickness="1"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="10,0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid Margin="15">

        <Grid.RowDefinitions>
            <RowDefinition Height="100"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ========================================= -->
        <!-- HEADER                                    -->
        <!-- ========================================= -->

        <Border Background="#1E3A8A"
                CornerRadius="12"
                Padding="20"
                Margin="0,0,0,15">

            <StackPanel VerticalAlignment="Center">

                <TextBlock Text="👤Gestión de Usuarios y Roles"
                           FontSize="26"
                           FontWeight="Bold"
                           Foreground="White"/>

                <TextBlock Text="Administra usuarios, roles y permisos de acceso"
                           FontSize="13"
                           Foreground="#93C5FD"/>
                
                

            </StackPanel>
            
            

        </Border>

        <!-- ========================================= -->
        <!-- CONTENIDO                                 -->
        <!-- ========================================= -->

        <Grid Grid.Row="1">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360"/>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ===================================== -->
            <!-- FORMULARIO USUARIO                    -->
            <!-- ===================================== -->

            <Border Background="White"
                    CornerRadius="12"
                    Padding="20"
                    Margin="0,0,12,0"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1">

                <ScrollViewer VerticalScrollBarVisibility="Auto">

                    <StackPanel>

                        <TextBlock Text="Datos del Usuario"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#1E293B"
                                   Margin="0,0,0,15"/>

                        <TextBlock Text="Nombre"
                                   FontSize="12"
                                   FontWeight="Bold"
                                   Foreground="#374151"/>

                        <TextBox x:Name="txtNombre"
                                 Style="{StaticResource TxtField}"/>

                        <TextBlock Text="Apellido"
                                   FontSize="12"
                                   FontWeight="Bold"
                                   Foreground="#374151"/>

                        <TextBox x:Name="txtApellido"
                                 Style="{StaticResource TxtField}"/>

                        <TextBlock Text="Usuario (Login)"
                                   FontSize="12"
                                   FontWeight="Bold"
                                   Foreground="#374151"/>

                        <TextBox x:Name="txtUsuarioLogin"
                                 Style="{StaticResource TxtField}"/>

                        <TextBlock Text="Correo"
                                   FontSize="12"
                                   FontWeight="Bold"
                                   Foreground="#374151"/>

                        <TextBox x:Name="txtCorreo"
                                 Style="{StaticResource TxtField}"/>

                        <TextBlock Text="Teléfono"
                                   FontSize="12"
                                   FontWeight="Bold"
                                   Foreground="#374151"/>

                        <TextBox x:Name="txtTelefono"
                                 Style="{StaticResource TxtField}"/>

                        <TextBlock Text="Contraseña"
                                   FontSize="12"
                                   FontWeight="Bold"
                                   Foreground="#374151"/>

                        <Grid Margin="0,5,0,12">

                            <Border BorderBrush="#CBD5E1"
                                    BorderThickness="1"
                                    CornerRadius="8">

                                <PasswordBox x:Name="txtPassword"
                                             Height="38"
                                             FontSize="14"
                                             BorderThickness="0"
                                             Padding="10,0"
                                             PasswordChanged="TxtPassword_PasswordChanged"/>

                            </Border>

                            <TextBlock x:Name="txtPlaceholderPassword"
                                       Text="•••••••• (contraseña guardada)"
                                       FontSize="12"
                                       Foreground="#94A3B8"
                                       IsHitTestVisible="False"
                                       VerticalAlignment="Center"
                                       Margin="12,0,0,0"
                                       Visibility="Collapsed"/>

                        </Grid>

                        <TextBlock Text="(Dejar vacío para no cambiarla al editar)"
                                   FontSize="11"
                                   Foreground="#94A3B8"
                                   Margin="0,0,0,12"/>

                        <TextBlock Text="Rol"
                                   FontSize="12"
                                   FontWeight="Bold"
                                   Foreground="#374151"/>

                        <Border BorderBrush="#CBD5E1"
                                BorderThickness="1"
                                CornerRadius="8"
                                Margin="0,5,0,12">

                            <ComboBox x:Name="cbRoles"
                                      Height="36"
                                      FontSize="14"
                                      BorderThickness="0"
                                      Background="Transparent"
                                      DisplayMemberPath="Nombre"
                                      SelectedValuePath="Id"
                                      Padding="8,0"/>

                        </Border>

                        <CheckBox x:Name="chkActivo"
                                  Content="Usuario Activo"
                                  FontSize="14"
                                  Foreground="#374151"
                                  IsChecked="True"
                                  Margin="0,5,0,20"/>

                        <Grid Margin="0,0,0,8">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0"
                                    Content="🆕 Nuevo"
                                    Style="{StaticResource BtnAccion}"
                                    Background="#64748B"
                                    Click="BtnNuevo_Click"/>

                            <Button Grid.Column="2"
                                    Content="💾 Guardar"
                                    Style="{StaticResource BtnAccion}"
                                    Background="#2563EB"
                                    Click="BtnGuardar_Click"/>

                        </Grid>

                        <Button Content="🗑️ Eliminar Usuario"
                                Style="{StaticResource BtnAccion}"
                                Background="#DC2626"
                                Click="BtnEliminar_Click"/>

                    </StackPanel>

                </ScrollViewer>

            </Border>

            <!-- ===================================== -->
            <!-- ✅ CHECKLIST DE MÓDULOS               -->
            <!-- ===================================== -->

            <Border Grid.Column="1"
                    Background="White"
                    CornerRadius="12"
                    Padding="20"
                    Margin="0,0,12,0"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1">

                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="🔐 Permisos de Acceso"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="#1E293B"
                               Margin="0,0,0,4"/>

                    <TextBlock Grid.Row="1"
                               Text="Solo verá los módulos habilitados"
                               FontSize="11"
                               Foreground="#94A3B8"
                               Margin="0,0,0,12"/>

                    <ScrollViewer Grid.Row="2"
                                  VerticalScrollBarVisibility="Auto">

                        <ItemsControl x:Name="icModulos">

                            <ItemsControl.ItemTemplate>
                                <DataTemplate>

                                    <Border Margin="0,3"
                                            CornerRadius="8"
                                            Padding="10,8">

                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#F8FAFC"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding TieneAcceso}"
                                                                 Value="True">
                                                        <Setter Property="Background"
                                                                Value="#EFF6FF"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>

                                        <CheckBox Content="{Binding NombreModulo}"
                                                  IsChecked="{Binding TieneAcceso, Mode=TwoWay}"
                                                  FontSize="14"
                                                  Foreground="#374151"
                                                  FontWeight="SemiBold"/>

                                    </Border>

                                </DataTemplate>
                            </ItemsControl.ItemTemplate>

                        </ItemsControl>

                    </ScrollViewer>

                </Grid>

            </Border>

            <!-- ===================================== -->
            <!-- TABLA DE USUARIOS                     -->
            <!-- ===================================== -->

            <Border Grid.Column="2"
                    Background="White"
                    CornerRadius="12"
                    Padding="15"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1">

                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Usuarios Registrados"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="#1E293B"
                               Margin="0,0,0,10"/>

                    <DataGrid x:Name="dgUsuarios"
                              Grid.Row="1"
                              AutoGenerateColumns="False"
                              FontSize="14"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              BorderThickness="0"
                              RowHeight="40"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#F1F5F9"
                              SelectionChanged="DgUsuarios_SelectionChanged">

                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#F8FAFC"/>
                                <Setter Property="Foreground" Value="#64748B"/>
                                <Setter Property="FontSize" Value="12"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Padding" Value="10,8"/>
                                <Setter Property="BorderThickness" Value="0"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>

                        <DataGrid.Columns>

                            <DataGridTextColumn Header="Usuario"
                                Binding="{Binding UsuarioLogin}"
                                Width="120"/>

                            <DataGridTextColumn Header="Nombre"
                                Binding="{Binding Nombre}"
                                Width="*"/>

                            <DataGridTextColumn Header="Apellido"
                                Binding="{Binding Apellido}"
                                Width="*"/>

                            <DataGridTextColumn Header="Correo"
                                Binding="{Binding Correo}"
                                Width="170"/>

                            <DataGridTextColumn Header="Rol"
                                Binding="{Binding Rol.Nombre}"
                                Width="100"/>

                            <DataGridCheckBoxColumn Header="Activo"
                                Binding="{Binding Activo}"
                                Width="70"/>

                        </DataGrid.Columns>

                    </DataGrid>

                </Grid>

            </Border>

        </Grid>

    </Grid>

</Window>