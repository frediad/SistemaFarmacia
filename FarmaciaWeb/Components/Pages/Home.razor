
@page "/"

<PageTitle>FarmaClick Yatzil</PageTitle>

<div class="dashboard-container">

    <div class="topbar">
        <div>
            <h1>Sistema Farmacia de todos</h1>
            <p>Panel principal del sistema de ventas e inventario</p>
        </div>

        <button class="sales-button">
            Nueva Venta
        </button>
    </div>

    <div class="cards-container">

        <div class="dashboard-card">
            <h3>Ventas del Día</h3>
            <h2>$12,540</h2>
            <p>+15% respecto a ayer</p>
        </div>

        <div class="dashboard-card">
            <h3>Productos en Inventario</h3>
            <h2>1,245</h2>
            <p>Productos disponibles</p>
        </div>

        <div class="dashboard-card">
            <h3>Pedidos Web</h3>
            <h2>32</h2>
            <p>Pedidos pendientes</p>
        </div>

        <div class="dashboard-card alert-card">
            <h3>Stock Bajo</h3>
            <h2>18</h2>
            <p>Productos necesitan reabastecimiento</p>
        </div>

    </div>

    <div class="sections-container">

        <div class="recent-sales">
            <h2>Ventas Recientes</h2>

            <table>
                <thead>
                    <tr>
                        <th>Ticket</th>
                        <th>Cliente</th>
                        <th>Total</th>
                        <th>Estado</th>
                    </tr>
                </thead>

                <tbody>
                    <tr>
                        <td>#00125</td>
                        <td>Juan Pérez</td>
                        <td>$350</td>
                        <td>Completado</td>
                    </tr>

                    <tr>
                        <td>#00126</td>
                        <td>María López</td>
                        <td>$820</td>
                        <td>Completado</td>
                    </tr>

                    <tr>
                        <td>#00127</td>
                        <td>Carlos Ruiz</td>
                        <td>$145</td>
                        <td>Pendiente</td>
                    </tr>
                </tbody>
            </table>
        </div>

        <div class="quick-actions">
            <h2>Acciones Rápidas</h2>

            <button>Agregar Producto</button>
            <button>Consultar Inventario</button>
            <button>Ver Pedidos Web</button>
            <button>Administrar Usuarios</button>
        </div>

    </div>

</div>

<style>

    body {
        background-color: #f4f6f9;
        font-family: Arial, Helvetica, sans-serif;
    }

    .dashboard-container {
        padding: 30px;
    }

    .topbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
    }

    .topbar h1 {
        margin: 0;
        font-size: 38px;
    }

    .topbar p {
        color: #666;
        margin-top: 5px;
    }

    .sales-button {
        background-color: #2563eb;
        color: white;
        border: none;
        padding: 14px 24px;
        border-radius: 10px;
        font-size: 16px;
        cursor: pointer;
    }

    .cards-container {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 20px;
        margin-bottom: 30px;
    }

    .dashboard-card {
        background-color: white;
        border-radius: 18px;
        padding: 25px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.08);
    }

    .dashboard-card h3 {
        color: #666;
        margin-bottom: 10px;
    }

    .dashboard-card h2 {
        font-size: 36px;
        margin: 0;
    }

    .dashboard-card p {
        color: #888;
        margin-top: 10px;
    }

    .alert-card {
        border-left: 6px solid #dc2626;
    }

    .sections-container {
        display: grid;
        grid-template-columns: 2fr 1fr;
        gap: 20px;
    }

    .recent-sales,
    .quick-actions {
        background-color: white;
        border-radius: 18px;
        padding: 25px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.08);
    }

    table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 20px;
    }

    th,
    td {
        padding: 14px;
        border-bottom: 1px solid #e5e7eb;
        text-align: left;
    }

    th {
        background-color: #f3f4f6;
    }

    .quick-actions {
        display: flex;
        flex-direction: column;
        gap: 15px;
    }

    .quick-actions button {
        padding: 14px;
        border: none;
        border-radius: 10px;
        background-color: #10b981;
        color: white;
        font-size: 15px;
        cursor: pointer;
    }

    .quick-actions button:hover {
        opacity: 0.9;
    }

</style>

